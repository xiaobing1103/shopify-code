{% comment %}
  延迟加载非关键脚本
  在 layout/theme.liquid 的 </body> 前使用: {% render 'defer-scripts' %}
{% endcomment %}

<script>
  // 延迟加载非关键脚本
  window.addEventListener('load', function() {
    // 延迟加载的脚本列表
    const deferredScripts = [
      '{{ "custom.js" | asset_url }}',
      '{{ "product-canvas-editor.js" | asset_url }}',
      // 根据需要添加其他非关键脚本
    ];

    deferredScripts.forEach(function(src) {
      const script = document.createElement('script');
      script.src = src;
      script.async = true;
      document.body.appendChild(script);
    });
  });

  // 延迟加载第三方应用脚本
  function loadThirdPartyScripts() {
    // Ecomposer
    if (typeof ecomposerInit !== 'undefined') {
      setTimeout(ecomposerInit, 2000);
    }

    // PageFly
    if (typeof pageflyInit !== 'undefined') {
      setTimeout(pageflyInit, 2000);
    }
  }

  // 在页面交互后加载
  ['scroll', 'mousemove', 'touchstart'].forEach(function(event) {
    window.addEventListener(event, function() {
      loadThirdPartyScripts();
    }, { once: true, passive: true });
  });

  // 或在 3 秒后自动加载
  setTimeout(loadThirdPartyScripts, 3000);
</script>
