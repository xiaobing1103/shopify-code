{%- comment -%}
  Main Product Color Selector Snippet
  独立复制 product-color-selector 的逻辑，只给 main-product 使用。
  目的：避免通过 render 原 snippet + 外层 CSS 的方式影响原始样式。
{%- endcomment -%}

{%- liquid
  assign color_mode = bk_stts.color_mode | default: 'color'
  assign selector_mode = bk_stts.selector_mode | default: 'default'
  assign color_size = bk_stts.color_size | default: 'medium'
  assign title_label = bk_stts.title_label | default: ''
  assign title_spacing = bk_stts.title_spacing | default: 16
  assign title_spacing_mobile = bk_stts.title_spacing_mobile | default: title_spacing
  assign title_gap = bk_stts.title_gap | default: 2
  assign title_gap_mobile = bk_stts.title_gap_mobile | default: title_gap
  assign title_font_size = bk_stts.title_font_size | default: 14
  assign title_font_size_mobile = bk_stts.title_font_size_mobile | default: title_font_size
  assign title_font_weight = bk_stts.title_font_weight | default: 400
  assign title_font_weight_mobile = bk_stts.title_font_weight_mobile | default: title_font_weight
  assign title_layout = bk_stts.title_layout | default: 'space-between'
  assign title_justify = title_layout
  if title_layout == 'left'
    assign title_justify = 'flex-start'
  elsif title_layout == 'right'
    assign title_justify = 'flex-end'
  endif

  assign color_swatch = 'disabled-'
  assign color_mode_list = 'color, color is-sw-cl__round, variant_image, variant_image is-sw-cl__round' | split: ', '
  if color_mode_list contains color_mode
    assign color_swatch = 'is-sw__color '
  endif

  if color_mode contains 'color' or color_mode contains 'variant'
    assign show_tooltip = ''
  else
    assign show_tooltip = '-off'
  endif
-%}

{%- if isProductDefault == false -%}
  {{ 'swatch.css' | asset_url | append: '?v=20251201-v3' | stylesheet_tag }}

  {%- assign independent_form_id = 'product-form-independent-main-' | append: pr_se_id -%}

  <style>
    #t4s-callBackVariant{{ independent_form_id }} .t4s-swatch__title,
    #t4s-callBackVariant{{ independent_form_id }} .t4s-swatch__title span,
    #t4s-callBackVariant{{ independent_form_id }} .t4s-swatch__title a,
    #t4s-callBackVariant{{ independent_form_id }} .t4s-swatch__current,
    #t4s-callBackVariant{{ independent_form_id }} .t4s-dropdown__title,
    #t4s-callBackVariant{{ independent_form_id }} .t4s-dropdown__title span {
      font-size: var(--t4s-color-title-font-size) !important;
      font-weight: var(--t4s-color-title-font-weight) !important;
    }

    @media (max-width: 767px) {
      #t4s-callBackVariant{{ independent_form_id }} {
        --t4s-color-title-spacing: {{ title_spacing_mobile }}px;
        --t4s-color-title-gap: {{ title_gap_mobile }}px;
        --t4s-color-title-font-size: {{ title_font_size_mobile }}px;
        --t4s-color-title-font-weight: {{ title_font_weight_mobile }};
      }
    }
  </style>

  <div class="t4s-independent-color-selector-wrapper t4s-independent-color-selector-wrapper--title-{{ title_layout | handle }} t4s-independent-color-selector-wrapper--main-product-title-right" style="--t4s-color-title-spacing: {{ title_spacing }}px; --t4s-color-title-gap: {{ title_gap }}px; --t4s-color-title-font-size: {{ title_font_size }}px; --t4s-color-title-font-weight: {{ title_font_weight }}; --t4s-color-title-justify: {{ title_justify }};">
    <div data-callBackVariant id="t4s-callBackVariant{{ independent_form_id }}">
      <script class="pr_variants_json" type="application/json">
        {{ product.variants | json }}
      </script>
      <script class="pr_options_json" type="application/json">
        {{ product.options_with_values | json }}
      </script>

      <form
        id="{{ independent_form_id }}"
        class="t4s-product-form"
        data-productid="{{ product.id }}"
        data-type="add-to-cart-form"
        style="display: contents;"
      >
        <select name="id" style="display: none;">
          {%- for variant in product.variants -%}
            <option
              value="{{ variant.id }}"
              {% if variant == current_variant %}selected="selected"{% endif %}
            >
              {{ variant.title }}
            </option>
          {%- endfor -%}
        </select>

        <div
          class="t4s-swatch t4s-color-mode__{{ color_mode }} t4s-color-size__{{ color_size }} t4s-selector-mode__{{ selector_mode }}"
          data-independent-color-selector
        >
          {%- for option in product.options_with_values -%}
            {%- liquid
              if option.values.size == 1
                assign selected_value = option.values.first
              else
                assign option_index = 'option' | append: forloop.index
                assign selected_value = current_variant[option_index]
              endif
              assign option_name = option.name
              assign title_text = title_label | default: option_name
              assign name_downcase = option_name | downcase
            -%}

            {%- if get_color contains name_downcase -%}
              <div
                data-swatch-option
                data-id="{{ forloop.index0 }}"
                class="t4s-swatch__option is-t4s-style__color is-t4s-name__{{ option_name | handle }}"
              >
                <h4 class="t4s-swatch__title t4s-swatch__title--layout-{{ title_layout | handle }}" style="--t4s-color-title-justify: {{ title_justify }}; display: flex !important; align-items: center !important; justify-content: {{ title_justify }} !important; gap: var(--t4s-color-title-gap); width: 100%; margin: 0 0 var(--t4s-color-title-spacing) !important; font-size: var(--t4s-color-title-font-size) !important; font-weight: var(--t4s-color-title-font-weight) !important;">
                  <span class="t4s-swatch__title-left">
                    <span class="t4s-swatch__label">{{ title_text }}:</span>
                    {%- if name_sizeg == name_downcase %}{{ html_sizeg }}{% endif %}
                  </span>
                  <span class="t4s-swatch__title-right" style="{% if title_layout == 'space-between' %}margin-left: auto !important;{% else %}margin-left: 0 !important;{% endif %}">
                    <span data-current-value class="t4s-dib t4s-swatch__current">
                      {{- selected_value | default: choose_an_option -}}
                    </span>
                  </span>
                </h4>
                <div data-swatch-list class="t4s-swatch__list">
                  {%- if color_mode != 'dropdown' -%}
                    {%- for value in option.values -%}
                      {%- liquid
                        assign swatch_focal_point = null
                        if value.swatch.image
                          assign image_url = value.swatch.image | image_url: width: 100, height: 100
                          assign swatch_value = 'url(' | append: image_url | append: ')'
                          assign swatch_focal_point = value.swatch.image.presentation.focal_point
                        elsif value.swatch.color
                          assign swatch_value = value.swatch.color
                        else
                          assign swatch_value = null
                        endif
                      -%}
                      <div
                        data-swatch-item
                        data-tooltip{{ show_tooltip }}="top"
                        title="{{ value | escape }}"
                        class="t4s-swatch__item {{ color_swatch }}bg_color_{{ value | handle }} lazyloadt4s{% if selected_value == value %} is--selected{% endif %}"
                        data-value="{{ value | escape }}"
                        {% if swatch_value %}
                          style="--swatch--background: {{ swatch_value }};{% if swatch_focal_point %} --swatch-focal-point: {{ swatch_focal_point }};{% endif %}"
                        {% endif %}
                      >
                        {{ value }}
                      </div>
                    {%- endfor -%}

                  {%- else -%}
                    <button
                      type="button"
                      data-dropdown-open
                      data-position="bottom-end"
                      data-id="t4s_nt_{{ pr_se_id }}{{ forloop.index }}"
                    >
                      <span data-current-value>{{ selected_value | default: choose_an_option }}</span>
                      <svg class="t4s-icon-select-arrow" role="presentation" viewBox="0 0 19 12">
                        <use xlink:href="#t4s-select-arrow"></use>
                      </svg>
                    </button>
                    <div
                      data-dropdown-wrapper
                      class="t4s-dropdown__wrapper t4s-current-scrollbar"
                      id="t4s_nt_{{ pr_se_id }}{{ forloop.index }}"
                    >
                      <div class="t4s-drop-arrow"></div>
                      <div class="t4s-dropdown__header">
                        <span class="t4s-dropdown__title">
                          {{- option_name }}:
                          <span data-current-value>{{ selected_value | default: choose_an_option }}</span>
                        </span>
                        <button type="button" data-dropdown-close aria-label="{{ 'general.aria.close' | t }}">
                          <svg role="presentation" class="t4s-iconsvg-close" viewBox="0 0 16 14">
                            <path d="M15 0L1 14m14 0L1 0" stroke="currentColor" fill="none" fill-rule="evenodd"></path>
                          </svg>
                        </button>
                      </div>
                      <div class="t4s-dropdown__content">
                        {%- for value in option.values -%}
                          {%- liquid
                            assign swatch_focal_point = null
                            if value.swatch.image
                              assign image_url = value.swatch.image | image_url: width: 100, height: 100
                              assign swatch_value = 'url(' | append: image_url | append: ')'
                              assign swatch_focal_point = value.swatch.image.presentation.focal_point
                            elsif value.swatch.color
                              assign swatch_value = value.swatch.color
                            else
                              assign swatch_value = null
                            endif
                          -%}
                          <div
                            data-swatch-item
                            data-dropdown-off
                            class="t4s-swatch__item t4s-truncate {{ color_swatch }}bg_color_{{ value | handle }} lazyloadt4s{% if selected_value == value %} is--selected{% endif %}"
                            data-value="{{ value | escape }}"
                            {% if swatch_value %}
                              style="--swatch--background: {{ swatch_value }};{% if swatch_focal_point %} --swatch-focal-point: {{ swatch_focal_point }};{% endif %}"
                            {% endif %}
                          >
                            {{ value }}
                          </div>
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </form>
    </div>
  </div>

  <script>
    (function() {
      function initIndependentColorSelector() {
        var independentWrapper = document.querySelector('[data-callBackVariant][id="t4s-callBackVariant{{ independent_form_id }}"]');
        var mainWrapper = document.querySelector('[data-callBackVariant][id="t4s-callBackVariant{{ 'product-form-' | append: pr_se_id }}"]');

        if (!independentWrapper || !mainWrapper) {
          setTimeout(initIndependentColorSelector, 100);
          return;
        }

        var independentSwatch = independentWrapper.querySelector('.t4s-swatch');

        var mainSwatches = mainWrapper.querySelectorAll('.t4s-swatch');
        var mainSwatch = null;

        if (mainSwatches.length > 0) {
          for (var i = 0; i < mainSwatches.length; i++) {
            var colorSwatchOptions = mainSwatches[i].querySelectorAll('[data-swatch-option].is-t4s-style__color');
            if (colorSwatchOptions.length > 0) {
              mainSwatch = mainSwatches[i];
              break;
            }
          }

          if (!mainSwatch) {
            for (var j = 0; j < mainSwatches.length; j++) {
              var swatchOptions = mainSwatches[j].querySelectorAll('[data-swatch-option]');
              if (swatchOptions.length > 0) {
                mainSwatch = mainSwatches[j];
                break;
              }
            }
          }

          if (!mainSwatch) {
            mainSwatch = mainSwatches[0];
          }
        }

        if (!independentSwatch) {
          setTimeout(initIndependentColorSelector, 100);
          return;
        }

        var variantsJson = independentWrapper.querySelector('.pr_variants_json');
        var optionsJson = independentWrapper.querySelector('.pr_options_json');

        if (!variantsJson || !optionsJson) {
          return;
        }

        var variants = JSON.parse(variantsJson.textContent);
        var options = JSON.parse(optionsJson.textContent);

        if (independentWrapper.dataset.independentColorSelectorInit === 'true') {
          return;
        }
        independentWrapper.dataset.independentColorSelectorInit = 'true';

        var mainForm = mainWrapper.querySelector('form');
        var mainSelect = mainForm ? mainForm.querySelector('select[name="id"]') : null;

        function findVariantById(variantId) {
          if (!variantId) {
            return null;
          }

          var normalizedVariantId = String(variantId);

          return variants.find(function(variant) {
            return String(variant.id) === normalizedVariantId;
          }) || null;
        }

        function escapeAttributeValue(value) {
          return String(value).replace(/\\/g, '\\\\').replace(/"/g, '\\"');
        }

        function syncIndependentOption(optionIndex, selectedValue) {
          var independentOption = independentSwatch.querySelector('[data-swatch-option][data-id="' + optionIndex + '"]');
          if (!independentOption || !selectedValue) {
            return;
          }

          independentOption.querySelectorAll('[data-swatch-item]').forEach(function(item) {
            item.classList.remove('is--selected');
          });

          var independentItem = independentOption.querySelector(
            '[data-swatch-item][data-value="' + escapeAttributeValue(selectedValue) + '"]'
          );
          if (independentItem) {
            independentItem.classList.add('is--selected');
          }

          independentOption.querySelectorAll('[data-current-value]').forEach(function(currentValueEl) {
            currentValueEl.textContent = selectedValue;
          });
        }

        function syncIndependentFromVariant(selectedVariant) {
          if (!selectedVariant) {
            return;
          }

          independentSwatch.querySelectorAll('[data-swatch-option]').forEach(function(option) {
            var optionIndex = option.getAttribute('data-id');
            var optionKey = 'option' + (parseInt(optionIndex, 10) + 1);
            var optionValue = selectedVariant[optionKey];

            if (optionValue) {
              syncIndependentOption(optionIndex, optionValue);
            }
          });

          var independentSelect = independentWrapper.querySelector('select[name="id"]');
          if (independentSelect) {
            independentSelect.value = selectedVariant.id;
          }
        }

        function dispatchIndependentSync(optionIndex, selectedValue) {
          window.dispatchEvent(new CustomEvent('t4s:independent-color-selector-change', {
            detail: {
              sectionId: '{{ pr_se_id }}',
              optionIndex: optionIndex,
              selectedValue: selectedValue,
              sourceFormId: '{{ independent_form_id }}'
            }
          }));
        }

        function getCurrentSelectedValues() {
          var selectedValues = {};

          independentSwatch.querySelectorAll('[data-swatch-option]').forEach(function(option) {
            var optionIndex = option.getAttribute('data-id');
            var selectedItem = option.querySelector('[data-swatch-item].is--selected');
            if (selectedItem) {
              selectedValues[optionIndex] = selectedItem.getAttribute('data-value');
            }
          });

          mainWrapper.querySelectorAll('[data-swatch-option]').forEach(function(mainOption) {
            var mainOptionIndex = mainOption.getAttribute('data-id');

            if (!selectedValues.hasOwnProperty(mainOptionIndex)) {
              var mainSelectedItem = mainOption.querySelector('[data-swatch-item].is--selected');
              if (mainSelectedItem) {
                selectedValues[mainOptionIndex] = mainSelectedItem.getAttribute('data-value');
              }
            }
          });

          return selectedValues;
        }

        function findMatchedVariant(selectedValues) {
          return variants.find(function(variant) {
            for (var idx in selectedValues) {
              var optionKey = 'option' + (parseInt(idx, 10) + 1);
              if (variant[optionKey] !== selectedValues[idx]) {
                return false;
              }
            }
            return true;
          }) || null;
        }

        function syncMainSelections(selectedValues) {
          mainWrapper.querySelectorAll('[data-swatch-option]').forEach(function(mainOption) {
            var mainOptionIndex = mainOption.getAttribute('data-id');
            if (!selectedValues.hasOwnProperty(mainOptionIndex)) {
              return;
            }

            var valueToSelect = selectedValues[mainOptionIndex];

            mainOption.querySelectorAll('[data-swatch-item]').forEach(function(item) {
              item.classList.remove('is--selected');
            });

            var itemToSelect = mainOption.querySelector(
              '[data-swatch-item][data-value="' + escapeAttributeValue(valueToSelect) + '"]'
            );
            if (itemToSelect) {
              itemToSelect.classList.add('is--selected');
            }

            mainOption.querySelectorAll('[data-current-value]').forEach(function(currentValueEl) {
              currentValueEl.textContent = valueToSelect;
            });
          });
        }

        function applySelectionToMainForm(selectedValues) {
          var matchedVariant = findMatchedVariant(selectedValues);

          if (!matchedVariant || !mainSelect) {
            return false;
          }

          if (String(mainSelect.value) !== String(matchedVariant.id)) {
            mainSelect.value = matchedVariant.id;
            mainSelect.dispatchEvent(new Event('change', { bubbles: true }));
          }

          setTimeout(function() {
            syncMainSelections(selectedValues);
            updateAvailableOptions();
          }, 50);

          return true;
        }

        function findMainOption(independentOption) {
          var optionIndex = independentOption.getAttribute('data-id');
          var optionName = independentOption.className.match(/is-t4s-name__([^\s]+)/);
          var optionNameValue = optionName ? optionName[1] : null;

          var mainOption = mainWrapper.querySelector('[data-swatch-option][data-id="' + optionIndex + '"]');

          if (mainOption) {
            return mainOption;
          }

          if (optionNameValue) {
            mainOption = mainWrapper.querySelector('[data-swatch-option].is-t4s-name__' + optionNameValue);
            if (mainOption) {
              return mainOption;
            }

            if (optionNameValue === 'color' || optionNameValue === 'colour') {
              mainOption = mainWrapper.querySelector('[data-swatch-option].is-t4s-style__color');
              if (mainOption) {
                return mainOption;
              }
            }
          }

          var independentOptions = independentSwatch.querySelectorAll('[data-swatch-option]');

          if (independentOptions.length === 1) {
            var mainColorOptions = mainWrapper.querySelectorAll('[data-swatch-option].is-t4s-style__color');

            if (mainColorOptions.length === 1) {
              return mainColorOptions[0];
            }

            var mainOptions = mainWrapper.querySelectorAll('[data-swatch-option]');
            if (mainOptions.length === 1) {
              return mainOptions[0];
            }
          }

          return null;
        }

        if (mainSelect) {
          mainSelect.addEventListener('change', function() {
            var selectedVariant = findVariantById(mainSelect.value);

            if (!selectedVariant) {
              return;
            }

            syncIndependentFromVariant(selectedVariant);

            setTimeout(function() {
              updateAvailableOptions();
            }, 50);
          });
        }

        window.addEventListener('t4s:independent-color-selector-change', function(event) {
          var detail = event.detail || {};

          if (
            detail.sectionId !== '{{ pr_se_id }}' ||
            detail.sourceFormId === '{{ independent_form_id }}' ||
            typeof detail.optionIndex === 'undefined' ||
            !detail.selectedValue
          ) {
            return;
          }

          syncIndependentOption(String(detail.optionIndex), detail.selectedValue);

          setTimeout(function() {
            updateAvailableOptions();
          }, 50);
        });

        function updateAvailableOptions() {
          if (mainSwatch) {
            independentSwatch.querySelectorAll('[data-swatch-option]').forEach(function(independentOption) {
              var mainOption = findMainOption(independentOption);

              if (!mainOption) {
                return;
              }

              independentOption.querySelectorAll('[data-swatch-item]').forEach(function(independentItem) {
                var itemValue = independentItem.getAttribute('data-value');
                var mainItem = mainOption.querySelector(
                  '[data-swatch-item][data-value="' + escapeAttributeValue(itemValue) + '"]'
                );

                if (!mainItem) {
                  independentItem.classList.add('is--soldout', 'is--unavailable', 'is--hidden');
                  independentItem.setAttribute('disabled', 'disabled');
                  independentItem.style.display = 'none';
                } else {
                  if (
                    mainItem.classList.contains('is--soldout') ||
                    mainItem.style.display === 'none' ||
                    mainItem.classList.contains('is--hidden')
                  ) {
                    independentItem.classList.add('is--soldout', 'is--unavailable', 'is--hidden');
                    independentItem.setAttribute('disabled', 'disabled');
                    independentItem.style.display = 'none';
                  } else {
                    independentItem.classList.remove('is--soldout', 'is--unavailable', 'is--hidden');
                    independentItem.removeAttribute('disabled');
                    independentItem.style.display = '';
                  }
                }
              });
            });
          } else {
            var selectedValues = getCurrentSelectedValues();

            independentSwatch.querySelectorAll('[data-swatch-option]').forEach(function(option) {
              var optionIndex = option.getAttribute('data-id');

              option.querySelectorAll('[data-swatch-item]').forEach(function(item) {
                var itemValue = item.getAttribute('data-value');
                var testValues = Object.assign({}, selectedValues);
                testValues[optionIndex] = itemValue;

                var hasMatchingVariant = variants.some(function(variant) {
                  var matches = true;
                  for (var idx in testValues) {
                    var optionKey = 'option' + (parseInt(idx) + 1);
                    if (variant[optionKey] !== testValues[idx]) {
                      matches = false;
                      break;
                    }
                  }
                  return matches;
                });

                if (hasMatchingVariant) {
                  item.classList.remove('is--soldout', 'is--unavailable', 'is--hidden');
                  item.removeAttribute('disabled');
                  item.style.display = '';
                } else {
                  item.classList.add('is--soldout', 'is--unavailable', 'is--hidden');
                  item.setAttribute('disabled', 'disabled');
                  item.style.display = 'none';
                }
              });
            });
          }
        }

        independentSwatch.addEventListener('click', function(e) {
          var clickedItem = e.target.closest('[data-swatch-item]');
          if (!clickedItem) return;

          if (clickedItem.classList.contains('is--soldout') || clickedItem.classList.contains('is--unavailable')) {
            e.preventDefault();
            e.stopPropagation();
            return;
          }

          e.preventDefault();
          e.stopPropagation();

          var swatchOption = clickedItem.closest('[data-swatch-option]');
          if (!swatchOption) return;

          var optionIndex = swatchOption.getAttribute('data-id');
          var selectedValue = clickedItem.getAttribute('data-value');

          swatchOption.querySelectorAll('[data-swatch-item]').forEach(function(item) {
            item.classList.remove('is--selected');
          });
          clickedItem.classList.add('is--selected');

          var currentValueEl = swatchOption.querySelector('[data-current-value]');
          if (currentValueEl) {
            currentValueEl.textContent = selectedValue;
          }

          dispatchIndependentSync(optionIndex, selectedValue);

          var selectedValues = getCurrentSelectedValues();
          var selectionApplied = applySelectionToMainForm(selectedValues);

          if (!selectionApplied) {
            var mainSwatchOption = findMainOption(swatchOption);
            if (!mainSwatchOption) {
              return;
            }

            var mainSwatchItem = mainSwatchOption.querySelector(
              '[data-swatch-item][data-value="' + escapeAttributeValue(selectedValue) + '"]'
            );
            if (!mainSwatchItem) {
              return;
            }

            mainSwatchItem.click();

            setTimeout(function() {
              updateAvailableOptions();
            }, 100);

            setTimeout(function() {
              updateAvailableOptions();
            }, 300);
          }
        });

        if (mainSwatch) {
          var observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
              if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
                var target = mutation.target;
                if (target.hasAttribute('data-swatch-item') && target.classList.contains('is--selected')) {
                  var swatchOption = target.closest('[data-swatch-option]');
                  if (!swatchOption) return;

                  var optionIndex = swatchOption.getAttribute('data-id');
                  var selectedValue = target.getAttribute('data-value');
                  var independentOption = independentSwatch.querySelector('[data-swatch-option][data-id="' + optionIndex + '"]');

                  if (independentOption) {
                    independentOption.querySelectorAll('[data-swatch-item]').forEach(function(item) {
                      item.classList.remove('is--selected');
                    });

                    var independentItem = independentOption.querySelector(
                      '[data-swatch-item][data-value="' + escapeAttributeValue(selectedValue) + '"]'
                    );
                    if (independentItem) {
                      independentItem.classList.add('is--selected');

                      var currentValueEl = independentOption.querySelector('[data-current-value]');
                      if (currentValueEl) {
                        currentValueEl.textContent = selectedValue;
                      }
                    }
                  }

                  setTimeout(function() {
                    updateAvailableOptions();
                  }, 50);
                }
              }
            });
          });

          mainSwatch.querySelectorAll('[data-swatch-item]').forEach(function(item) {
            observer.observe(item, { attributes: true, attributeFilter: ['class'] });
          });

          var displayObserver = new MutationObserver(function(mutations) {
            var needsUpdate = false;
            mutations.forEach(function(mutation) {
              if (
                mutation.type === 'attributes' &&
                (mutation.attributeName === 'style' || mutation.attributeName === 'class')
              ) {
                needsUpdate = true;
              }
            });

            if (needsUpdate) {
              setTimeout(function() {
                updateAvailableOptions();
              }, 50);
            }
          });

          mainSwatch.querySelectorAll('[data-swatch-item]').forEach(function(item) {
            displayObserver.observe(item, {
              attributes: true,
              attributeFilter: ['style', 'class']
            });
          });
        }

        var initialVariant = mainSelect ? findVariantById(mainSelect.value) : null;
        if (initialVariant) {
          syncIndependentFromVariant(initialVariant);
        }

        if (mainSwatch || mainWrapper) {
          independentSwatch.querySelectorAll('[data-swatch-option]').forEach(function(independentOption) {
            var mainOption = findMainOption(independentOption);

            if (!mainOption) {
              return;
            }

            independentOption.querySelectorAll('[data-swatch-item]').forEach(function(independentItem) {
              var itemValue = independentItem.getAttribute('data-value');
              var mainItem = mainOption.querySelector(
                '[data-swatch-item][data-value="' + escapeAttributeValue(itemValue) + '"]'
              );

              if (!mainItem) {
                independentItem.classList.add('is--soldout', 'is--unavailable', 'is--hidden');
                independentItem.style.display = 'none';
              } else {
                if (mainItem.classList.contains('is--soldout')) {
                  independentItem.classList.add('is--soldout', 'is--unavailable', 'is--hidden');
                  independentItem.style.display = 'none';
                } else {
                  independentItem.classList.remove('is--soldout', 'is--unavailable', 'is--hidden');
                  independentItem.style.display = '';
                }

                if (mainItem.classList.contains('is--selected')) {
                  independentItem.classList.add('is--selected');

                  var currentValueEl = independentOption.querySelector('[data-current-value]');
                  if (currentValueEl) {
                    currentValueEl.textContent = itemValue;
                  }
                } else {
                  independentItem.classList.remove('is--selected');
                }

                if (mainItem.style.display === 'none') {
                  independentItem.style.display = 'none';
                  independentItem.classList.add('is--hidden');
                }
              }
            });
          });
        } else {
          updateAvailableOptions();
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initIndependentColorSelector);
      } else {
        initIndependentColorSelector();
      }
    })();
  </script>

  <style>
    .t4s-independent-color-selector-wrapper--main-product-title-right [data-independent-color-selector] [data-swatch-item].is--soldout,
    .t4s-independent-color-selector-wrapper--main-product-title-right [data-independent-color-selector] [data-swatch-item].is--unavailable,
    .t4s-independent-color-selector-wrapper--main-product-title-right [data-independent-color-selector] [data-swatch-item].is--hidden {
      display: none !important;
    }

    .t4s-independent-color-selector-wrapper--main-product-title-right [data-swatch-option] {
      display: block;
    }

    .t4s-independent-color-selector-wrapper--main-product-title-right .t4s-swatch__title,
    [data-independent-color-selector] .t4s-swatch__title[class*="t4s-swatch__title--layout-"] {
      display: flex !important;
      align-items: center;
      justify-content: var(--t4s-color-title-justify, space-between) !important;
      gap: var(--t4s-color-title-gap, 2px);
      width: 100%;
      margin: 0 0 var(--t4s-color-title-spacing, 16px) !important;
      text-align: left;
    }

    .t4s-independent-color-selector-wrapper--main-product-title-right .t4s-swatch__title-left {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    .t4s-independent-color-selector-wrapper--main-product-title-right .t4s-swatch__label {
      display: inline-block;
    }

    .t4s-independent-color-selector-wrapper--main-product-title-right .t4s-swatch__title-right {
      display: inline-flex;
      align-items: center;
      justify-content: flex-end;
      gap: var(--t4s-color-title-gap, 2px);
      min-width: 0;
      text-align: right;
    }

    [data-independent-color-selector] .t4s-swatch__title[class*="t4s-swatch__title--layout-"] .t4s-swatch__title-right {
      margin-left: 0 !important;
    }

    .t4s-independent-color-selector-wrapper--title-space-between .t4s-swatch__title-right,
    [data-independent-color-selector] .t4s-swatch__title--layout-space-between .t4s-swatch__title-right {
      margin-left: auto !important;
    }

    .t4s-independent-color-selector-wrapper--main-product-title-right .t4s-swatch__current {
      min-width: 0;
      white-space: normal;
    }

    .t4s-independent-color-selector-wrapper--main-product-title-right .t4s-swatch__title a {
      margin: 0;
    }

    .t4s-independent-color-selector-wrapper--main-product-title-right .t4s-swatch__list {
      min-width: 0;
    }

    @media (max-width: 767px) {
      .t4s-independent-color-selector-wrapper--main-product-title-right .t4s-swatch__title {
        gap: 12px;
        margin-bottom: var(--t4s-color-title-spacing, 16px) !important;
      }
    }
  </style>
{%- endif -%}
