{% comment %}
  优化的图片输出 snippet
  使用方法: {% render 'optimized-image', image: product.featured_image, alt: product.title, loading: 'lazy' %}
{% endcomment %}

{%- liquid
  assign image_url = image | image_url: width: 1920
  assign loading_attr = loading | default: 'lazy'
  assign sizes_attr = sizes | default: '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw'
-%}

<img
  src="{{ image_url | image_url: width: 800 }}"
  srcset="
    {{ image_url | image_url: width: 400 }} 400w,
    {{ image_url | image_url: width: 800 }} 800w,
    {{ image_url | image_url: width: 1200 }} 1200w,
    {{ image_url | image_url: width: 1920 }} 1920w
  "
  sizes="{{ sizes_attr }}"
  loading="{{ loading_attr }}"
  {% if loading_attr == 'eager' %}fetchpriority="high"{% endif %}
  width="{{ image.width }}"
  height="{{ image.height }}"
  alt="{{ alt | escape }}"
  class="{{ class }}"
>
