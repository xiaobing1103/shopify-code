      margin: {{ atc_notice_margin_top }}px {{ atc_notice_visual_right }}px -{{ atc_notice_overlap_mb }}px {{ atc_notice_visual_left }}px !important;
      padding: {{ atc_notice_padding_vertical_mb }}px {{ atc_notice_padding_right_mb }}px
        {{ atc_notice_padding_vertical_mb }}px {{ atc_notice_padding_horizontal_mb }}px !important;
      font-size: {{ atc_notice_font_size_mb }}px !important;
