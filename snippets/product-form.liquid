{%- assign product_form_id = 'product-form-' | append: pr_se_id -%}
{%- liquid
  assign pr_variants = product.variants
  assign PR_buy_pr = false
  if bk_stts.show_dynamic_checkout and isExternal == false and isProductAvailable
    assign PR_buy_pr = true
  endif
  assign choose_an_option = 'products.product.choose_an_option' | t
  assign date_in = settings.date_in
  assign class_frm = 't4s-form__product has--form__swatch'
  if isProductDefault
    assign class_frm = 't4s-form__product'
  endif
  if arr_properties.size > 0 and isProductAvailable
    assign class_frm = class_frm | append: ' has--properties'
  endif
  if settings.sticky_atc and type == 'main'
    assign class_frm = class_frm | append: ' is--main-sticky'
  else
    assign class_frm = class_frm | append: ' is--atc-sticky'
  endif

  assign color_swatch = 'disabled-'
  assign color_mode = bk_stts.color_mode
  assign selector_mode = bk_stts.selector_mode
  assign stt_color_ck = settings.color_ck | default: ';'
  assign color_ck = stt_color_ck | append: ',color,colors,couleur,colour' | remove: ';,'
  assign get_color = color_ck | downcase | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
  assign color_mode_list = 'color, color is-sw-cl__round, variant_image, variant_image is-sw-cl__round' | split: ', '
  if color_mode_list contains color_mode
    assign color_swatch = 'is-sw__color '
  endif
  assign hide_color_selector = bk_stts.hide_color_selector | default: false
  assign show_add_to_cart_button = true
  if bk_stts.show_add_to_cart_button == false
    assign show_add_to_cart_button = false
  endif
  if bk_stts.hide_non_color_selectors == false
    assign hide_non_color_selectors = false
  else
    assign hide_non_color_selectors = true
  endif
  assign qty_full_width = bk_stts.qty_full_width | default: false
  assign qty_width_class = ''
  assign qty_width_style = ''
  assign form_buttons_extra_style = ''
  assign form_buttons_row_extra_style = ''
  if qty_full_width
    assign qty_width_class = ' is-qty-full-width'
    assign qty_width_style = 'width: 100% !important; min-width: 100% !important; max-width: 100% !important; flex: 0 0 100% !important;'
    assign form_buttons_extra_style = ' width: 100% !important; max-width: 100% !important;'
    assign form_buttons_row_extra_style = ' width: 100% !important; max-width: 100% !important; flex-wrap: wrap !important;'
  endif
  assign current_variant_available = current_variant.available
  assign use_incoming_mess = settings.use_incoming_mess
  assign current_variant_incoming = false
  assign current_inventory_quantity = current_variant.inventory_quantity
  if current_inventory_quantity <= 0 and current_variant.inventory_management == 'shopify' and current_variant.incoming
    assign current_variant_incoming = true
  endif
  if pos_sizeg == '1'
    assign html_sizeg = ''
  endif
  if current_variant.inventory_management != null and current_inventory_quantity > 0 and current_variant.inventory_policy != 'continue'
    assign max_qty = current_inventory_quantity
  else
    assign max_qty = 9999
  endif
  if current_variant.quantity_rule.max and max_qty > current_variant.quantity_rule.max
    assign max_qty = current_variant.quantity_rule.max
  endif
  if color_mode contains 'color' or color_mode contains 'variant'
    assign show_tooltip = ''
  else
    assign show_tooltip = '-off'
  endif
-%}
{%- liquid
  assign gift_card_recipient_feature_active = false
  if bk_stts.show_gift_card_recipient and product.gift_card?
    assign gift_card_recipient_feature_active = true
    assign PR_buy_pr = false
  endif
-%}

{%- if color_mode == 'dropdown' or selector_mode == 'dropdown' -%}
  <link rel="stylesheet" href="{{ 'base_drop.min.css' | asset_url }}" media="all">
{%- endif -%}
{%- assign option_group_bg_color = bk_stts.option_group_bg_color | default: '#F7F4EE' -%}
{%- assign option_group_text_color = bk_stts.option_group_text_color | default: '#2E2B27' -%}
{%- assign atc_btn_bg_color = bk_stts.atc_btn_bg_color | default: '#000000' -%}
{%- assign atc_btn_text_color = bk_stts.atc_btn_text_color | default: '#ffffff' -%}
{%- assign atc_btn_bg_hover_color = bk_stts.atc_btn_bg_hover_color | default: '#333333' -%}
{%- assign atc_btn_text_hover_color = bk_stts.atc_btn_text_hover_color | default: '#ffffff' -%}
{%- assign atc_btn_gradient_from = bk_stts.atc_btn_gradient_from | default: atc_btn_bg_color -%}
{%- assign atc_btn_gradient_to = bk_stts.atc_btn_gradient_to | default: atc_btn_bg_hover_color -%}
{%- assign atc_btn_gradient_hover_from = bk_stts.atc_btn_gradient_hover_from | default: atc_btn_bg_hover_color -%}
{%- assign atc_btn_gradient_hover_to = bk_stts.atc_btn_gradient_hover_to | default: atc_btn_bg_color -%}
{%- assign atc_btn_enable_gradient = bk_stts.atc_btn_enable_gradient | default: false -%}
{%- assign atc_btn_padding_y = bk_stts.atc_btn_padding_y | default: 0 -%}
{%- assign atc_btn_font_size = bk_stts.atc_btn_font_size | default: 14 -%}
{%- liquid
  assign show_atc_notice = bk_stts.show_custom_redirect_notice
  if show_atc_notice == blank
    assign show_atc_notice = true
  endif
  assign hide_atc_notice = bk_stts.hide_custom_redirect_notice
  if hide_atc_notice == blank
    assign hide_atc_notice = false
  endif
  assign atc_notice_margin_top = bk_stts.custom_redirect_notice_margin_top | default: 14
  assign atc_notice_margin_left = bk_stts.custom_redirect_notice_margin_left | default: 0
  assign atc_notice_margin_right = bk_stts.custom_redirect_notice_margin_right | default: 0
  assign atc_notice_font_size = bk_stts.custom_redirect_notice_font_size | default: 15
  assign atc_notice_font_size_mb = bk_stts.custom_redirect_notice_font_size_mb | default: 14
  assign atc_notice_line_height = bk_stts.custom_redirect_notice_line_height | default: 120
  assign atc_notice_icon_gap = bk_stts.custom_redirect_notice_icon_gap | default: 2
  assign atc_notice_icon_gap_mb = bk_stts.custom_redirect_notice_icon_gap_mb | default: 2
  assign atc_notice_icon_size = 18
  assign atc_notice_icon_size_mb = 16
  assign atc_notice_min_height = bk_stts.custom_redirect_notice_min_height | default: 0
  assign atc_notice_padding_vertical = bk_stts.custom_redirect_notice_padding_vertical | default: 6
  assign atc_notice_padding_horizontal = bk_stts.custom_redirect_notice_padding_horizontal | default: 10
  assign atc_notice_padding_vertical_mb = bk_stts.custom_redirect_notice_padding_vertical_mb | default: 6
  assign atc_notice_padding_horizontal_mb = bk_stts.custom_redirect_notice_padding_horizontal_mb | default: 8
  assign atc_notice_border_radius = bk_stts.custom_redirect_notice_border_radius | default: 12
  assign atc_notice_justify_content = bk_stts.custom_redirect_notice_justify_content | default: 'center'
  assign atc_notice_text_align = bk_stts.custom_redirect_notice_text_align | default: 'center'
  if atc_notice_justify_content == 'center'
    assign atc_notice_text_align = 'center'
  endif
  assign atc_notice_text_color = bk_stts.custom_redirect_notice_text_color | default: '#7B7B85'
  assign atc_notice_count_color = bk_stts.custom_redirect_notice_count_color | default: '#7B7B85'
  assign atc_notice_bg_color = bk_stts.custom_redirect_notice_bg_color | default: '#ffffff'
  assign atc_notice_bg_gradient = bk_stts.custom_redirect_notice_bg_gradient | default: 'linear-gradient(90deg, rgba(255, 237, 205, 0.6) 0%, rgba(255, 255, 255, 0) 90%)'
  assign atc_notice_bg_gradient_key = atc_notice_bg_gradient | replace: ' ', '' | downcase
  assign atc_notice_border_color = bk_stts.custom_redirect_notice_border_color | default: '#ffffff'
  if atc_notice_text_color == '#7B7B85'
    assign atc_notice_text_color = '#d6dbe1'
  endif
  if atc_notice_count_color == '#7B7B85'
    assign atc_notice_count_color = '#f3f6f9'
  endif
  if atc_notice_bg_color == '#ffffff'
    assign atc_notice_bg_color = '#566271'
  endif
  if atc_notice_bg_gradient_key == 'linear-gradient(90deg,rgba(255,237,205,0.6)0%,rgba(255,255,255,0)90%)'
    assign atc_notice_bg_gradient = 'linear-gradient(180deg, #5e6977 0%, #4b5562 100%)'
  endif
  if atc_notice_border_color == '#ffffff'
    assign atc_notice_border_color = 'transparent'
  endif
  assign atc_notice_surface = atc_notice_bg_gradient
  if atc_notice_surface == blank or atc_notice_surface == 'none'
    assign atc_notice_surface = atc_notice_bg_color
  endif
  assign atc_notice_padding_right = atc_notice_padding_horizontal | plus: 18
  assign atc_notice_padding_right_mb = atc_notice_padding_horizontal_mb | plus: 14
  assign atc_notice_visual_left = atc_notice_margin_left
  assign atc_notice_visual_right = atc_notice_margin_right
  assign atc_notice_redirect_block = blank
  if seBlocks != blank
    assign atc_notice_redirect_block = seBlocks | where: 'type', 'custom_redirect_button' | first
  endif
  assign atc_notice_redirect_stts = blank
  if atc_notice_redirect_block != blank
    assign atc_notice_redirect_stts = atc_notice_redirect_block.settings
  endif
  assign atc_notice_text = bk_stts.custom_redirect_notice_text | default: '[count] People Ordered In The Last 2 Hours' | strip
  if atc_notice_text == '[count] People Ordered In The Last 2 Hours' and atc_notice_redirect_stts.custom_redirect_notice_text != blank
    assign atc_notice_text = atc_notice_redirect_stts.custom_redirect_notice_text | strip
  endif
  assign atc_notice_count = bk_stts.custom_redirect_notice_count | default: '17'
  if atc_notice_count == '17' and atc_notice_redirect_stts.custom_redirect_notice_count != blank
    assign atc_notice_count = atc_notice_redirect_stts.custom_redirect_notice_count
  endif
  assign atc_notice_count_raw = atc_notice_count | plus: 0
  if atc_notice_count_raw > 0
    assign atc_notice_count = atc_notice_count_raw | divided_by: 10 | times: 10
    if atc_notice_count < 10
      assign atc_notice_count = 10
    endif
  else
    assign atc_notice_count = 0
  endif
  assign atc_notice_random_enabled = bk_stts.custom_redirect_notice_enable_random_count
  if atc_notice_random_enabled == blank
    assign atc_notice_random_enabled = false
  endif
  assign atc_notice_overnight_min = bk_stts.custom_redirect_notice_overnight_min | default: 4 | plus: 0
  assign atc_notice_overnight_max = bk_stts.custom_redirect_notice_overnight_max | default: 12 | plus: 0
  assign atc_notice_daytime_min = bk_stts.custom_redirect_notice_daytime_min | default: 12 | plus: 0
  assign atc_notice_daytime_max = bk_stts.custom_redirect_notice_daytime_max | default: 24 | plus: 0
  assign atc_notice_redirect_overnight_min = atc_notice_redirect_stts.custom_redirect_notice_overnight_min | default: atc_notice_overnight_min | plus: 0
  assign atc_notice_redirect_overnight_max = atc_notice_redirect_stts.custom_redirect_notice_overnight_max | default: atc_notice_overnight_max | plus: 0
  assign atc_notice_redirect_daytime_min = atc_notice_redirect_stts.custom_redirect_notice_daytime_min | default: atc_notice_daytime_min | plus: 0
  assign atc_notice_redirect_daytime_max = atc_notice_redirect_stts.custom_redirect_notice_daytime_max | default: atc_notice_daytime_max | plus: 0
  if atc_notice_overnight_min == 4 and atc_notice_redirect_overnight_min != 4
    assign atc_notice_overnight_min = atc_notice_redirect_overnight_min
  endif
  if atc_notice_overnight_max == 12 and atc_notice_redirect_overnight_max != 12
    assign atc_notice_overnight_max = atc_notice_redirect_overnight_max
  endif
  if atc_notice_daytime_min == 12 and atc_notice_redirect_daytime_min != 12
    assign atc_notice_daytime_min = atc_notice_redirect_daytime_min
  endif
  if atc_notice_daytime_max == 24 and atc_notice_redirect_daytime_max != 24
    assign atc_notice_daytime_max = atc_notice_redirect_daytime_max
  endif
  assign atc_notice_use_range_count = atc_notice_random_enabled
  if atc_notice_overnight_min != 4 or atc_notice_overnight_max != 12 or atc_notice_daytime_min != 12 or atc_notice_daytime_max != 24
    assign atc_notice_use_range_count = true
  endif
  assign atc_notice_dom_id = 't4s-viewed-today' | append: block.id | append: '-atc-copy'
  assign atc_notice_overlap = 6
  assign atc_notice_overlap_mb = 4
  assign show_atc_notice_block = false
  if show_atc_notice and hide_atc_notice != true and atc_notice_text != blank
    assign show_atc_notice_block = true
  endif
-%}

<style>
  #{{ product_form_id }} {
    --t4s-option-group-bg: {{ option_group_bg_color }};
    --t4s-option-group-surface: {{ option_group_bg_color }};
    --t4s-option-group-text: {{ option_group_text_color }};
    --t4s-option-group-border: {{ option_group_text_color }};
    --t4s-option-group-accent: {{ option_group_text_color }};
    --t4s-option-group-hover-bg: {{ option_group_bg_color }};
    --t4s-option-group-selected-bg: {{ option_group_bg_color }};
    --t4s-option-group-selected-text: {{ option_group_text_color }};
    --t4s-option-group-check-bg: {{ option_group_text_color }};
    --t4s-option-group-check-color: {{ option_group_bg_color }};
    --t4s-qty-bg: {{ option_group_bg_color }};
    --t4s-qty-text: {{ option_group_text_color }};
    --t4s-qty-border: {{ option_group_text_color }};
    --t4s-qty-button-bg: {{ option_group_bg_color }};
    --t4s-qty-button-hover-bg: {{ option_group_bg_color }};
    --t4s-qty-icon-color: {{ option_group_text_color }};
    --t4s-qty-icon-hover-color: {{ option_group_text_color }};
    --t4s-atc-bg: {{ atc_btn_bg_color }};
    --t4s-atc-text: {{ atc_btn_text_color }};
    --t4s-atc-bg-hover: {{ atc_btn_bg_hover_color }};
    --t4s-atc-text-hover: {{ atc_btn_text_hover_color }};
    --t4s-atc-custom-background: {% if atc_btn_enable_gradient %}linear-gradient(135deg, {{ atc_btn_gradient_from }}, {{ atc_btn_gradient_to }}){% else %}{{ atc_btn_bg_color }}{% endif %};
    --t4s-atc-custom-background-hover: {% if atc_btn_enable_gradient %}linear-gradient(135deg, {{ atc_btn_gradient_hover_from }}, {{ atc_btn_gradient_hover_to }}){% else %}{{ atc_btn_bg_hover_color }}{% endif %};
  }

  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) {
    background: var(--t4s-option-group-bg) !important;
    color: var(--t4s-option-group-text) !important;
    border-radius: 16px !important;
    padding: 14px 16px !important;
    margin-bottom: 14px !important;
  }

  #{{ product_form_id }} .t4s-swatch__option--hidden-non-color {
    position: absolute !important;
    left: -9999px !important;
    top: auto !important;
    display: block !important;
    opacity: 0 !important;
    pointer-events: none !important;
    width: 0 !important;
    height: 0 !important;
    min-width: 0 !important;
    min-height: 0 !important;
    padding: 0 !important;
    margin: 0 !important;
    border: 0 !important;
    overflow: hidden !important;
  }

  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-swatch__title,
  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-swatch__title span,
  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-swatch__current,
  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-swatch__item,
  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-swatch__list > button,
  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-dropdown__title,
  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-dropdown__title span {
    color: var(--t4s-option-group-text) !important;
  }

  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-swatch__list {
    margin: 10px 0 0 !important;
  }

  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-swatch__item,
  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-swatch__list > button,
  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-dropdown__wrapper {
    background: var(--t4s-option-group-surface) !important;
    border-color: var(--t4s-option-group-border) !important;
  }

  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-swatch__item {
    box-shadow: inset 0 0 0 1px var(--t4s-option-group-border) !important;
  }

  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-swatch__item.is--selected,
  #{{ product_form_id }} .t4s-swatch__option:not(.is-t4s-style__color) .t4s-dropdown__wrapper .t4s-swatch__item.is--selected {
    background: var(--t4s-option-group-selected-bg) !important;
    color: var(--t4s-option-group-selected-text) !important;
    border-color: var(--t4s-option-group-accent) !important;
    box-shadow: inset 0 0 0 2px var(--t4s-option-group-accent) !important;
  }

  #{{ product_form_id }} .t4s-product-form__submit.t4s-btn-color-custom[data-atc-form]:not(.t4s-btn-style-outline):not(.t4s-btn-style-bordered):not(.t4s-btn-style-link) {
    color: var(--t4s-atc-text) !important;
    background: var(--t4s-atc-custom-background) !important;
    border-color: var(--t4s-atc-bg) !important;
  }

  #{{ product_form_id }} .t4s-product-form__submit.t4s-btn-color-custom[data-atc-form]:not(.t4s-btn-style-outline):not(.t4s-btn-style-bordered):not(.t4s-btn-style-link)::before {
    background: var(--t4s-atc-custom-background-hover) !important;
    border-color: var(--t4s-atc-bg-hover) !important;
  }

  #{{ product_form_id }} .t4s-product-form__submit.t4s-btn-color-custom[data-atc-form]:not(.t4s-btn-style-outline):not(.t4s-btn-style-bordered):not(.t4s-btn-style-link):hover {
    color: var(--t4s-atc-text-hover) !important;
    background: var(--t4s-atc-custom-background-hover) !important;
    border-color: var(--t4s-atc-bg-hover) !important;
  }

  #{{ product_form_id }} .t4s-product-form__submit[data-atc-form] {
    --btn-size: {{ atc_btn_font_size }}px;
    height: auto !important;
    min-height: 0 !important;
    padding-top: {{ atc_btn_padding_y }}px !important;
    padding-bottom: {{ atc_btn_padding_y }}px !important;
  }

  #{{ product_form_id }} .t4s-product-form__atc-notice-wrap {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    max-width: 100%;
    flex: 1 1 100%;
    position: relative;
    box-sizing: border-box;
  }

  #{{ product_form_id }} .t4s-product-form__atc-notice-wrap .t4s-pr_viewed_today_notice {
    --t4s-atc-notice-tail-visible: 26px;
    --t4s-atc-notice-tail-top-cut: 18px;
    position: relative;
    z-index: 1;
    display: flex !important;
    align-items: center;
    align-self: flex-start;
    gap: {{ atc_notice_icon_gap }}px !important;
    width: fit-content !important;
    max-width: calc(100% - {{ atc_notice_visual_left }}px - {{ atc_notice_visual_right }}px - 30px);
    margin: {{ atc_notice_margin_top }}px {{ atc_notice_visual_right }}px -{{ atc_notice_overlap }}px {{ atc_notice_visual_left }}px !important;
    padding: {{ atc_notice_padding_vertical }}px {{ atc_notice_padding_right }}px {{ atc_notice_padding_vertical }}px
      {{ atc_notice_padding_horizontal }}px !important;
    border: 0 !important;
    border-radius: {{ atc_notice_border_radius }}px {{ atc_notice_border_radius }}px 0 0 !important;
    background: transparent !important;
    color: {{ atc_notice_text_color }} !important;
    font-size: {{ atc_notice_font_size }}px !important;
    box-shadow: none !important;
    overflow: visible;
    min-height: {{ atc_notice_min_height }}px !important;
    justify-content: {{ atc_notice_justify_content }} !important;
  }

  #{{ product_form_id }} .t4s-product-form__atc-notice-wrap .t4s-pr_viewed_today_notice::before {
    content: '';
    position: absolute;
    inset: 0 calc(-1 * var(--t4s-atc-notice-tail-visible)) 0 0;
    border-radius: inherit;
    background: {{ atc_notice_surface }} !important;
    clip-path: polygon(0 0, calc(100% - var(--t4s-atc-notice-tail-top-cut)) 0, 100% 100%, 0 100%);
    box-shadow: 0 8px 14px rgba(36, 45, 57, 0.12) !important;
    z-index: -1;
    pointer-events: none;
  }

  #{{ product_form_id }} .t4s-product-form__atc-notice-wrap .t4s-pr_viewed_today_notice .t4s-viewed-today__icon,
  #{{ product_form_id }} .t4s-product-form__atc-notice-wrap .t4s-pr_viewed_today_notice .t4s-viewed-today__text {
    position: relative;
    z-index: 1;
  }

  #{{ product_form_id }} .t4s-product-form__atc-notice-wrap .t4s-pr_viewed_today_notice .t4s-viewed-today__icon {
    flex: 0 0 {{ atc_notice_icon_size }}px !important;
    width: {{ atc_notice_icon_size }}px !important;
    height: {{ atc_notice_icon_size }}px !important;
    margin-right: -1px !important;
  }

  #{{ product_form_id }} .t4s-product-form__atc-notice-wrap .t4s-pr_viewed_today_notice .t4s-viewed-today__text {
    display: flex;
    align-items: center;
    color: {{ atc_notice_text_color }} !important;
    text-align: {{ atc_notice_text_align }} !important;
    line-height: {{ atc_notice_line_height }}% !important;
    justify-content: {{ atc_notice_justify_content }} !important;
    white-space: nowrap;
  }

  #{{ product_form_id }} .t4s-product-form__atc-notice-wrap .t4s-pr_viewed_today_notice .t4s-viewed-today__count {
    color: {{ atc_notice_count_color }} !important;
  }

  #{{ product_form_id }} .t4s-product-form__atc-notice-wrap .t4s-product-form__submit[data-atc-form] {
