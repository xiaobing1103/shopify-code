{% comment %}
  关键 CSS - 内联到 <head> 中以加快首屏渲染
  在 layout/theme.liquid 的 <head> 中使用: {% render 'critical-css' %}
{% endcomment %}

<style>
  /* 重置和基础样式 */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    line-height: 1.6;
    color: #333;
  }

  /* 头部关键样式 */
  .header {
    position: relative;
    z-index: 100;
  }

  /* 首屏内容 */
  .hero-section {
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* 产品网格基础布局 */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
  }

  /* 图片容器 */
  .image-container {
    position: relative;
    overflow: hidden;
  }

  .image-container img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* 加载状态 */
  .loading {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: loading 1.5s infinite;
  }

  @keyframes loading {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
  }
</style>
