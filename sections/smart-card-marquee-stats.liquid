{%- liquid
  assign se_stts = section.settings
  assign slide_blocks = section.blocks | where: 'type', 'slide'
  assign stat_blocks = section.blocks | where: 'type', 'stat'
  assign loading_attribute = 'eager'

  if se_stts.lazy_load
    assign loading_attribute = 'lazy'
  endif
-%}

{%- style -%}
  .smart-card-marquee-stats-{{ section.id }} {
    margin-top: {{ se_stts.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ se_stts.margin_bottom | times: 0.75 | round: 0 }}px;
    background: {{ se_stts.background_color }};
    color: {{ se_stts.text_color }};
    overflow: hidden;
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__carousel {
    overflow: hidden;
    padding-top: {{ se_stts.carousel_padding_top_mobile }}px;
    padding-bottom: {{ se_stts.carousel_padding_bottom_mobile }}px;
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__track {
    display: flex;
    width: max-content;
    animation: smartCardMarquee{{ section.id | replace: '-', '' }} {{ se_stts.scroll_speed_mobile }}s linear infinite;
    will-change: transform;
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__list {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    gap: {{ se_stts.card_gap_mobile }}px;
    padding-right: {{ se_stts.card_gap_mobile }}px;
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__slide {
    width: {{ se_stts.card_width_mobile }}px;
    height: {{ se_stts.card_height_mobile }}px;
    border-radius: {{ se_stts.card_radius }}px;
    overflow: hidden;
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    border: {{ se_stts.card_border_thickness }}px solid {{ se_stts.card_border_color }};
    text-decoration: none;
    background: var(--card-background, #182233);
    color: var(--card-text-color, #ffffff);
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__slide img,
  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__slide svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: {{ se_stts.card_image_fit }};
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__slide svg {
    background: #1b2430;
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__slide-text {
    padding: 18px;
    width: 100%;
    text-align: center;
    font-size: {{ se_stts.card_text_size_mobile }}px;
    line-height: {{ se_stts.card_text_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.card_text_weight }};
    letter-spacing: {{ se_stts.card_text_letter_spacing }}px;
    color: inherit;
    white-space: normal;
    overflow-wrap: anywhere;
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__stats-wrap {
    width: min(100% - {{ se_stts.padding_horizontal_mobile | times: 2 }}px, {{ se_stts.content_width }}px);
    margin: {{ se_stts.stats_margin_top_mobile }}px auto {{ se_stts.stats_margin_bottom_mobile }}px;
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ se_stts.stats_gap_mobile }}px;
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__stat {
    text-align: {{ se_stts.stats_text_align }};
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__stat-value {
    margin: 0;
    color: {{ se_stts.value_color }};
    font-size: {{ se_stts.value_size_mobile }}px;
    line-height: {{ se_stts.value_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.value_weight }};
    letter-spacing: {{ se_stts.value_letter_spacing }}px;
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__stat-label {
    margin: {{ se_stts.label_margin_top_mobile }}px 0 0;
    color: {{ se_stts.label_color }};
    font-size: {{ se_stts.label_size_mobile }}px;
    line-height: {{ se_stts.label_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.label_weight }};
    letter-spacing: {{ se_stts.label_letter_spacing }}px;
  }

  .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__stat-text {
    margin: {{ se_stts.description_margin_top_mobile }}px auto 0;
    max-width: {{ se_stts.description_max_width_mobile }}px;
    color: {{ se_stts.description_color }};
    font-size: {{ se_stts.description_size_mobile }}px;
    line-height: {{ se_stts.description_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.description_weight }};
    letter-spacing: {{ se_stts.description_letter_spacing }}px;
  }

  {% if se_stts.pause_hover %}
    .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__carousel:hover .smart-card-marquee-stats__track {
      animation-play-state: paused;
    }
  {% endif %}

  {% if se_stts.reverse_direction %}
    @keyframes smartCardMarquee{{ section.id | replace: '-', '' }} {
      from {
        transform: translateX(-12.5%);
      }
      to {
        transform: translateX(0);
      }
    }
  {% else %}
    @keyframes smartCardMarquee{{ section.id | replace: '-', '' }} {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-12.5%);
      }
    }
  {% endif %}

  @media (min-width: 768px) {
    .smart-card-marquee-stats-{{ section.id }} {
      margin-top: {{ se_stts.margin_top }}px;
      margin-bottom: {{ se_stts.margin_bottom }}px;
    }

    .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__carousel {
      padding-top: {{ se_stts.carousel_padding_top }}px;
      padding-bottom: {{ se_stts.carousel_padding_bottom }}px;
    }

    .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__track {
      animation-duration: {{ se_stts.scroll_speed }}s;
    }

    .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__list {
      gap: {{ se_stts.card_gap }}px;
      padding-right: {{ se_stts.card_gap }}px;
    }

    .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__slide {
      width: {{ se_stts.card_width }}px;
      height: {{ se_stts.card_height }}px;
    }

    .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__slide-text {
      font-size: {{ se_stts.card_text_size }}px;
    }

    .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__stats-wrap {
      width: min(100% - {{ se_stts.padding_horizontal | times: 2 }}px, {{ se_stts.content_width }}px);
      margin-top: {{ se_stts.stats_margin_top }}px;
      margin-bottom: {{ se_stts.stats_margin_bottom }}px;
    }

    .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__stats {
      grid-template-columns: repeat({{ se_stts.stats_columns }}, minmax(0, 1fr));
      gap: {{ se_stts.stats_gap }}px;
    }

    .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__stat-value {
      font-size: {{ se_stts.value_size }}px;
    }

    .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__stat-label {
      margin-top: {{ se_stts.label_margin_top }}px;
      font-size: {{ se_stts.label_size }}px;
    }

    .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__stat-text {
      margin-top: {{ se_stts.description_margin_top }}px;
      max-width: {{ se_stts.description_max_width }}px;
      font-size: {{ se_stts.description_size }}px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .smart-card-marquee-stats-{{ section.id }} .smart-card-marquee-stats__track {
      animation-play-state: paused;
    }
  }
{%- endstyle -%}

{%- capture slide_list -%}
  <div class="smart-card-marquee-stats__list" aria-hidden="true">
    {%- for block in slide_blocks -%}
      {%- liquid
        assign block_stts = block.settings
        assign slide_alt = block_stts.image.alt | default: block_stts.title | escape
      -%}
      <div
        class="smart-card-marquee-stats__slide"
        style="--card-background: {{ block_stts.background_color }}; --card-text-color: {{ block_stts.text_color }};"
        {{ block.shopify_attributes }}
      >
        {%- if block_stts.image != blank -%}
          {{ block_stts.image | image_url: width: 900 | image_tag: loading: loading_attribute, widths: '240, 360, 520, 700, 900', sizes: '(min-width: 768px) 260px, 190px', alt: slide_alt }}
        {%- elsif block_stts.title != blank -%}
          <span class="smart-card-marquee-stats__slide-text">{{ block_stts.title }}</span>
        {%- else -%}
          {{ 'image' | placeholder_svg_tag }}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
{%- endcapture -%}

<section class="smart-card-marquee-stats-{{ section.id }}" {{ section.shopify_attributes }}>
  {%- if slide_blocks.size > 0 -%}
    <div class="smart-card-marquee-stats__carousel">
      <div class="smart-card-marquee-stats__track">
        {{ slide_list }}
        {{ slide_list }}
        {{ slide_list }}
        {{ slide_list }}
        {{ slide_list }}
        {{ slide_list }}
        {{ slide_list }}
        {{ slide_list }}
      </div>
    </div>
  {%- endif -%}

  {%- if stat_blocks.size > 0 -%}
    <div class="smart-card-marquee-stats__stats-wrap">
      <div class="smart-card-marquee-stats__stats">
        {%- for block in stat_blocks -%}
          <div class="smart-card-marquee-stats__stat" {{ block.shopify_attributes }}>
            {%- if block.settings.value != blank -%}
              <p class="smart-card-marquee-stats__stat-value">{{ block.settings.value }}</p>
            {%- endif -%}

            {%- if block.settings.label != blank -%}
              <p class="smart-card-marquee-stats__stat-label">{{ block.settings.label }}</p>
            {%- endif -%}

            {%- if block.settings.description != blank -%}
              <p class="smart-card-marquee-stats__stat-text">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

