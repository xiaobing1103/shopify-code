{%- liquid
  assign se_stts = section.settings
  assign row_blocks = section.blocks | where: 'type', 'row'
-%}

{%- style -%}
  .smart-card-comparison-{{ section.id }} {
    margin-top: {{ se_stts.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ se_stts.margin_bottom | times: 0.75 | round: 0 }}px;
    background: {{ se_stts.background_color }};
    color: {{ se_stts.text_color }};
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__inner {
    width: min(100% - {{ se_stts.padding_horizontal_mobile | times: 2 }}px, {{ se_stts.content_width }}px);
    margin: 0 auto;
    padding-top: {{ se_stts.padding_top_mobile }}px;
    padding-bottom: {{ se_stts.padding_bottom_mobile }}px;
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__heading {
    margin: {{ se_stts.heading_margin_top_mobile }}px auto {{ se_stts.heading_margin_bottom_mobile }}px;
    max-width: {{ se_stts.heading_width }}px;
    text-align: center;
    color: {{ se_stts.heading_color }};
    font-size: {{ se_stts.heading_size_mobile }}px;
    line-height: {{ se_stts.heading_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.heading_weight }};
    letter-spacing: {{ se_stts.heading_letter_spacing }}px;
    text-transform: none;
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__highlight {
    display: inline-block;
    padding: {{ se_stts.highlight_padding_vertical_mobile }}px {{ se_stts.highlight_padding_horizontal_mobile }}px;
    background: {{ se_stts.highlight_background_color }};
    color: {{ se_stts.highlight_color }};
    font-size: {{ se_stts.highlight_size_mobile }}px;
    line-height: {{ se_stts.highlight_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.highlight_weight }};
    letter-spacing: {{ se_stts.highlight_letter_spacing }}px;
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__table {
    width: min(100%, {{ se_stts.table_width }}px);
    margin: {{ se_stts.table_margin_top_mobile }}px auto {{ se_stts.table_margin_bottom_mobile }}px;
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__row {
    display: grid;
    grid-template-columns: minmax(130px, 1.4fr) minmax(82px, 1fr) minmax(82px, 1fr);
    align-items: center;
    border-top: {{ se_stts.row_border_thickness }}px solid {{ se_stts.row_border_color }};
    min-height: {{ se_stts.row_height_mobile }}px;
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__row:last-child {
    border-bottom: {{ se_stts.row_border_thickness }}px solid {{ se_stts.row_border_color }};
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__cell {
    padding: {{ se_stts.cell_padding_vertical_mobile }}px {{ se_stts.cell_padding_horizontal_mobile }}px;
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__cell--status {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__head-cell {
    color: {{ se_stts.column_color }};
    font-size: {{ se_stts.column_size_mobile }}px;
    line-height: {{ se_stts.column_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.column_weight }};
    letter-spacing: {{ se_stts.column_letter_spacing }}px;
    text-align: center;
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__feature {
    color: {{ se_stts.feature_color }};
    font-size: {{ se_stts.feature_size_mobile }}px;
    line-height: {{ se_stts.feature_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.feature_weight }};
    letter-spacing: {{ se_stts.feature_letter_spacing }}px;
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__icon {
    width: {{ se_stts.icon_size_mobile }}px;
    height: {{ se_stts.icon_size_mobile }}px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__icon svg {
    width: {{ se_stts.icon_symbol_size_mobile }}px;
    height: {{ se_stts.icon_symbol_size_mobile }}px;
    display: block;
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__icon--check {
    background: {{ se_stts.check_background_color }};
    color: {{ se_stts.check_color }};
  }

  .smart-card-comparison-{{ section.id }} .smart-card-comparison__icon--cross {
    background: {{ se_stts.cross_background_color }};
    color: {{ se_stts.cross_color }};
  }

  @media (min-width: 768px) {
    .smart-card-comparison-{{ section.id }} {
      margin-top: {{ se_stts.margin_top }}px;
      margin-bottom: {{ se_stts.margin_bottom }}px;
    }

    .smart-card-comparison-{{ section.id }} .smart-card-comparison__inner {
      width: min(100% - {{ se_stts.padding_horizontal | times: 2 }}px, {{ se_stts.content_width }}px);
      padding-top: {{ se_stts.padding_top }}px;
      padding-bottom: {{ se_stts.padding_bottom }}px;
    }

    .smart-card-comparison-{{ section.id }} .smart-card-comparison__heading {
      margin-top: {{ se_stts.heading_margin_top }}px;
      margin-bottom: {{ se_stts.heading_margin_bottom }}px;
      font-size: {{ se_stts.heading_size }}px;
    }

    .smart-card-comparison-{{ section.id }} .smart-card-comparison__highlight {
      padding: {{ se_stts.highlight_padding_vertical }}px {{ se_stts.highlight_padding_horizontal }}px;
      font-size: {{ se_stts.highlight_size }}px;
    }

    .smart-card-comparison-{{ section.id }} .smart-card-comparison__table {
      margin-top: {{ se_stts.table_margin_top }}px;
      margin-bottom: {{ se_stts.table_margin_bottom }}px;
    }

    .smart-card-comparison-{{ section.id }} .smart-card-comparison__row {
      grid-template-columns: minmax(220px, 1.35fr) minmax(160px, 1fr) minmax(160px, 1fr);
      min-height: {{ se_stts.row_height }}px;
    }

    .smart-card-comparison-{{ section.id }} .smart-card-comparison__cell {
      padding: {{ se_stts.cell_padding_vertical }}px {{ se_stts.cell_padding_horizontal }}px;
    }

    .smart-card-comparison-{{ section.id }} .smart-card-comparison__head-cell {
      font-size: {{ se_stts.column_size }}px;
    }

    .smart-card-comparison-{{ section.id }} .smart-card-comparison__feature {
      font-size: {{ se_stts.feature_size }}px;
    }

    .smart-card-comparison-{{ section.id }} .smart-card-comparison__icon {
      width: {{ se_stts.icon_size }}px;
      height: {{ se_stts.icon_size }}px;
    }

    .smart-card-comparison-{{ section.id }} .smart-card-comparison__icon svg {
      width: {{ se_stts.icon_symbol_size }}px;
      height: {{ se_stts.icon_symbol_size }}px;
    }
  }
{%- endstyle -%}

{%- capture check_icon -%}
  <span class="smart-card-comparison__icon smart-card-comparison__icon--check" aria-label="Yes">
    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M5 10.4l3 3.1 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </span>
{%- endcapture -%}

{%- capture cross_icon -%}
  <span class="smart-card-comparison__icon smart-card-comparison__icon--cross" aria-label="No">
    <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M6.3 6.3l7.4 7.4M13.7 6.3l-7.4 7.4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </span>
{%- endcapture -%}

<section class="smart-card-comparison-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="smart-card-comparison__inner">
    {%- if se_stts.heading_before != blank or se_stts.heading_highlight != blank or se_stts.heading_after != blank -%}
      <h2 class="smart-card-comparison__heading">
        {%- if se_stts.heading_before != blank -%}{{ se_stts.heading_before }}{%- endif -%}
        {%- if se_stts.heading_highlight != blank -%}
          <span class="smart-card-comparison__highlight">{{ se_stts.heading_highlight }}</span>
        {%- endif -%}
        {%- if se_stts.heading_after != blank -%}{{ se_stts.heading_after }}{%- endif -%}
      </h2>
    {%- endif -%}

    <div class="smart-card-comparison__table">
      <div class="smart-card-comparison__row smart-card-comparison__row--head">
        <div class="smart-card-comparison__cell"></div>
        <div class="smart-card-comparison__cell smart-card-comparison__head-cell">{{ se_stts.digital_column_label }}</div>
        <div class="smart-card-comparison__cell smart-card-comparison__head-cell">{{ se_stts.paper_column_label }}</div>
      </div>

      {%- for block in row_blocks -%}
        <div class="smart-card-comparison__row" {{ block.shopify_attributes }}>
          <div class="smart-card-comparison__cell smart-card-comparison__feature">
            {{ block.settings.feature }}
          </div>
          <div class="smart-card-comparison__cell smart-card-comparison__cell--status">
            {%- if block.settings.digital_status == 'check' -%}
              {{ check_icon }}
            {%- elsif block.settings.digital_status == 'cross' -%}
              {{ cross_icon }}
            {%- endif -%}
          </div>
          <div class="smart-card-comparison__cell smart-card-comparison__cell--status">
            {%- if block.settings.paper_status == 'check' -%}
              {{ check_icon }}
            {%- elsif block.settings.paper_status == 'cross' -%}
              {{ cross_icon }}
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

