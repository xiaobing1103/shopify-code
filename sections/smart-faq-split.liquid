{%- liquid
  assign se_stts = section.settings
  assign faq_blocks = section.blocks | where: 'type', 'faq'
-%}

{%- style -%}
  .smart-faq-split-{{ section.id }} {
    margin-top: {{ se_stts.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ se_stts.margin_bottom | times: 0.75 | round: 0 }}px;
    background: {{ se_stts.background_color }};
    color: {{ se_stts.text_color }};
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__inner {
    width: min(100% - {{ se_stts.padding_horizontal_mobile | times: 2 }}px, {{ se_stts.content_width }}px);
    margin: 0 auto;
    padding-top: {{ se_stts.padding_top_mobile }}px;
    padding-bottom: {{ se_stts.padding_bottom_mobile }}px;
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ se_stts.columns_gap_mobile }}px;
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__content {
    text-align: {{ se_stts.content_align_mobile }};
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__heading {
    margin: {{ se_stts.heading_margin_top_mobile }}px 0 {{ se_stts.heading_margin_bottom_mobile }}px;
    color: {{ se_stts.heading_color }};
    font-size: {{ se_stts.heading_size_mobile }}px;
    line-height: {{ se_stts.heading_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.heading_weight }};
    letter-spacing: {{ se_stts.heading_letter_spacing }}px;
    text-transform: none;
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__text {
    margin: {{ se_stts.text_margin_top_mobile }}px 0 {{ se_stts.text_margin_bottom_mobile }}px;
    color: {{ se_stts.body_text_color }};
    font-size: {{ se_stts.text_size_mobile }}px;
    line-height: {{ se_stts.text_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.text_weight }};
    letter-spacing: {{ se_stts.text_letter_spacing }}px;
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: {{ se_stts.button_gap }}px;
    min-height: {{ se_stts.button_height_mobile }}px;
    margin: {{ se_stts.button_margin_top_mobile }}px 0 {{ se_stts.button_margin_bottom_mobile }}px;
    padding: 0 {{ se_stts.button_padding_horizontal_mobile }}px;
    border-radius: {{ se_stts.button_radius }}px;
    background: {{ se_stts.button_background_color }};
    color: {{ se_stts.button_color }};
    font-size: {{ se_stts.button_size_mobile }}px;
    line-height: 1;
    font-weight: {{ se_stts.button_weight }};
    letter-spacing: {{ se_stts.button_letter_spacing }}px;
    text-decoration: none;
    transition: background-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__button:hover {
    background: {{ se_stts.button_hover_background_color }};
    color: {{ se_stts.button_hover_color }};
    transform: translateY(-1px);
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__button svg {
    width: {{ se_stts.button_icon_size_mobile }}px;
    height: {{ se_stts.button_icon_size_mobile }}px;
    flex: 0 0 auto;
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__items {
    display: grid;
    gap: {{ se_stts.item_gap_mobile }}px;
    margin: {{ se_stts.faq_margin_top_mobile }}px 0 {{ se_stts.faq_margin_bottom_mobile }}px;
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__item {
    border: {{ se_stts.item_border_thickness }}px solid {{ se_stts.item_border_color }};
    border-radius: {{ se_stts.item_radius }}px;
    background: {{ se_stts.item_background_color }};
    overflow: hidden;
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__question {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    min-height: {{ se_stts.item_height_mobile }}px;
    padding: {{ se_stts.question_padding_vertical_mobile }}px {{ se_stts.question_padding_horizontal_mobile }}px;
    color: {{ se_stts.question_color }};
    font-size: {{ se_stts.question_size_mobile }}px;
    line-height: {{ se_stts.question_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.question_weight }};
    letter-spacing: {{ se_stts.question_letter_spacing }}px;
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__question::-webkit-details-marker {
    display: none;
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__chevron {
    width: {{ se_stts.chevron_size_mobile }}px;
    height: {{ se_stts.chevron_size_mobile }}px;
    color: {{ se_stts.chevron_color }};
    flex: 0 0 auto;
    transition: transform 180ms ease;
  }

  .smart-faq-split-{{ section.id }} details[open] .smart-faq-split__chevron {
    transform: rotate(180deg);
  }

  .smart-faq-split-{{ section.id }} .smart-faq-split__answer {
    margin: {{ se_stts.answer_margin_top_mobile }}px {{ se_stts.answer_margin_horizontal_mobile }}px {{ se_stts.answer_margin_bottom_mobile }}px;
    padding: {{ se_stts.answer_padding_top_mobile }}px 0 {{ se_stts.answer_padding_bottom_mobile }}px;
    color: {{ se_stts.answer_color }};
    font-size: {{ se_stts.answer_size_mobile }}px;
    line-height: {{ se_stts.answer_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.answer_weight }};
    letter-spacing: {{ se_stts.answer_letter_spacing }}px;
    border-top: {{ se_stts.answer_border_thickness }}px solid {{ se_stts.answer_border_color }};
  }

  @media (min-width: 768px) {
    .smart-faq-split-{{ section.id }} {
      margin-top: {{ se_stts.margin_top }}px;
      margin-bottom: {{ se_stts.margin_bottom }}px;
    }

    .smart-faq-split-{{ section.id }} .smart-faq-split__inner {
      width: min(100% - {{ se_stts.padding_horizontal | times: 2 }}px, {{ se_stts.content_width }}px);
      padding-top: {{ se_stts.padding_top }}px;
      padding-bottom: {{ se_stts.padding_bottom }}px;
      grid-template-columns: minmax(260px, {{ se_stts.left_column_width }}fr) minmax(420px, {{ se_stts.right_column_width }}fr);
      gap: {{ se_stts.columns_gap }}px;
      align-items: start;
    }

    .smart-faq-split-{{ section.id }} .smart-faq-split__content {
      text-align: {{ se_stts.content_align }};
    }

    .smart-faq-split-{{ section.id }} .smart-faq-split__heading {
      margin-top: {{ se_stts.heading_margin_top }}px;
      margin-bottom: {{ se_stts.heading_margin_bottom }}px;
      font-size: {{ se_stts.heading_size }}px;
    }

    .smart-faq-split-{{ section.id }} .smart-faq-split__text {
      margin-top: {{ se_stts.text_margin_top }}px;
      margin-bottom: {{ se_stts.text_margin_bottom }}px;
      font-size: {{ se_stts.text_size }}px;
    }

    .smart-faq-split-{{ section.id }} .smart-faq-split__button {
      min-height: {{ se_stts.button_height }}px;
      margin-top: {{ se_stts.button_margin_top }}px;
      margin-bottom: {{ se_stts.button_margin_bottom }}px;
      padding-left: {{ se_stts.button_padding_horizontal }}px;
      padding-right: {{ se_stts.button_padding_horizontal }}px;
      font-size: {{ se_stts.button_size }}px;
    }

    .smart-faq-split-{{ section.id }} .smart-faq-split__button svg {
      width: {{ se_stts.button_icon_size }}px;
      height: {{ se_stts.button_icon_size }}px;
    }

    .smart-faq-split-{{ section.id }} .smart-faq-split__items {
      gap: {{ se_stts.item_gap }}px;
      margin-top: {{ se_stts.faq_margin_top }}px;
      margin-bottom: {{ se_stts.faq_margin_bottom }}px;
    }

    .smart-faq-split-{{ section.id }} .smart-faq-split__question {
      min-height: {{ se_stts.item_height }}px;
      padding: {{ se_stts.question_padding_vertical }}px {{ se_stts.question_padding_horizontal }}px;
      font-size: {{ se_stts.question_size }}px;
    }

    .smart-faq-split-{{ section.id }} .smart-faq-split__chevron {
      width: {{ se_stts.chevron_size }}px;
      height: {{ se_stts.chevron_size }}px;
    }

    .smart-faq-split-{{ section.id }} .smart-faq-split__answer {
      margin: {{ se_stts.answer_margin_top }}px {{ se_stts.answer_margin_horizontal }}px {{ se_stts.answer_margin_bottom }}px;
      padding-top: {{ se_stts.answer_padding_top }}px;
      padding-bottom: {{ se_stts.answer_padding_bottom }}px;
      font-size: {{ se_stts.answer_size }}px;
    }
  }
{%- endstyle -%}

<section class="smart-faq-split-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="smart-faq-split__inner">
    <div class="smart-faq-split__content">
      {%- if se_stts.heading != blank -%}
        <h2 class="smart-faq-split__heading">{{ se_stts.heading | escape | newline_to_br }}</h2>
      {%- endif -%}

      {%- if se_stts.text != blank -%}
        <div class="smart-faq-split__text">{{ se_stts.text | escape | newline_to_br }}</div>
      {%- endif -%}

      {%- if se_stts.button_label != blank -%}
        <a class="smart-faq-split__button" href="{{ se_stts.button_link | default: '#' }}">
          <span>{{ se_stts.button_label }}</span>
          {%- if se_stts.show_button_arrow -%}
            <svg viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2.3 7h9.1M7.8 3.4 11.4 7l-3.6 3.6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {%- endif -%}
        </a>
      {%- endif -%}
    </div>

    <div class="smart-faq-split__items">
      {%- for block in faq_blocks -%}
        <details class="smart-faq-split__item" {% if block.settings.open_by_default %}open{% endif %} {{ block.shopify_attributes }}>
          <summary class="smart-faq-split__question">
            <span>{{ block.settings.question }}</span>
            <svg class="smart-faq-split__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          {%- if block.settings.answer != blank -%}
            <div class="smart-faq-split__answer">{{ block.settings.answer | escape | newline_to_br }}</div>
          {%- endif -%}
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Smart FAQ split",
  "tag": "section",
  "class": "t4s-section smart-faq-split-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked\nQuestions"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Your guide to the TaeMark Teams Plus."
    },
