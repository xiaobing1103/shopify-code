      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "show_button_arrow",
      "label": "Show button arrow",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 900,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Content width",
      "default": 1040
    },
    {
      "type": "range",
      "id": "left_column_width",
      "min": 1,
      "max": 4,
      "step": 0.1,
      "label": "Left column width",
      "default": 1.1
    },
    {
      "type": "range",
      "id": "right_column_width",
      "min": 1,
