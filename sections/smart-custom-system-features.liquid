{%- liquid
  assign se_stts = section.settings
  assign feature_blocks = section.blocks | where: 'type', 'feature'
  assign loading_attribute = 'eager'

  if se_stts.lazy_load
    assign loading_attribute = 'lazy'
  endif
-%}

{%- style -%}
  .smart-system-features-{{ section.id }} {
    margin-top: {{ se_stts.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ se_stts.margin_bottom | times: 0.75 | round: 0 }}px;
    background: {{ se_stts.background_color }};
    color: {{ se_stts.text_color }};
  }

  .smart-system-features-{{ section.id }} .smart-system-features__inner {
    width: min(100% - {{ se_stts.padding_horizontal_mobile | times: 2 }}px, {{ se_stts.content_width }}px);
    margin: 0 auto;
    padding-top: {{ se_stts.padding_top_mobile }}px;
    padding-bottom: {{ se_stts.padding_bottom_mobile }}px;
    text-align: center;
  }

  .smart-system-features-{{ section.id }} .smart-system-features__header {
    max-width: {{ se_stts.header_width }}px;
    margin: 0 auto;
  }

  .smart-system-features-{{ section.id }} .smart-system-features__heading {
    margin: {{ se_stts.heading_margin_top_mobile }}px 0 {{ se_stts.heading_margin_bottom_mobile }}px;
    color: {{ se_stts.heading_color }};
    font-size: {{ se_stts.heading_size_mobile }}px;
    line-height: {{ se_stts.heading_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.heading_weight }};
    letter-spacing: {{ se_stts.heading_letter_spacing }}px;
    text-transform: none;
  }

  .smart-system-features-{{ section.id }} .smart-system-features__text {
    margin: {{ se_stts.text_margin_top_mobile }}px auto {{ se_stts.text_margin_bottom_mobile }}px;
    max-width: {{ se_stts.text_width }}px;
    color: {{ se_stts.text_color }};
    font-size: {{ se_stts.text_size_mobile }}px;
    line-height: {{ se_stts.text_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.text_weight }};
    letter-spacing: {{ se_stts.text_letter_spacing }}px;
  }

  .smart-system-features-{{ section.id }} .smart-system-features__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ se_stts.feature_gap_mobile }}px;
    margin-top: {{ se_stts.features_margin_top_mobile }}px;
    margin-bottom: {{ se_stts.features_margin_bottom_mobile }}px;
  }

  .smart-system-features-{{ section.id }} .smart-system-features__item {
    text-align: center;
  }

  .smart-system-features-{{ section.id }} .smart-system-features__icon {
    width: var(--feature-icon-size-mobile, {{ se_stts.icon_size_mobile }}px);
    height: var(--feature-icon-size-mobile, {{ se_stts.icon_size_mobile }}px);
    margin: {{ se_stts.icon_margin_top_mobile }}px auto {{ se_stts.icon_margin_bottom_mobile }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .smart-system-features-{{ section.id }} .smart-system-features__icon img,
  .smart-system-features-{{ section.id }} .smart-system-features__icon svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  .smart-system-features-{{ section.id }} .smart-system-features__icon svg {
    background: transparent;
  }

  .smart-system-features-{{ section.id }} .smart-system-features__title {
    margin: {{ se_stts.feature_title_margin_top_mobile }}px 0 {{ se_stts.feature_title_margin_bottom_mobile }}px;
    color: {{ se_stts.feature_title_color }};
    font-size: {{ se_stts.feature_title_size_mobile }}px;
    line-height: {{ se_stts.feature_title_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.feature_title_weight }};
    letter-spacing: {{ se_stts.feature_title_letter_spacing }}px;
    text-transform: none;
  }

  .smart-system-features-{{ section.id }} .smart-system-features__description {
    margin: {{ se_stts.feature_text_margin_top_mobile }}px auto {{ se_stts.feature_text_margin_bottom_mobile }}px;
    max-width: {{ se_stts.feature_text_width_mobile }}px;
    color: {{ se_stts.feature_text_color }};
    font-size: {{ se_stts.feature_text_size_mobile }}px;
    line-height: {{ se_stts.feature_text_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.feature_text_weight }};
    letter-spacing: {{ se_stts.feature_text_letter_spacing }}px;
  }

  @media (min-width: 768px) {
    .smart-system-features-{{ section.id }} {
      margin-top: {{ se_stts.margin_top }}px;
      margin-bottom: {{ se_stts.margin_bottom }}px;
    }

    .smart-system-features-{{ section.id }} .smart-system-features__inner {
      width: min(100% - {{ se_stts.padding_horizontal | times: 2 }}px, {{ se_stts.content_width }}px);
      padding-top: {{ se_stts.padding_top }}px;
      padding-bottom: {{ se_stts.padding_bottom }}px;
    }

    .smart-system-features-{{ section.id }} .smart-system-features__heading {
      margin-top: {{ se_stts.heading_margin_top }}px;
      margin-bottom: {{ se_stts.heading_margin_bottom }}px;
      font-size: {{ se_stts.heading_size }}px;
    }

    .smart-system-features-{{ section.id }} .smart-system-features__text {
      margin-top: {{ se_stts.text_margin_top }}px;
      margin-bottom: {{ se_stts.text_margin_bottom }}px;
      font-size: {{ se_stts.text_size }}px;
    }

    .smart-system-features-{{ section.id }} .smart-system-features__grid {
      grid-template-columns: repeat({{ se_stts.columns }}, minmax(0, 1fr));
      gap: {{ se_stts.feature_gap }}px;
      margin-top: {{ se_stts.features_margin_top }}px;
      margin-bottom: {{ se_stts.features_margin_bottom }}px;
    }

    .smart-system-features-{{ section.id }} .smart-system-features__icon {
      width: var(--feature-icon-size, {{ se_stts.icon_size }}px);
      height: var(--feature-icon-size, {{ se_stts.icon_size }}px);
      margin-top: {{ se_stts.icon_margin_top }}px;
      margin-bottom: {{ se_stts.icon_margin_bottom }}px;
    }

    .smart-system-features-{{ section.id }} .smart-system-features__title {
      margin-top: {{ se_stts.feature_title_margin_top }}px;
      margin-bottom: {{ se_stts.feature_title_margin_bottom }}px;
      font-size: {{ se_stts.feature_title_size }}px;
    }

    .smart-system-features-{{ section.id }} .smart-system-features__description {
      margin-top: {{ se_stts.feature_text_margin_top }}px;
      margin-bottom: {{ se_stts.feature_text_margin_bottom }}px;
      max-width: {{ se_stts.feature_text_width }}px;
      font-size: {{ se_stts.feature_text_size }}px;
    }
  }
{%- endstyle -%}

<section class="smart-system-features-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="smart-system-features__inner">
    <div class="smart-system-features__header">
      {%- if se_stts.heading != blank -%}
        <h2 class="smart-system-features__heading">{{ se_stts.heading }}</h2>
      {%- endif -%}

      {%- if se_stts.text != blank -%}
        <div class="smart-system-features__text">{{ se_stts.text | escape | newline_to_br }}</div>
      {%- endif -%}
    </div>

    {%- if feature_blocks.size > 0 -%}
      <div class="smart-system-features__grid">
        {%- for block in feature_blocks -%}
          <div class="smart-system-features__item" {{ block.shopify_attributes }}>
            <div
              class="smart-system-features__icon"
              style="--feature-icon-size-mobile: {{ block.settings.icon_image_size_mobile | default: se_stts.icon_size_mobile }}px; --feature-icon-size: {{ block.settings.icon_image_size | default: se_stts.icon_size }}px;"
            >
              {%- if block.settings.icon != blank -%}
                {{ block.settings.icon | image_url: width: 480 | image_tag: loading: loading_attribute, widths: '64, 96, 128, 180, 240, 320, 480', alt: block.settings.icon.alt | default: block.settings.title | escape }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag }}
              {%- endif -%}
            </div>

            {%- if block.settings.title != blank -%}
              <h3 class="smart-system-features__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="smart-system-features__description">{{ block.settings.text | escape | newline_to_br }}</div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
