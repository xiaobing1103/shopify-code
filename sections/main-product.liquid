                      style="margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;"
                    >
                      {{ block.settings.text }}
                    </div>
                  </div>

                {%- when 'media_below_html' -%}
                  <div class="t4s-product-media-block t4s-product-media-block--html" {{ block.shopify_attributes }}>
                    <div
                      class="t4s-rte"
                      style="margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;"
                    >
                      {{ block.settings.page.content }}
