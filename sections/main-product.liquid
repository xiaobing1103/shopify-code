{%- comment -%}
  Color_pink | alt text
  t4option0_0 | alt text
{%- endcomment -%}

{%- liquid
  assign seBlocks_temp = section.blocks
  assign block_form_temp = seBlocks_temp | where: 'type', 'form' | first
  if block_form_temp.settings.show_kaching_bundles == false
    assign hide_kaching_bundles = true
  else
    assign hide_kaching_bundles = false
  endif
-%}

{%- if hide_kaching_bundles -%}
  <style>
    /* Hide Kaching Bundles when the Product Form block disables them. */
    kaching-bundle,
    kaching-bundles-block,
    .kaching-bundles,
    [class*='kaching'] {
      display: none !important;
      visibility: hidden !important;
      opacity: 0 !important;
      height: 0 !important;
      overflow: hidden !important;
    }
  </style>
{%- endif -%}

{%- liquid
  assign isProductAvailable = product.available
  if isProductAvailable and settings.variant_remove == '2'
    assign remove_soldout = true
  else
    assign remove_soldout = false
  endif
  assign se_stts = section.settings
  assign se_id = section.id
  assign pr_se_id = product.id | append: se_id
  assign media_layout = se_stts.media_layout
  assign pr_variants = product.variants
  assign variants_size = pr_variants.size
  assign selected_variant = product.selected_variant
  assign pr_curent = settings.pr_curent
  if pr_curent == '1' and variants_size > 1
    assign current_variant = selected_variant
  elsif pr_curent == '2'
    assign current_variant = selected_variant | default: pr_variants.first
    if remove_soldout and current_variant.available == false and isProductAvailable
      assign current_variant = product.first_available_variant
    endif
  else
    assign current_variant = product.selected_or_first_available_variant
  endif
  assign PR_no_pick = false
  if pr_curent == '1' and variants_size > 1 and selected_variant == blank
    assign PR_no_pick = true
  endif
  assign isProductDefault = product.has_only_default_variant

  assign ntsoldout = false
  assign unvariants = false
  assign ck_so_un = false
  if isProductDefault == false and variants_size > 1
    assign unavailable_prs = pr_variants | where: 'available', false
    assign options_size = product.options.size
    assign vls0 = product.options_with_values[0].values.size | default: 1
    assign vls1 = product.options_with_values[1].values.size | default: 1
    assign vls2 = product.options_with_values[2].values.size | default: 1
    assign ntvariants_size = vls0 | times: vls1 | times: vls2 | minus: pr_variants.size
    if unavailable_prs.size > 0 or product.available == false
      assign ntsoldout = true
    endif
    if ntvariants_size > 0
      assign unvariants = true
    endif
    if ntsoldout or unvariants
      assign ck_so_un = true
    endif
  endif
  assign pr_tags = product.tags

  assign ck_external = false
  assign pr_metafields = product.metafields
  assign pr_metafields_meta = pr_metafields.meta
  assign meta_theme = product.metafields.theme
  assign cus_qty = meta_theme.cus_qty | default: 1
  assign isExternal = false
  assign external_title = meta_theme.external_title
  assign external_link = meta_theme.external_link
  if external_title != blank and external_link != blank
    assign isExternal = true
  endif
  assign isGrouped = false
  assign seBlocks = section.blocks
  assign block_form = seBlocks | where: 'type', 'form' | first
  assign show_add_to_cart_button = true
  if block_form != blank and block_form.settings.show_add_to_cart_button == false
    assign show_add_to_cart_button = false
  endif
  assign block_bundle_selector = seBlocks | where: 'type', 'bundle_selector' | first
  assign block_custom_redirect = seBlocks | where: 'type', 'custom_redirect_button' | first
  assign bundle_selector_enabled = false
  if block_bundle_selector != blank and block_bundle_selector.settings.enable_bundle_selector
    assign bundle_selector_enabled = true
    assign default_bundle = block_bundle_selector.settings.default_bundle | default: 'pack2'
    if default_bundle == 'pack1'
      assign cus_qty = block_bundle_selector.settings.pack1_quantity | default: 1
    elsif default_bundle == 'pack3'
      assign cus_qty = block_bundle_selector.settings.pack3_quantity | default: 5
    else
      assign cus_qty = block_bundle_selector.settings.pack2_quantity | default: 3
    endif
  endif
  if bundle_selector_enabled == false and current_variant.quantity_rule.min and cus_qty < current_variant.quantity_rule.min
    assign cus_qty = current_variant.quantity_rule.min
  endif
  if block_form.settings.product_list != blank
    assign isGrouped = true
  endif
  assign custom_badge = meta_theme.custom_badge
  if custom_badge != blank
    assign arr_badge = custom_badge | replace: '  ', '' | replace: ' ;', ';' | replace: '; ', ';' | split: ';' | join: 'nt-t4s' | escape | split: 'nt-t4s'
    assign arr_badge_handle = arr_badge | join: 'nt-t4s' | handle | split: 'nt-t4s'
  else
    assign badge_tags = product.tags | where: 'badge_'
    if badge_tags.size > 0
      assign arr_badge_tags = badge_tags | join: 'nt-t4s' | remove: 'badge_' | escape
      assign arr_badge = arr_badge_tags | split: 'nt-t4s'
      assign arr_badge_handle = arr_badge_tags | handle | split: 'nt-t4s'
    endif
  endif

  assign product_media = product.media
  assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
  assign media_size = product_media.size
  if media_size < 1
    assign media_layout = 'no_media_size'
  elsif media_size == 1
    assign media_layout = 'one_media_size'
  endif
  assign canMedia_group = false
  assign mediaAlt = product_media | map: 'alt' | join: 'nt-t4s'
  if settings.use_group_media and variants_size > 1 and media_size > 1
    if mediaAlt contains 't4option_' or mediaAlt contains 'olor_'
      assign canMedia_group = true

      if mediaAlt contains 't4option'
        assign ops_name = product.options_with_values | map: 'name'
        assign ops_name_1 = product.options_by_name[ops_name[0]].values
        assign ops_name_2 = product.options_by_name[ops_name[1]].values
        assign ops_name_3 = product.options_by_name[ops_name[2]].values
      endif

      unless PR_no_pick
        assign isMediaHidden = 'is--media-hide'
        assign current_option1 = current_variant.option1 | downcase
        assign current_option2 = current_variant.option2 | downcase
        assign current_option3 = current_variant.option3 | downcase
      endunless
    endif
  endif

  if mediaAlt contains 'break--360'
    assign has_media_360 = true
  else
    assign has_media_360 = false
  endif

  case se_stts.media_size
    when 'small'
      assign class_media = 'col-md-4'
      assign class_info = 'col-md-8'
      assign height = 530
    when 'medium'
      assign class_media = 'col-md-6'
      assign class_info = 'col-md-6'
      assign height = 720
    when 'large'
      assign class_media = 'col-md-7'
      assign class_info = 'col-md-5'
      assign height = 1090
  endcase

  assign image_ratio = se_stts.image_ratio
  if image_ratio == 'ratioadapt'
    assign imgatt = ''
  else
    assign imgatt = 'data-'
  endif
  if settings.enable_his and PR_no_pick == false
    assign enableHistoryState = settings.enable_his
  else
    assign enableHistoryState = false
  endif

  assign links_vendor = linklists['image-vendor-the4'].links
  assign pr_vendor = product.vendor

  assign inventory_quantity = current_variant.inventory_quantity
  assign inventory_management = current_variant.inventory_management
  if inventory_quantity <= 0 and inventory_management == 'shopify' and current_variant.available
    assign classdn1 = 't4s-dn'
    assign classdn2 = ''
    assign isPreoder = true
  else
    assign classdn1 = ''
    assign classdn2 = 't4s-dn'
    assign isPreoder = false
  endif

  assign main_click = se_stts.main_click
  if main_click == 'pswp'
    assign class_pswp_disable = ''
  else
    assign class_pswp_disable = ' is-pswp-disable'
  endif

  assign bk_stts__sizeg = Block_sizeg.settings
  assign bk_size_chart = bk_stts__sizeg.size_chart | default: '1'
  assign pos_sizeg = bk_stts__sizeg.pos_sizeg

  assign Block_price = seBlocks | where: 'type', 'price_review' | first
  assign block_price_stts = Block_price.settings
  assign Block_viewed_today_notice = seBlocks | where: 'type', 'viewed_today_notice' | first
  assign inline_viewed_today_notice = false
  if Block_viewed_today_notice != blank
    assign block_viewed_today_notice_stts = Block_viewed_today_notice.settings
    if Block_price != blank and block_viewed_today_notice_stts.text != blank and Block_price.settings.rating
      assign inline_viewed_today_notice = true
    endif
  endif

  assign tabCheck = false
  assign idTabDes = 't4s-tab-des' | append: se_id
  assign idTabReview = 't4s-tab-review' | append: se_id
  assign tabs_position = se_stts.tabs_position
  assign enable_video_looping = se_stts.enable_video_looping
  assign enable_video_muting = se_stts.enable_video_muting
  assign enable_video_autoplaying = se_stts.enable_video_autoplaying
  case media_layout
    when 'thumbnails_left', 'thumbnails_bottom', 'thumbnails_right', 'without_thumbnails'
      assign hasIsotope = false
    else
      assign hasIsotope = true
  endcase
  assign use_link_vendor = settings.use_link_vendor

  assign isSticky = false
  assign isStickyMB = false
  assign sticky_mode = se_stts.sticky_mode
  if sticky_mode != '0' and isGrouped == false and isProductAvailable and settings.atc_ajax_enable and show_add_to_cart_button
    assign isSticky = true
    if sticky_mode == '2'
      assign isStickyMB = true
    endif
  endif

  assign media_heading = se_stts.media_heading
  assign media_heading_show_desktop = se_stts.media_heading_show_desktop
  assign media_heading_show_mobile = se_stts.media_heading_show_mobile
  assign media_heading_size = se_stts.media_heading_size
  assign media_heading_height = se_stts.media_heading_height
  assign media_heading_color = se_stts.media_heading_color
  assign media_heading_bg_color = se_stts.media_heading_bg_color
  assign media_heading_bg_gradient = se_stts.media_heading_bg_gradient
  assign media_heading_padding_v = se_stts.media_heading_padding_v
  assign media_heading_padding_h = se_stts.media_heading_padding_h
  assign media_heading_radius = se_stts.media_heading_radius
  assign featured_info_group_enable = se_stts.featured_info_group_enable
  assign customization_group_enable = se_stts.customization_group_enable
-%}

{%- assign media_custom_img = se_stts.media_custom_img -%}
{%- assign media_custom_img_enable = se_stts.media_custom_img_enable -%}
{%- assign media_custom_img_show_desktop = se_stts.media_custom_img_show_desktop -%}
{%- assign media_custom_img_show_mobile = se_stts.media_custom_img_show_mobile -%}
{%- assign media_custom_img_width = se_stts.media_custom_img_width -%}
{%- assign media_custom_img_radius = se_stts.media_custom_img_radius -%}

{%- capture html_sizeg -%}
  {%- if bk_size_chart != '1' and Block_sizeg != blank -%}
    {%- liquid
      assign ck_s = true
      assign sc_type = bk_stts__sizeg.sc_type
      assign page_size = bk_stts__sizeg.page
      assign image = bk_stts__sizeg.image

      if bk_size_chart == '2' or pos_sizeg == '2'
        assign ck_s = false
        assign size_ck = bk_stts__sizeg.size_ck | append: ',size,sizes,Gr??e'
        assign get_size = size_ck | downcase | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
        for option in product.options_with_values
          assign name = option.name | downcase
          if get_size contains name
            assign name_sizeg = name
            assign ck_s = true
            break
          endif
        endfor
      endif
    -%}

    {%- if sc_type == '1' and page_size != blank and ck_s -%}
      <a class="t4s-ch t4s-btn__size-chart" data-no-instant rel="nofollow" href="{{ page_size.url }}" data-class="t4s-mfp-btn-close-inline" data-id="t4s-pr-popup__size-guide" data-storageid="{{ page_size.url }}" data-open-mfp-ajax data-style="max-width:950px" data-mfp-src="{{ page_size.url }}/?section_id=ajax_popup">{{ 'products.product.product_size_guide' | t }}</a>
    {%- elsif sc_type == '2' and image != blank and ck_s -%}
      <a class="t4s-ch t4s-btn__size-chart" data-no-instant rel="nofollow"  href="{{ product.url }}" data-t4s-image-opend data-pswp-src="{{ image | image_url }}" data-pswp-w="{{ image.width }}" data-pswp-h="{{ image.height }}" data-pswp-class="pswp__size-guide">{{ 'products.product.product_size_guide' | t }}</a>

    {%- endif -%}

  {%- endif -%}
{%- endcapture -%}

{%- if Block_price != blank and product.price_varies and block_price_stts.price != '0' -%}
  {%- liquid
    assign size_price_pr_mb = block_price_stts.size_price_pr_mb | default: block_price_stts.size_price_pr
    assign fw_price_pr_mb = block_price_stts.fw_price_pr_mb | default: block_price_stts.fw_price_pr
  -%}
  {%- capture style_price -%}
  style="--price-size:{{ block_price_stts.size_price_pr }}px;--price-weight:{{ block_price_stts.fw_price_pr }};--price-color:{{ block_price_stts.price_color }};--price-compare-color:{{ block_price_stts.price_compare_color | default: block_price_stts.price_color }};--price-sale-color:{{ block_price_stts.price_sale_color }};"
  {%- endcapture -%}
  <style>
    @media (max-width: 767px) {
      #product-form-{{ pr_se_id }} .t4s-product-price {
        --price-size: {{ size_price_pr_mb }}px !important;
        --price-weight: {{ fw_price_pr_mb }} !important;
      }
    }
  </style>
  {%- capture html_price -%}
    {%- render 'product-price-single', variant: current_variant, product: product, PR_no_pick: false, type_sale: block_price_stts.type_sale, price_varies_style: '0', style_inline: style_price, hide_compare_price: block_price_stts.hide_compare_price, show_currency_code: block_price_stts.show_currency_code -%}
  {%- endcapture -%}
{%- endif -%}

{{ 'pre_flickityt4s.min.css' | asset_url | stylesheet_tag }}
{{ 'slider-settings.css' | asset_url | stylesheet_tag }}
{{ 'main-product.css' | asset_url | stylesheet_tag }}

{%- comment -%} Shared product-level style output for this section. {%- endcomment -%}
{%- render 'product-custom-styles',
  se_stts: se_stts,
  se_id: se_id,
  media_heading: media_heading,
  media_heading_size: media_heading_size,
  media_heading_height: media_heading_height,
  media_heading_color: media_heading_color,
  media_heading_bg_color: media_heading_bg_color,
  media_heading_bg_gradient: media_heading_bg_gradient,
  media_heading_padding_v: media_heading_padding_v,
  media_heading_padding_h: media_heading_padding_h,
  media_heading_radius: media_heading_radius,
  media_heading_border_width: media_heading_border_width,
  media_heading_border_color: media_heading_border_color,
  media_heading_show_desktop: media_heading_show_desktop,
  media_heading_show_mobile: media_heading_show_mobile,
  media_custom_img_enable: media_custom_img_enable,
  media_custom_img: media_custom_img,
  media_custom_img_width: media_custom_img_width,
  media_custom_img_radius: media_custom_img_radius,
  media_custom_img_show_desktop: media_custom_img_show_desktop,
  media_custom_img_show_mobile: media_custom_img_show_mobile
-%}

{%- comment -%} Product Personalizer shared styles. {%- endcomment -%}
{%- render 'product-personalizer-styles', se_stts: se_stts, product: product -%}

{%- if media_heading != blank -%}
  <style>
    .t4s-product-media-heading-{{ se_id }} {
      position: absolute;
      top: 12px;
      right: 12px;
      z-index: 10;
      font-size: {{ media_heading_size }}px;
      line-height: {{ media_heading_height }}%;
      color: {{ media_heading_color }};
      {% if media_heading_bg_gradient != blank %}
      background: {{ media_heading_bg_gradient }};
      {% else %}
      background: {{ media_heading_bg_color }};
      {% endif %}
      padding: {{ media_heading_padding_v }}px {{ media_heading_padding_h }}px;
      border-radius: {{ media_heading_radius }}px;
      border: {{ media_heading_border_width }}px solid {{ media_heading_border_color }};
      font-weight: 500;
      {% if media_heading_show_desktop %}
      display: block;
      {% else %}
      display: none;
      {% endif %}
    }

    @media (max-width: 767px) {
      .t4s-product-media-heading-{{ se_id }} {
        {% if media_heading_show_mobile %}
        display: block;
        {% else %}
        display: none;
        {% endif %}
      }
    }
  </style>
{%- endif -%}

{%- if media_custom_img_enable and media_custom_img != blank -%}
  <style>
    .t4s-product-media-custom-img-{{ se_id }} {
      position: absolute;
      top: 12px;
      left: 12px;
      z-index: 10;
      width: {{ media_custom_img_width }}px;
      height: {{ media_custom_img_width }}px;
      border-radius: {{ media_custom_img_radius }}px;
      overflow: hidden;
      {% if media_custom_img_show_desktop %}
      display: block;
      {% else %}
      display: none;
      {% endif %}
    }
    .t4s-product-media-custom-img-{{ se_id }} img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    @media (max-width: 767px) {
      .t4s-product-media-custom-img-{{ se_id }} {
        {% if media_custom_img_show_mobile %}
        display: block;
        {% else %}
        display: none;
        {% endif %}
      }
    }
  </style>
{%- endif -%}

<div class="t4s-container t4s-main-product__content is--layout_{{ se_stts.pr_layout }} t4s-product-media__{{ media_layout }} t4s-product-thumb-size__{{ se_stts.thumb_lr_size }}">
  <div class="t4s-row">
    <div class="t4s-col-item t4s-col-12 t4s-main-area">
      <div
        data-product-featured='{"id":"{{ product.id }}","isMainProduct":true, "sectionId":"{{ se_id }}", "disableSwatch":{{ isProductDefault }}, "media": {% if media_size > 1 %}true{% else %}false{% endif %},"enableHistoryState": {{ enableHistoryState }}, "formID": "#product-form-{{ pr_se_id }}", "removeSoldout":{{ remove_soldout }}, "changeVariantByImg":{{ settings.use_change_variant_by_img }}, "isNoPick":{{ PR_no_pick }},"hasSoldoutUnavailable":{{ ck_so_un }},"enable_zoom_click_mb":{{ se_stts.enable_zoom_click_mb }},"main_click":"{{ main_click }}","canMediaGroup":{{ canMedia_group }},"isGrouped":{{ isGrouped }},"hasIsotope":{{ hasIsotope }},"available":{{ product.available }}, "customBadge":{{ arr_badge | json }}, "customBadgeHandle":{{ arr_badge_handle | json }},"dateStart":{{ product.created_at | date: "%s" }}, "compare_at_price":{{ current_variant.compare_at_price | json }},"price":{{ current_variant.price | json }}, "isPreoder":{{ isPreoder }}, "showFirstMedia":{{ settings.show_first_media }}, "isSticky":{{ isSticky }}, "isStickyMB":{{ isStickyMB }}, "stickyShow":"{{ se_stts.sticky_show }}", "useStickySelect": {{ se_stts.enable_select }} }'
        class="t4s-row t4s-row__product is-zoom-type__{{ se_stts.zoom_tp }}"
        data-t4s-zoom-main
        {% if main_click == 'zoom' %}
          data-zoom-options='{"type":"{{ se_stts.zoom_tp }}", "magnify":2, "touch":false, "pr_type":"1","isZoomPR": true}'
        {% endif %}
      >
        <div class="t4s-{{ class_media }} t4s-col-12 t4s-col-item t4s-product__media-wrapper">
          {%- case media_layout -%}
            {%- when 'no_media_size' -%}
              {%- render 'product-media-no-media',
                se_stts: se_stts,
                se_id: se_id,
                image_ratio: image_ratio,
                imgatt: imgatt,
                class_pswp_disable: class_pswp_disable,
                media_custom_img_enable: media_custom_img_enable,
                media_custom_img: media_custom_img,
                media_heading: media_heading,
                product: product
              -%}

            {%- when 'one_media_size' -%}
              {%- render 'product-media-one-media',
                product_media: product_media,
                se_stts: se_stts,
                se_id: se_id,
                image_ratio: image_ratio,
                imgatt: imgatt,
                variant_images: variant_images,
                enable_video_looping: enable_video_looping,
                enable_video_muting: enable_video_muting,
                enable_video_autoplaying: enable_video_autoplaying,
                height: height,
                class_pswp_disable: class_pswp_disable,
                media_custom_img_enable: media_custom_img_enable,
                media_custom_img: media_custom_img,
                media_heading: media_heading,
                product: product
              -%}

            {%- when 'thumbnails_left', 'thumbnails_bottom', 'thumbnails_right', 'without_thumbnails' -%}
              {%- render 'product-media-thumbnails',
                media_layout: media_layout,
                product_media: product_media,
                se_stts: se_stts,
                se_id: se_id,
                image_ratio: image_ratio,
                imgatt: imgatt,
                variant_images: variant_images,
                enable_video_looping: enable_video_looping,
                enable_video_muting: enable_video_muting,
                enable_video_autoplaying: enable_video_autoplaying,
                height: height,
                isMediaHidden: isMediaHidden,
                current_option1: current_option1,
                current_option2: current_option2,
                current_option3: current_option3,
                ops_name: ops_name,
                ops_name_1: ops_name_1,
                ops_name_2: ops_name_2,
                ops_name_3: ops_name_3,
                class_pswp_disable: class_pswp_disable,
                variants_size: variants_size,
                canMedia_group: canMedia_group,
                has_media_360: has_media_360,
                media_custom_img_enable: media_custom_img_enable,
                media_custom_img: media_custom_img,
                media_heading: media_heading,
                product: product
              -%}

            {%- when 'one_column', 'two_columns', 'combined_grid' -%}
              {%- liquid
                if media_layout == 'one_column'
                  assign class_col = 't4s-col-md-12 '
                  assign row_g = '0'
                elsif media_layout == 'two_columns'
                  assign class_col = 't4s-col-md-6 '
                  assign row_g = '10'
                else
                  assign class_col = 't4s-col-md-12 '
                  assign row_g = '10'
                endif
              -%}

              <div class="t4s-row t4s-g-0" timeline hdt-reveal="slide-in">
                <div data-product-single-media-group class="{{ class_main }}t4s-col-12 t4s-col-item t4s-pr">
                  <div
                    data-media-sizes="{{ product_media.size }}"
                    data-t4s-gallery
                    data-t4s-thumb-true
                    data-main-media
                    class="t4s-row t4s-g-{{ row_g }} t4s-slide-eff-{{ se_stts.eff }} flickityt4s isotopet4s isotopet4s-later carousel-disable-md t4s_{{ image_ratio }} t4s_position_{{ se_stts.image_position }} t4s_{{ se_stts.image_size }}{% if se_stts.nav_btn %} t4s-flicky-slider t4s-slider-btn-{{ se_stts.nav_btn }} t4s-slider-btn-style-{{ se_stts.btn_owl }} t4s-slider-btn-{{ se_stts.btn_shape }} t4s-slider-btn-{{ se_stts.btn_size }} t4s-slider-btn-cl-{{ se_stts.btn_cl }} t4s-slider-btn-vi-{{ se_stts.btn_vi }} t4s-slider-btn-hidden-mobile-{{ se_stts.btn_hidden_mobile }} {% endif %}"
                    data-isotopet4s-js='{"transitionDuration": 0,"itemSelector-":"[data-main-slide]:not(.is--media-hide)","filter": "[data-main-slide]:not(.is--media-hide)", "layoutMode":"packery" }'
                    data-flickityt4s-js='{"cellSelector": "[data-main-slide]:not(.is--media-hide)","isFilter":{{ canMedia_group }},"watchCSS": true,"imagesLoaded": 0,"adaptiveHeight": 1, "contain": 1, "groupCells": "100%", "dragThreshold" : {% if se_stts.eff == 'fade' %}6{% else %}5{% endif %}, "cellAlign": "left","wrapAround": true,"prevNextButtons": {{ se_stts.nav_btn }},"percentPosition": 1,"pageDots": false, "autoPlay" : 0, "pauseAutoPlayOnHover" : true , "t4sid": "{{ se_id }}", "thumbNav": false, "thumbVertical": false, "isMedia": true }'
                  >
                    {%- liquid
                      for media in product_media
                        if media.preview_image and media.preview_image.alt contains 'break--360'
                          break
                        endif
                        render 'product-thumbnail', media: media, imgatt: imgatt, variant_images: variant_images, loop: enable_video_looping, mute: enable_video_muting, autoplay: false, height: height, se_id: se_id, isMediaHidden: isMediaHidden, current_option1: current_option1, current_option2: current_option2, current_option3: current_option3, class_col: class_col, ops_name: ops_name, ops_name_1: ops_name_1, ops_name_2: ops_name_2, ops_name_3: ops_name_3, class_pswp_disable: class_pswp_disable, variants_size: variants_size
                      endfor
                      if has_media_360
                        render 'product-360', product: product, se_id: se_id, class_col: class_col
                      endif
                    -%}
                  </div>
                  <link
                    href="{{ 'single-pr-badge.css' | asset_url }}"
                    rel="stylesheet"
                    media="print"
                    onload="this.media='all'"
                  >
                  <div
                    data-product-single-badge
                    data-sort="sale,new,soldout,preOrder,custom"
                    class="t4s-single-product-badge t4s-pa t4s-pe-none t4s-op-0"
                  ></div>
                  {%- if media_custom_img_enable and media_custom_img != blank -%}
                    <div class="t4s-product-media-custom-img-{{ se_id }}">
                      {{ media_custom_img | image_url: width: 400 | image_tag: loading: 'lazy', class: 't4s-obj-eff' }}
                    </div>
                  {%- endif -%}
                  {%- if media_heading != blank -%}
                    <div class="t4s-product-media-heading-{{ se_id }}">{{ media_heading }}</div>
                  {%- endif -%}
                  {%- render 'product-btns', se_stts: se_stts, product: product -%}
                </div>
              </div>
          {%- endcase -%}

          {%- comment -%} Additional media blocks rendered below the product gallery. {%- endcomment -%}
          <div class="t4s-product__media-blocks">
            {%- for block in seBlocks -%}
              {%- case block.type -%}
                {%- when 'media_below_text' -%}
                  <div class="t4s-product-media-block t4s-product-media-block--text" {{ block.shopify_attributes }}>
                    <div
                      class="t4s-rte"
                      style="margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;"
                    >
                      {{ block.settings.text }}
                    </div>
                  </div>

                {%- when 'media_below_html' -%}
                  <div class="t4s-product-media-block t4s-product-media-block--html" {{ block.shopify_attributes }}>
                    <div
                      class="t4s-rte"
                      style="margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;"
                    >
                      {{ block.settings.page.content }}
                    </div>
                  </div>

                {%- when 'media_below_liquid' -%}
                  <div class="t4s-product-media-block t4s-product-media-block--liquid" {{ block.shopify_attributes }}>
                    <div style="margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;">
                      {{ block.settings.custom_liquid }}
                    </div>
                  </div>

                {%- when 'media_below_liquid_img' -%}
                  {%- render 'product-block-media-below-liquid-image', block: block, bk_stts: block.settings -%}

                {%- when 'media_below_image' -%}
                  {%- liquid
                    assign media_type = block.settings.media_type | default: 'image'
                    assign has_content = false

                    if media_type == 'image' and block.settings.image != blank
                      assign has_content = true
                    elsif media_type == 'video' and block.settings.video_file != blank
                      assign has_content = true
                    endif
                  -%}

                  {%- if has_content -%}
                    {%- if media_type == 'video' -%}
                      {%- comment -%} Video block setup. {%- endcomment -%}
                      {%- liquid
                        assign video_file = block.settings.video_file
                        assign video_url = ''

                        if video_file.sources
                          for source in video_file.sources
                            if source.format == 'mp4' or source.format == 'webm'
                              assign video_url = source.url
                              break
                            endif
                          endfor
                        endif

                        if video_url == blank and video_file != blank
                          assign video_url = video_file
                        endif

                        assign video_poster = block.settings.video_poster
                        assign autoplay = block.settings.autoplay
                        assign loop = block.settings.loop
                        assign muted = block.settings.muted
                        assign controls = block.settings.controls
                        assign alignment = block.settings.alignment
                        assign video_width = block.settings.image_width
                        assign video_height = block.settings.video_height
                        assign video_fit = block.settings.video_fit | default: 'contain'
                        assign margin_top = block.settings.margin_top
                        assign margin_bottom = block.settings.margin_bottom
                        assign hide_on_mobile = block.settings.hide_on_mobile
                        assign border_radius = block.settings.border_radius | default: 0

                        assign block_id = block.id
                        assign video_id = 'video-' | append: block_id
                      -%}

                      <style>
                        #{{ video_id }}-wrapper {
                          margin-top: {{ margin_top }}px;
                          margin-bottom: {{ margin_bottom }}px;
                          text-align: {{ alignment }};
                        }

                        {% if hide_on_mobile %}
                          @media (max-width: 767px) {
                            #{{ video_id }}-wrapper {
                              display: none !important;
                            }
                          }
                        {% endif %}

                        #{{ video_id }}-container {
                          position: relative;
                          display: inline-block;
                          max-width: {{ video_width }}px;
                          width: 100%;
                          {% if video_height > 0 %}
                          height: {{ video_height }}px;
                          {% endif %}
                          border-radius: {{ border_radius }}px;
                          overflow: hidden;
                          background: #000;
                        }

                        #{{ video_id }} {
                          width: 100%;
                          {% if video_height > 0 %}
                          height: {{ video_height }}px;
                          object-fit: {{ video_fit }};
                          {% else %}
                          height: auto;
                          {% endif %}
                          display: block;
                          border-radius: {{ border_radius }}px;
                        }

                        .video-poster-{{ block_id }} {
                          position: absolute;
                          top: 0;
                          left: 0;
                          width: 100%;
                          height: 100%;
                          object-fit: cover;
                          cursor: pointer;
                          transition: opacity 0.3s ease;
                          z-index: 2;
                        }

                        .video-poster-{{ block_id }}.is-hidden {
                          opacity: 0;
                          pointer-events: none;
                        }

                        .video-play-btn-{{ block_id }} {
                          position: absolute;
                          top: 50%;
                          left: 50%;
                          transform: translate(-50%, -50%);
                          width: 80px;
                          height: 80px;
                          background: rgba(255, 255, 255, 0.95);
                          border-radius: 50%;
                          cursor: pointer;
                          display: flex;
                          align-items: center;
                          justify-content: center;
                          transition: all 0.3s ease;
                          z-index: 10;
                          box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
                        }

                        .video-play-btn-{{ block_id }}:hover {
                          transform: translate(-50%, -50%) scale(1.1);
                          background: rgba(255, 255, 255, 1);
                        }

                        .video-play-btn-{{ block_id }}.is-hidden {
                          opacity: 0;
                          pointer-events: none;
                        }

                        .video-play-btn-{{ block_id }}::after {
                          content: '';
                          width: 0;
                          height: 0;
                          border-style: solid;
                          border-width: 15px 0 15px 26px;
                          border-color: transparent transparent transparent #000;
                          margin-left: 4px;
                        }

                        .video-loading-{{ block_id }} {
                          position: absolute;
                          top: 0;
                          left: 0;
                          width: 100%;
                          height: 100%;
                          display: flex;
                          align-items: center;
                          justify-content: center;
                          background: #f5f5f5;
                          z-index: 1;
                        }

                        .video-loading-{{ block_id }}.is-hidden {
                          display: none;
                        }

                        @media (max-width: 767px) {
                          .video-play-btn-{{ block_id }} {
                            width: 60px;
                            height: 60px;
                          }

                          .video-play-btn-{{ block_id }}::after {
                            border-width: 12px 0 12px 20px;
                          }
                        }
                      </style>

                      <div
                        id="{{ video_id }}-wrapper"
                        class="t4s-product-media-block t4s-product-media-block--video{% if hide_on_mobile %} t4s-dn-mb{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        <div id="{{ video_id }}-container">
                          <div class="video-loading-{{ block_id }}" data-video-loading>
                            <svg
                              width="40"
                              height="40"
                              viewBox="0 0 40 40"
                              xmlns="http://www.w3.org/2000/svg"
                              stroke="#999"
                            >
                              <g fill="none" fill-rule="evenodd">
                                <g transform="translate(2 2)" stroke-width="3">
                                  <circle stroke-opacity=".2" cx="18" cy="18" r="18"/>
                                  <path d="M36 18c0-9.94-8.06-18-18-18">
                                    <animateTransform attributeName="transform" type="rotate" from="0 18 18" to="360 18 18" dur="1s" repeatCount="indefinite"/>
                                  </path>
                                </g>
                              </g>
                            </svg>
                          </div>

                          <video
                            id="{{ video_id }}"
                            class="product-media-video"
                            data-video-element
                            preload="metadata"
                            {% if loop %}
                              loop
                            {% endif %}
                            {% if muted %}
                              muted
                            {% endif %}
                            {% if controls %}
                              controls
                            {% endif %}
                            playsinline
                            webkit-playsinline
                            {% if video_poster != blank %}
                              poster="{{ video_poster | image_url: width: video_width }}"
                            {% endif %}
                          >
                            {%- if video_file.sources -%}
                              {%- for source in video_file.sources -%}
                                <source src="{{ source.url }}" type="{{ source.mime_type }}">
                              {%- endfor -%}
                            {%- elsif video_url != blank -%}
                              <source src="{{ video_url }}" type="video/mp4">
                            {%- endif -%}
                            Your browser does not support the video tag.
                          </video>

                          {%- if autoplay == false -%}
                            {%- if video_poster != blank -%}
                              <img
                                class="video-poster-{{ block_id }}"
                                src="{{ video_poster | image_url: width: video_width }}"
                                alt="Video poster"
                                data-video-poster
                              >
                            {%- endif -%}

                            <div class="video-play-btn-{{ block_id }}" data-video-play-btn></div>
                          {%- endif -%}
                        </div>
                      </div>

                      {%- render 'product-media-below-video-script', video_id: video_id, autoplay: autoplay -%}
                    {%- else -%}
                      {%- comment -%} Image block fallback. {%- endcomment -%}
                      <div
                        class="t4s-product-media-block t4s-product-media-block--image{% if block.settings.hide_on_mobile %} t4s-dn-mb{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        <div style="margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px; text-align: {{ block.settings.alignment }};">
                          {%- if block.settings.link != blank -%}
                            <a href="{{ block.settings.link }}">
                          {%- endif -%}
                          {{
                            block.settings.image
                            | image_url: width: block.settings.image_width
                            | image_tag: loading: 'lazy', style: 'max-width: 100%; height: auto;'
                          }}
                          {%- if block.settings.link != blank -%}
                            </a>
                          {%- endif -%}
                        </div>
                      </div>
                    {%- endif -%}
                  {%- endif -%}
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
        <div data-t4s-zoom-info class="t4s-{{ class_info }} t4s-col-12 t4s-col-item t4s-product__info-wrapper t4s-pr">
          <div id="product-zoom-{{ section.id }}" class="t4s-product__zoom-wrapper"></div>
          <div
            id="ProductInfo-template--{{ se_id }}__main"
            class="t4s-product__info-container{% if se_stts.enable_sticky_info %} t4s-product__info-container--sticky{% endif %}"
            style="display: flex; flex-direction: column;"
            timeline
            hdt-reveal="slide-in"
          >
            {%- liquid
              assign customization_group_title_block = blank
              assign customization_group_use_accordion = customization_group_enable
              assign customization_group_heading = 'Design Service'
              assign customization_group_heading_color = se_stts.customization_group_text_color
              assign customization_group_heading_size = 28
              assign customization_group_heading_weight = 600
              assign customization_group_heading_size_mobile = customization_group_heading_size
              assign customization_group_heading_weight_mobile = customization_group_heading_weight

              if customization_group_enable
                assign customization_group_title_block = seBlocks | where: 'type', 'redirect_bottom_title' | first
                if customization_group_title_block != blank
                  assign customization_group_heading = customization_group_title_block.settings.bottom_title | strip
                  assign customization_group_heading_color = customization_group_title_block.settings.title_color | default: se_stts.customization_group_text_color
                  assign customization_group_heading_size = customization_group_title_block.settings.title_font_size | default: 28
                  assign customization_group_heading_weight = customization_group_title_block.settings.title_font_weight | default: 600
                  assign customization_group_heading_size_mobile = customization_group_title_block.settings.title_font_size_mobile | default: customization_group_heading_size
                  assign customization_group_heading_weight_mobile = customization_group_title_block.settings.title_font_weight_mobile | default: customization_group_heading_weight
                  if customization_group_heading == blank
                    assign customization_group_heading = 'Design Service'
                  endif
                elsif block_custom_redirect != blank
                  if block_custom_redirect.settings.show_custom_redirect_bottom_title
                    assign customization_group_heading = block_custom_redirect.settings.custom_redirect_bottom_title | strip
                    assign customization_group_heading_color = block_custom_redirect.settings.custom_redirect_title_color | default: se_stts.customization_group_text_color
                    assign customization_group_heading_size = block_custom_redirect.settings.custom_redirect_title_font_size | default: 28
                    assign customization_group_heading_weight = block_custom_redirect.settings.custom_redirect_title_font_weight | default: 600
                    if customization_group_heading == blank
                      assign customization_group_heading = 'Design Service'
                    endif
                  endif
                endif

                if se_stts.customization_group_heading_font_size > 0
                  assign customization_group_heading_size = se_stts.customization_group_heading_font_size
                endif
              endif
            -%}
            {%- render 'product-main-group-assets',
              se_id: se_id,
              se_stts: se_stts,
              featured_info_group_enable: featured_info_group_enable,
              customization_group_enable: customization_group_enable,
              customization_group_heading_color: customization_group_heading_color,
              customization_group_heading_size: customization_group_heading_size,
              customization_group_heading_weight: customization_group_heading_weight,
              customization_group_heading_size_mobile: customization_group_heading_size_mobile,
              customization_group_heading_weight_mobile: customization_group_heading_weight_mobile,
              customization_group_use_accordion: customization_group_use_accordion
            -%}
            {%- assign featured_info_group_open = false -%}
            {%- assign customization_group_open = false -%}
            {%- for block in seBlocks -%}
              {%- assign bk_stts = block.settings -%}
              {%- assign bk_id = block.id -%}
              {%- liquid
                assign current_is_featured_info_block = false
                assign current_is_customization_group_block = false
                if featured_info_group_enable and customization_group_use_accordion == false
                  case block.type
                    when 'image_text_upload'
                      assign current_is_featured_info_block = true
                    when 'viewed_today_notice'
                      if bk_stts.text != blank
                        assign current_is_featured_info_block = true
                      endif
                    when 'custom_redirect_button'
                      if request.design_mode or bk_stts.custom_redirect_product != blank
                        assign current_is_featured_info_block = true
                      endif
                    when '@app'
                      if block.type contains 'kaching-bundles' or block.type contains '6c637362-a106-4a32-94ac-94dcfd68cdb8'
                        assign current_is_featured_info_block = false
                      elsif block.type contains 'kickflip-customizer' or block.type contains '852f7399-e025-496f-91ce-94176f54ae8c'
                        assign current_is_featured_info_block = false
                      endif
                  endcase
                endif
                if customization_group_enable
                  case block.type
                    when 'form', 'custom_image_upload', 'steps_image', 'steps', 'bundle_selector', 'option_selector', 'viewed_today_notice'
                      assign current_is_customization_group_block = true
                    when '@app'
                      if block.id contains 'kaching' or block.type contains 'kaching-bundles' or block.type contains '6c637362-a106-4a32-94ac-94dcfd68cdb8'
                        assign current_is_customization_group_block = true
                      endif
                  endcase
                endif
              -%}
              {%- if current_is_featured_info_block == false and featured_info_group_open -%}
                </div>
                {%- assign featured_info_group_open = false -%}
              {%- endif -%}
              {%- if current_is_featured_info_block and featured_info_group_open == false -%}
                <div class="t4s-product__featured-info-group t4s-product__featured-info-group--{{ se_id }}">
                  {%- assign featured_info_group_open = true -%}
              {%- endif -%}
              {%- if current_is_customization_group_block == false and customization_group_open -%}
                {%- if customization_group_use_accordion -%}
                    </div>
                  </details>
                {%- else -%}
                  </div>
                {%- endif -%}
                {%- assign customization_group_open = false -%}
              {%- endif -%}
              {%- if current_is_customization_group_block and customization_group_open == false -%}
                {%- if customization_group_use_accordion -%}
                  <details
                    class="t4s-product__customization-group t4s-product__customization-group--{{ se_id }} is-accordion-group"
                    data-customization-accordion="{{ se_id }}"
                  >
                    <summary class="t4s-product__customization-group-summary--{{ se_id }}">
                      <span class="t4s-product__customization-group-summary-main--{{ se_id }}{% if se_stts.customization_group_summary_alignment == 'center' %} is-center{% endif %}">
                        <span class="t4s-product__customization-group-summary-text--{{ se_id }}">
                          {{ customization_group_heading }}
                        </span>
                        <span class="t4s-product__customization-group-summary-icon--{{ se_id }}" aria-hidden="true">
                          <svg viewBox="0 0 20 20" width="20" height="20" fill="none">
                            <path d="M5 8L10 13L15 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                          </svg>
                        </span>
                      </span>
                      {%- if se_stts.customization_group_show_collapsed_note and se_stts.customization_group_collapsed_note != blank -%}
                        <span class="t4s-product__customization-group-collapsed-note--{{ se_id }}">
                          <span class="t4s-product__customization-group-collapsed-note-line--{{ se_id }}" aria-hidden="true"></span>
                          <span class="t4s-product__customization-group-collapsed-note-text--{{ se_id }}">
                            {{ se_stts.customization_group_collapsed_note | escape | newline_to_br }}
                          </span>
                          <span class="t4s-product__customization-group-collapsed-note-line--{{ se_id }}" aria-hidden="true"></span>
                        </span>
                      {%- endif -%}
                    </summary>
                    <div class="t4s-product__customization-group-content--{{ se_id }}">
                {%- else -%}
                  <div class="t4s-product__customization-group t4s-product__customization-group--{{ se_id }}">
                {%- endif -%}
                  {%- assign customization_group_open = true -%}
              {%- endif -%}
              {%- case block.type -%}
                {%- when 'properties' %}
                  {% continue -%}
                {%- when 'title' -%}
                  {% liquid
                    if bk_stts.lh_pr == 0
                      assign lh_pr = 1
                    else
                      assign lh_pr = bk_stts.lh_pr | append: 'px'
                    endif
                    assign size_pr_mb = bk_stts.size_pr_mb | default: bk_stts.size_pr
                    assign fw_pr_mb = bk_stts.fw_pr_mb | default: bk_stts.fw_pr
                  %}
                  <style>
                    .t4s-product__title {
                      --title-size: {{ bk_stts.size_pr }}px;
                      --title-weight: {{ bk_stts.fw_pr }};
                    }
                    @media (max-width: 767px) {
                      .t4s-product__title {
                        --title-size: {{ size_pr_mb }}px;
                        --title-weight: {{ fw_pr_mb }};
                      }
                    }
                  </style>
                  <div
                    class="t4s-product__title-wrapper"
                    style="display: flex; align-items: center; flex-wrap: wrap; gap: 12px;"
                  >
                    <h1
                      class="t4s-product__title"
                      style="--title-family:var(--font-family-{{ bk_stts.fnt_df_pr }});--title-style:{{ bk_stts.txt_tr_pr }};--title-line-height:{{ lh_pr }};--title-spacing:{{ bk_stts.ls_pr }}px;--title-color:{{ bk_stts.pr_title_color }};--title-color-hover:{{ bk_stts.pr_title_color }}; margin: 0; font-size: var(--title-size); font-weight: var(--title-weight);"
                      {{ block.shopify_attributes }}
                    >
                      {{ product.title }}
                    </h1>
                    {%- if bk_stts.show_free_shipping -%}
                      <span
                        class="t4s-free-shipping-tag"
                        style="display: inline-block; background-color: {{ bk_stts.free_shipping_bg_color }}; color: {{ bk_stts.free_shipping_text_color }}; border:1px solid {{ bk_stts.free_shipping_border_color }};padding: 4px 12px; border-radius: 4px; font-size: 14px; font-weight: 500; white-space: nowrap;"
                      >
                        {{ bk_stts.free_shipping_text }}
                      </span>
                    {%- endif -%}
                  </div>
                  {% comment %} data-bf-price-container {% endcomment %}
                {%- when 'price_review' -%}
                  {%- liquid
                    assign size_price_pr_mb = bk_stts.size_price_pr_mb | default: bk_stts.size_price_pr
                    assign fw_price_pr_mb = bk_stts.fw_price_pr_mb | default: bk_stts.fw_price_pr
                  -%}
                  <style>
                    .t4s-product__price-review--{{ bk_id }} .t4s-product__review-row {
                      margin-top: 12px;
                    }

                    .t4s-product__price-review--{{ bk_id }} .t4s-product__review-row.is-inline-viewed-notice {
                      display: flex;
                      align-items: center;
                      justify-content: space-between;
                      gap: 16px;
                      flex-wrap: wrap;
                    }

                    .t4s-product__price-review--{{ bk_id }} .t4s-product__review-row.is-inline-viewed-notice .t4s-pr_viewed_today_notice {
                      margin-top: 0;
                      margin-left: auto;
                    }

                    @media (max-width: 767px) {
                      .t4s-product__price-review--{{ bk_id }} {
                        --price-size: {{ size_price_pr_mb }}px !important;
                        --price-weight: {{ fw_price_pr_mb }} !important;
                        margin-top: {{ bk_stts.block_margin_top_mb | default: 0 }}px !important;
                        margin-bottom: {{ bk_stts.block_margin_bottom_mb | default: 16 }}px !important;
                      }

                      .t4s-product__price-review--{{ bk_id }} .t4s-product-price {
                        --price-size: {{ size_price_pr_mb }}px !important;
                        --price-weight: {{ fw_price_pr_mb }} !important;
                      }

                      .t4s-product__price-review--{{ bk_id }} .t4s-product__review-row.is-inline-viewed-notice {
                        gap: 10px;
                      }
                    }
                  </style>
                  <div
                    id="t4s-price-review-{{ bk_id }}"
                    class="t4s-product__price-review t4s-product__price-review--{{ bk_id }}"
                    style="--price-size: {{ bk_stts.size_price_pr }}px; --price-weight: {{ bk_stts.fw_price_pr }}; --price-color:{{ bk_stts.price_color }}; --price-compare-color:{{ bk_stts.price_compare_color | default: bk_stts.price_color }}; --price-sale-color:{{ bk_stts.price_sale_color }}; margin-top: {{ bk_stts.block_margin_top | default: 0 }}px; margin-bottom: {{ bk_stts.block_margin_bottom | default: 16 }}px;"
                    {{ block.shopify_attributes }}
                  >
                    {%- comment -%} Price {%- endcomment -%}
                    <div>
                      <!-- Original price display -->
                      <div id="t4s-price-review-target-{{ bk_id }}" data-bf-original-price data-bundle-price-review-target>
                        {%- render 'product-price-single',
                          variant: current_variant,
                          product: product,
                          PR_no_pick: PR_no_pick,
                          type_sale: bk_stts.type_sale,
                          price_varies_style: bk_stts.price,
                          hide_compare_price: bk_stts.hide_compare_price,
                          show_currency_code: bk_stts.show_currency_code
                        -%}
                      </div>

                      <!-- Discounted Black Friday price display -->
                      {% comment %}
                        <div data-bf-discount-price class="t4s-product-price" style="display: none;">
                          {%- liquid
                            if variant.title and bk_stts.price == '0'
                              assign bf_price = variant.price
                            else
                              assign bf_price = product.price
                            endif

                            assign bf_discount_percent = 20
                            assign bf_discount_price = bf_price | times: 0.8 | round

                            if settings.currency_code_enabled
                              assign bf_original_money = bf_price | money_with_currency
                              assign bf_discount_money = bf_discount_price | money_with_currency
                            else
                              assign bf_original_money = bf_price | money
                              assign bf_discount_money = bf_discount_price | money
                            endif
                          -%}
                          <span style="text-decoration: line-through; color: var(--price-compare-color, var(--price-color));">
                            {{- bf_original_money -}}
                          </span>
                          <span style="color: var(--price-sale-color); margin-left: 6px; font-weight: var(--price-weight);">
                            {{- bf_discount_money -}}
                          </span>
                        </div>
                      {% endcomment %}

                      <script>
                        (function () {
                          try {
                            var isDiscountApplied = localStorage.getItem('bf_discount_applied');

                            var container = document.currentScript.closest('[data-bf-price-container]');

                            if (container) {
                              var originalPrice = container.querySelector('[data-bf-original-price]');
                              var discountPrice = container.querySelector('[data-bf-discount-price]');

                              if (isDiscountApplied === 'true') {
                                if (originalPrice) originalPrice.style.display = 'none';
                                if (discountPrice) discountPrice.style.display = 'block';
                              } else {
                                if (originalPrice) originalPrice.style.display = 'block';
                                if (discountPrice) discountPrice.style.display = 'none';
                              }
                            }
                          } catch (e) {}
                        })();
                      </script>
                    </div>

                    {%- comment -%} Star Rating {%- endcomment -%}
                    {%- if bk_stts.rating -%}
                      {%- assign pid = product.id -%}
                      <div class="t4s-product__review-row{% if inline_viewed_today_notice %} is-inline-viewed-notice{% endif %}">
                        <a
                          href="#{{ idTabReview }}"
                          data-go-id="#{{ idTabReview }}"
                          class="t4s-product__review t4s-d-inline-block"
                        >
                          {%- case settings.app_review -%}
                            {%- when '1' -%}
                              <span class="shopify-product-reviews-badge" data-id="{{ pid }}"></span>
                            {%- when '2' -%}
                              <div class="review-widget">
                                <ryviu-widget-total
                                  reviews_data="{{ pr_metafields.ryviu.product_reviews_info | escape }}"
                                  product_id="{{ pid }}"
                                  handle="{{ product.handle }}"
                                ></ryviu-widget-total>
                              </div>
                            {%- when '3' -%}
                              <div product-id="{{ pid }}" class="alr-display-review-badge"></div>
                            {%- when '4' -%}
                              <div
                                class="loox-rating"
                                data-id="{{ pid }}"
                                data-rating="{{ pr_metafields.loox.avg_rating }}"
                                data-raters="{{ pr_metafields.loox.num_reviews }}"
                              ></div>
                            {%- when '5' -%}
                              {%- capture the_snippet_review_avg %}{% render 'ssw-widget-avg-rate-profile' %}{% endcapture -%}
                              {%- unless the_snippet_review_avg contains 'Liquid error' -%}
                                {{- the_snippet_review_avg -}}
                              {%- endunless -%}
                            {%- when '7' -%}
                              <!-- Start of Judge.me code -->
                              <div
                                style="{{ jm_style }}"
                                class="jdgm-widget jdgm-preview-badge"
                                data-id="{{ product.id }}"
                                style="pointer-events: none;"
                              >
                                {{- product.metafields.judgeme.badge -}}
                              </div>
                              <!-- End of Judge.me code -->
                            {%- when '8' -%}
                              <div
                                id="scm-product-detail-rate"
                                class="scm-reviews-rate"
                                data-rate-version2="{{ product.metafields.scm_review_importer.reviewsData.reviewCountInfo | json }}"
                                data-product-id="{{ product.id }}"
                              ></div>
                            {%- else -%}
                              <div class="t4s-pr_rating t4s-review_pr_other">{{ bk_stts.review_liquid }}</div>
                          {%- endcase -%}
                        </a>
                        {%- if inline_viewed_today_notice -%}
                          {%- render 'product-block-viewed-today-notice',
                            block: Block_viewed_today_notice,
                            bk_stts: block_viewed_today_notice_stts,
                            instance_suffix: '-rating-copy',
                            in_review_row: true
                          -%}
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </div>

                  {%- render 'product-price-review-sync-script',
                    block_id: bk_id,
                    section_id: se_id,
                    current_variant: current_variant,
                    product: product,
                    sale_type: bk_stts.type_sale,
                    hide_compare_price: bk_stts.hide_compare_price,
                    show_currency_code: bk_stts.show_currency_code
                  -%}

                  {%- comment -%} Product Personalizer CSS variables. {%- endcomment -%}
                  <style>
                    /* Product Personalizer upload button design tokens. */
                    :root {
                      --pplr-upload-btn-bg: {{ section.settings.pplr_upload_btn_bg_color | default: 'transparent' }};
                      --pplr-upload-btn-text: {{ section.settings.pplr_upload_btn_text_color | default: '#1976d2' }};
                      --pplr-upload-btn-border: {{ section.settings.pplr_upload_btn_border_color | default: 'rgba(25, 118, 210, 0.5)' }};
                      --pplr-upload-btn-bg-hover: {{ section.settings.pplr_upload_btn_bg_hover_color | default: 'rgba(25, 118, 210, 0.04)' }};
                    }
                  </style>

                  {%- if bk_stts.tax_ship and cart.taxes_included or shop.shipping_policy.body != blank -%}
                    <div class="t4s-product__policies t4s-rte" data-product-policies>
                      {%- if cart.taxes_included -%}
                        {{ 'products.product.include_taxes' | t }}
                      {%- endif -%}
                      {%- if shop.shipping_policy.body != blank -%}
                        {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                      {%- endif -%}
                    </div>
                  {%- endif -%}

                {%- when 'description' -%}
                  {%- liquid
                    assign product = section.settings.product | default: product
                    assign description_excerpt = block.settings.text | default: product.description
                    if description_excerpt == blank
                      continue
                    endif
                  -%}
                  <style>
                    t4s-product-description {
                      padding-bottom: 10px;
                    }
                    t4s-product-description.is--less .t4s-rl-text {
                      display: block;
                    }
                    t4s-product-description.is--less .t4s-rm-text {
                      display: none;
                    }
                    t4s-product-description .t4s-product__description::after {
                      position: absolute;
                      content: '';
                      left: 0;
                      right: 0;
                      bottom: 0;
                      height: 20px;
                      background: linear-gradient(to top, rgba(255, 255, 255, 0.5) 60%, transparent 100%);
                      transition: 0.3s linear;
                      pointer-events: none;
                    }
                    t4s-product-description.is--less .t4s-product__description::after {
                      opacity: 0;
                    }
                    t4s-product-description [data-lm-content] {
                      max-height: var(--m-h);
                      overflow: hidden;
                      transition: 0.3s linear;
                    }
                    t4s-product-description button.is--show {
                      display: block;
                    }
                    t4s-product-description .t4s-hidden {
                      display: none;
                    }
                    t4s-product-description button {
                      position: absolute;
                      left: 50%;
                      right: 0;
                      bottom: 0;
                      transform: translateX(-50%) translateY(50%);
                      width: fit-content;
                    }
                  </style>
                  {%- if product.description != blank and block.settings.des == '1' -%}
                    <div class="t4s-product-info__item t4s-product__description">
                      <div class="t4s-rte">
                        {{ product.description }}
                      </div>
                    </div>
                  {%- elsif description_excerpt != blank -%}
                    {%- if block.settings.readm == false -%}
                      <div class="t4s-product-info__item t4s-product__description">
                        <div class="t4s-rte">
                          {{ description_excerpt }}
                        </div>
                      </div>
                    {%- else -%}
                      <t4s-product-description
                        class="t4s-d-block t4s-product-description t4s-pr"
                        data-type="{{ block.type }}"
                        data-height="{{ block.settings.length | json }}"
                        {{ block.shopify_attributes }}
                      >
                        <div class="t4s-product-info__item t4s-product__description t4s-pr">
                          <div
                            class="t4s-rte t4s-full-des"
                            data-lm-content
                            style="--m-h: {{ block.settings.length }}px;"
                          >
                            {{ description_excerpt }}
                          </div>
                        </div>
                        <button class="t4s-product__description_readm t4s-pr-des-rm t4s-hidden">
                          <span class="t4s-rm-text">{{ block.settings.readm_txt }}</span>
                          <span class="t4s-rl-text t4s-hidden">{{ block.settings.readl_txt }}</span>
                        </button>
                      </t4s-product-description>
                    {%- endif -%}
                  {%- endif -%}
                  <script>
                    if (!customElements.get('t4s-product-description')) {
                      class ProductDescription extends HTMLElement {
                        constructor() {
                          super();
                          this.lm_btn = this.querySelector('.t4s-pr-des-rm');
                          this.content = this.querySelector('[data-lm-content]');
                          this.m_h_content = parseInt(this.getAttribute('data-height'));

                          if (!this.lm_btn || !this.content || this.m_h_content < 0) return;
                          setTimeout(() => {
                            this.lm_btn.classList.toggle(
                              'is--show',
                              parseInt(this.content.scrollHeight) > this.m_h_content
                            );
                          }, 500);
                          this.lm_btn.addEventListener('click', () => {
                            this.classList.contains('is--less')
                              ? this.content.style.setProperty('--m-h', `${this.m_h_content}px`)
                              : this.content.style.setProperty('--m-h', `${this.content.scrollHeight}px`);
                            this.classList.toggle('is--less');
                          });
                        }
                      }
                      customElements.define('t4s-product-description', ProductDescription);
                    }
                  </script>

                {%- when 'option_selector' -%}
                  {%- comment -%} Independent non-color option selector block. {%- endcomment -%}
                  {%- if isProductDefault == false -%}
                    {%- liquid
                      assign stt_color_ck = settings.color_ck | default: ';'
                      assign color_ck = stt_color_ck | append: ',color,colors,couleur,colour' | remove: ';,'
                      assign get_color = color_ck | downcase | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
                      assign choose_an_option = 'products.product.choose_an_option' | t
                    -%}

                    {%- render 'product-option-selector',
                      block: block,
                      bk_stts: bk_stts,
                      product: product,
                      current_variant: current_variant,
                      pr_se_id: pr_se_id,
                      isProductDefault: isProductDefault,
                      form_stts: block_form.settings,
                      option_name_filter: bk_stts.option_name_filter,
                      get_color: get_color,
                      choose_an_option: choose_an_option,
                      name_sizeg: name_sizeg,
                      html_sizeg: html_sizeg
                    -%}
                  {%- endif -%}

                {%- when 'color_selector' -%}
                  {%- comment -%} Color selector block. {%- endcomment -%}
                  {%- if isProductDefault == false -%}
                    {%- liquid
                      assign stt_color_ck = settings.color_ck | default: ';'
                      assign color_ck = stt_color_ck | append: ',color,colors,couleur,colour' | remove: ';,'
                      assign get_color = color_ck | downcase | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
                      assign choose_an_option = 'products.product.choose_an_option' | t
                    -%}

                    <style>
                      .t4s-color-selector-block-{{ block.id }} {
                        margin-top: {{ bk_stts.margin_top | default: 16 }}px !important;
                        margin-bottom: {{ bk_stts.margin_bottom | default: 16 }}px !important;
                      }

                      .t4s-color-selector-block-{{ block.id }} .t4s-swatch__title,
                      .t4s-color-selector-block-{{ block.id }} .t4s-swatch__title span,
                      .t4s-color-selector-block-{{ block.id }} .t4s-swatch__title a,
                      .t4s-color-selector-block-{{ block.id }} .t4s-swatch__current,
                      .t4s-color-selector-block-{{ block.id }} .t4s-dropdown__title,
                      .t4s-color-selector-block-{{ block.id }} .t4s-dropdown__title span {
                        color: {{ bk_stts.title_color | default: '#000000' }} !important;
                        font-size: {{ bk_stts.title_font_size | default: 14 }}px !important;
                        font-weight: {{ bk_stts.title_font_weight | default: 400 }} !important;
                      }

                      @media (max-width: 767px) {
                        .t4s-color-selector-block-{{ block.id }} .t4s-swatch__title,
                        .t4s-color-selector-block-{{ block.id }} .t4s-swatch__title span,
                        .t4s-color-selector-block-{{ block.id }} .t4s-swatch__title a,
                        .t4s-color-selector-block-{{ block.id }} .t4s-swatch__current,
                        .t4s-color-selector-block-{{ block.id }} .t4s-dropdown__title,
                        .t4s-color-selector-block-{{ block.id }} .t4s-dropdown__title span {
                          font-size: {{ bk_stts.title_font_size_mobile | default: bk_stts.title_font_size | default: 14 }}px !important;
                          font-weight: {{ bk_stts.title_font_weight_mobile | default: bk_stts.title_font_weight | default: 400 }} !important;
                        }
                      }
                    </style>

                    <div
                      class="t4s-color-selector-block t4s-color-selector-block-{{ block.id }}"
                      {{ block.shopify_attributes }}
                    >
                      {%- render 'product-color-selector',
                        product: product,
                        current_variant: current_variant,
                        pr_se_id: pr_se_id,
                        bk_stts: bk_stts,
                        isProductDefault: isProductDefault,
                        get_color: get_color,
                        choose_an_option: choose_an_option,
                        name_sizeg: name_sizeg,
                        html_sizeg: html_sizeg,
                        show_tooltip: show_tooltip
                      -%}
                    </div>
                  {%- endif -%}

                {%- when 'color_selector_right' -%}
                  {%- comment -%} Right-title color selector block. {%- endcomment -%}
                  {%- if isProductDefault == false -%}
                    {%- liquid
                      assign stt_color_ck = settings.color_ck | default: ';'
                      assign color_ck = stt_color_ck | append: ',color,colors,couleur,colour' | remove: ';,'
                      assign get_color = color_ck | downcase | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
                      assign choose_an_option = 'products.product.choose_an_option' | t
                    -%}

                    <style>
                      .t4s-color-selector-right-block-{{ block.id }} {
                        margin-top: {{ bk_stts.margin_top | default: 16 }}px !important;
                        margin-bottom: {{ bk_stts.margin_bottom | default: 16 }}px !important;
                      }

                      .t4s-color-selector-right-block-{{ block.id }} .t4s-swatch__title,
                      .t4s-color-selector-right-block-{{ block.id }} .t4s-swatch__title span,
                      .t4s-color-selector-right-block-{{ block.id }} .t4s-swatch__title a,
                      .t4s-color-selector-right-block-{{ block.id }} .t4s-swatch__current,
                      .t4s-color-selector-right-block-{{ block.id }} .t4s-dropdown__title,
                      .t4s-color-selector-right-block-{{ block.id }} .t4s-dropdown__title span {
                        color: {{ bk_stts.title_color | default: '#000000' }} !important;
                        font-size: {{ bk_stts.title_font_size | default: 14 }}px !important;
                        font-weight: {{ bk_stts.title_font_weight | default: 400 }} !important;
                      }

                      @media (max-width: 767px) {
                        .t4s-color-selector-right-block-{{ block.id }} .t4s-swatch__title,
                        .t4s-color-selector-right-block-{{ block.id }} .t4s-swatch__title span,
                        .t4s-color-selector-right-block-{{ block.id }} .t4s-swatch__title a,
                        .t4s-color-selector-right-block-{{ block.id }} .t4s-swatch__current,
                        .t4s-color-selector-right-block-{{ block.id }} .t4s-dropdown__title,
                        .t4s-color-selector-right-block-{{ block.id }} .t4s-dropdown__title span {
                          font-size: {{ bk_stts.title_font_size_mobile | default: bk_stts.title_font_size | default: 14 }}px !important;
                          font-weight: {{ bk_stts.title_font_weight_mobile | default: bk_stts.title_font_weight | default: 400 }} !important;
                        }
                      }
                    </style>

                    <div
                      class="t4s-color-selector-right-block t4s-color-selector-right-block-{{ block.id }}"
                      {{ block.shopify_attributes }}
                    >
                      {%- render 'product-color-selector-main-product',
                        product: product,
                        current_variant: current_variant,
                        pr_se_id: pr_se_id,
