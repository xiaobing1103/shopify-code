{%- liquid
  assign se_stts = section.settings
  assign testimonial_blocks = section.blocks | where: 'type', 'testimonial'
  assign loading_attribute = 'eager'

  if se_stts.lazy_load
    assign loading_attribute = 'lazy'
  endif

  assign mobile_card_width = se_stts.mobile_card_width | default: 86
  assign dot_active_color = se_stts.dot_active_color | default: '#000000'
  assign dot_color = se_stts.dot_color | default: '#d9dde3'
  assign dot_size = se_stts.dot_size | default: 9
  assign dot_active_width = se_stts.dot_active_width | default: 28
  assign dot_gap = se_stts.dot_gap | default: 10
  assign dots_margin_top_mobile = se_stts.dots_margin_top_mobile | default: 26
  assign dots_margin_bottom_mobile = se_stts.dots_margin_bottom_mobile | default: 0
-%}

{%- style -%}
  .smart-team-testimonials-{{ section.id }} {
    margin-top: {{ se_stts.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ se_stts.margin_bottom | times: 0.75 | round: 0 }}px;
    background: {{ se_stts.background_color }};
    color: {{ se_stts.text_color }};
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__inner {
    width: min(100% - {{ se_stts.padding_horizontal_mobile | times: 2 }}px, {{ se_stts.content_width }}px);
    margin: 0 auto;
    padding-top: {{ se_stts.padding_top_mobile }}px;
    padding-bottom: {{ se_stts.padding_bottom_mobile }}px;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__header {
    max-width: {{ se_stts.header_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__heading {
    margin: {{ se_stts.heading_margin_top_mobile }}px 0 {{ se_stts.heading_margin_bottom_mobile }}px;
    color: {{ se_stts.heading_color }};
    font-size: {{ se_stts.heading_size_mobile }}px;
    line-height: {{ se_stts.heading_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.heading_weight }};
    letter-spacing: {{ se_stts.heading_letter_spacing }}px;
    text-transform: none;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__intro {
    margin: {{ se_stts.intro_margin_top_mobile }}px auto {{ se_stts.intro_margin_bottom_mobile }}px;
    max-width: {{ se_stts.intro_width }}px;
    color: {{ se_stts.intro_color }};
    font-size: {{ se_stts.intro_size_mobile }}px;
    line-height: {{ se_stts.intro_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.intro_weight }};
    letter-spacing: {{ se_stts.intro_letter_spacing }}px;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__grid {
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-padding-inline: 0;
    -webkit-overflow-scrolling: touch;
    gap: {{ se_stts.card_gap_mobile }}px;
    margin-top: {{ se_stts.cards_margin_top_mobile }}px;
    margin-bottom: {{ se_stts.cards_margin_bottom_mobile }}px;
    padding-bottom: 4px;
    scrollbar-width: none;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__grid::-webkit-scrollbar {
    display: none;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__card {
    flex: 0 0 {{ mobile_card_width }}%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    padding: {{ se_stts.card_padding_vertical_mobile }}px {{ se_stts.card_padding_horizontal_mobile }}px;
    border: {{ se_stts.card_border_thickness }}px solid {{ se_stts.card_border_color }};
    border-radius: {{ se_stts.card_radius }}px;
    background: {{ se_stts.card_background_color }};
    text-align: {{ se_stts.card_text_align }};
    min-height: {{ se_stts.card_min_height_mobile }}px;
    box-sizing: border-box;
    box-shadow: 0 6px 18px rgba(17, 24, 39, 0.08);
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ dot_gap }}px;
    margin: {{ dots_margin_top_mobile }}px 0 {{ dots_margin_bottom_mobile }}px;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__dot {
    display: block;
    width: {{ dot_size }}px;
    height: {{ dot_size }}px;
    min-width: 0;
    min-height: 0;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: {{ dot_color }};
    appearance: none;
    cursor: pointer;
    font-size: 0;
    line-height: 0;
    transition: width 180ms ease, background-color 180ms ease;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__dot[aria-current="true"] {
    width: {{ dot_active_width }}px;
    background: {{ dot_active_color }};
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__dot:focus-visible {
    outline: 2px solid {{ dot_active_color }};
    outline-offset: 3px;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__author {
    display: flex;
    align-items: center;
    gap: {{ se_stts.author_gap }}px;
    justify-content: {% if se_stts.card_text_align == 'center' %}center{% elsif se_stts.card_text_align == 'right' %}flex-end{% else %}flex-start{% endif %};
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__avatar {
    width: {{ se_stts.avatar_size_mobile }}px;
    height: {{ se_stts.avatar_size_mobile }}px;
    margin: {{ se_stts.avatar_margin_top_mobile }}px 0 {{ se_stts.avatar_margin_bottom_mobile }}px;
    border-radius: {{ se_stts.avatar_radius }}%;
    overflow: hidden;
    flex: 0 0 auto;
    background: {{ se_stts.avatar_background_color }};
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__avatar img,
  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__avatar svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__avatar svg {
    background: {{ se_stts.avatar_background_color }};
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__name {
    margin: {{ se_stts.name_margin_top_mobile }}px 0 {{ se_stts.name_margin_bottom_mobile }}px;
    color: {{ se_stts.name_color }};
    font-size: {{ se_stts.name_size_mobile }}px;
    line-height: {{ se_stts.name_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.name_weight }};
    letter-spacing: {{ se_stts.name_letter_spacing }}px;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__company {
    margin: {{ se_stts.company_margin_top_mobile }}px 0 {{ se_stts.company_margin_bottom_mobile }}px;
    color: {{ se_stts.company_color }};
    font-size: {{ se_stts.company_size_mobile }}px;
    line-height: {{ se_stts.company_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.company_weight }};
    letter-spacing: {{ se_stts.company_letter_spacing }}px;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__stars {
    display: inline-flex;
    align-items: center;
    gap: {{ se_stts.rating_gap }}px;
    margin: {{ se_stts.rating_margin_top_mobile }}px 0 {{ se_stts.rating_margin_bottom_mobile }}px;
    color: {{ se_stts.rating_color }};
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__star {
    width: {{ se_stts.rating_size_mobile }}px;
    height: {{ se_stts.rating_size_mobile }}px;
    color: {{ se_stts.rating_empty_color }};
    flex: 0 0 auto;
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__star--active {
    color: {{ se_stts.rating_color }};
  }

  .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__quote {
    margin: {{ se_stts.quote_margin_top_mobile }}px 0 {{ se_stts.quote_margin_bottom_mobile }}px;
    color: {{ se_stts.quote_color }};
    font-size: {{ se_stts.quote_size_mobile }}px;
    line-height: {{ se_stts.quote_line_height | divided_by: 100.0 }};
    font-weight: {{ se_stts.quote_weight }};
    letter-spacing: {{ se_stts.quote_letter_spacing }}px;
  }

  @media (min-width: 768px) {
    .smart-team-testimonials-{{ section.id }} {
      margin-top: {{ se_stts.margin_top }}px;
      margin-bottom: {{ se_stts.margin_bottom }}px;
    }

    .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__inner {
      width: min(100% - {{ se_stts.padding_horizontal | times: 2 }}px, {{ se_stts.content_width }}px);
      padding-top: {{ se_stts.padding_top }}px;
      padding-bottom: {{ se_stts.padding_bottom }}px;
    }

    .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__heading {
      margin-top: {{ se_stts.heading_margin_top }}px;
      margin-bottom: {{ se_stts.heading_margin_bottom }}px;
      font-size: {{ se_stts.heading_size }}px;
    }

    .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__intro {
      margin-top: {{ se_stts.intro_margin_top }}px;
      margin-bottom: {{ se_stts.intro_margin_bottom }}px;
      font-size: {{ se_stts.intro_size }}px;
    }

    .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__grid {
      display: grid;
      overflow: visible;
      scroll-snap-type: none;
      grid-template-columns: repeat({{ se_stts.columns }}, minmax(0, 1fr));
      gap: {{ se_stts.card_gap }}px;
      margin-top: {{ se_stts.cards_margin_top }}px;
      margin-bottom: {{ se_stts.cards_margin_bottom }}px;
      padding-bottom: 0;
    }

    .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__card {
      flex: initial;
      scroll-snap-align: none;
      padding: {{ se_stts.card_padding_vertical }}px {{ se_stts.card_padding_horizontal }}px;
      min-height: {{ se_stts.card_min_height }}px;
      box-shadow: none;
    }

    .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__dots {
      display: none;
    }

    .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__avatar {
      width: {{ se_stts.avatar_size }}px;
      height: {{ se_stts.avatar_size }}px;
      margin-top: {{ se_stts.avatar_margin_top }}px;
      margin-bottom: {{ se_stts.avatar_margin_bottom }}px;
    }

    .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__name {
      margin-top: {{ se_stts.name_margin_top }}px;
      margin-bottom: {{ se_stts.name_margin_bottom }}px;
      font-size: {{ se_stts.name_size }}px;
    }

    .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__company {
      margin-top: {{ se_stts.company_margin_top }}px;
      margin-bottom: {{ se_stts.company_margin_bottom }}px;
      font-size: {{ se_stts.company_size }}px;
    }

    .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__stars {
      margin-top: {{ se_stts.rating_margin_top }}px;
      margin-bottom: {{ se_stts.rating_margin_bottom }}px;
    }

    .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__star {
      width: {{ se_stts.rating_size }}px;
      height: {{ se_stts.rating_size }}px;
    }

    .smart-team-testimonials-{{ section.id }} .smart-team-testimonials__quote {
      margin-top: {{ se_stts.quote_margin_top }}px;
      margin-bottom: {{ se_stts.quote_margin_bottom }}px;
      font-size: {{ se_stts.quote_size }}px;
    }
  }
{%- endstyle -%}

<section class="smart-team-testimonials-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="smart-team-testimonials__inner">
    <div class="smart-team-testimonials__header">
      {%- if se_stts.heading != blank -%}
        <h2 class="smart-team-testimonials__heading">{{ se_stts.heading }}</h2>
      {%- endif -%}

      {%- if se_stts.intro != blank -%}
        <div class="smart-team-testimonials__intro">{{ se_stts.intro | escape | newline_to_br }}</div>
      {%- endif -%}
    </div>

    {%- if testimonial_blocks.size > 0 -%}
      <div id="SmartTeamTestimonialsTrack-{{ section.id }}" class="smart-team-testimonials__grid">
        {%- for block in testimonial_blocks -%}
          <article class="smart-team-testimonials__card" {{ block.shopify_attributes }}>
            <div class="smart-team-testimonials__author">
              <div class="smart-team-testimonials__avatar">
                {%- if block.settings.avatar != blank -%}
                  {{ block.settings.avatar | image_url: width: 160 | image_tag: loading: loading_attribute, widths: '64, 96, 128, 160', alt: block.settings.avatar.alt | default: block.settings.name | escape }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag }}
                {%- endif -%}
              </div>

              <div class="smart-team-testimonials__author-text">
                {%- if block.settings.name != blank -%}
                  <h3 class="smart-team-testimonials__name">{{ block.settings.name }}</h3>
                {%- endif -%}

                {%- if block.settings.company != blank -%}
                  <p class="smart-team-testimonials__company">{{ block.settings.company }}</p>
                {%- endif -%}
              </div>
            </div>

            {%- if se_stts.show_rating -%}
              <div class="smart-team-testimonials__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                {%- for i in (1..5) -%}
                  <svg class="smart-team-testimonials__star{% if i <= block.settings.rating %} smart-team-testimonials__star--active{% endif %}" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill="currentColor" d="M10 1.7l2.5 5.1 5.6.8-4 3.9.9 5.5-5-2.6-5 2.6.9-5.5-4-3.9 5.6-.8L10 1.7z"/>
                  </svg>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- if block.settings.quote != blank -%}
              <div class="smart-team-testimonials__quote">{{ block.settings.quote | escape | newline_to_br }}</div>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>

      {%- if testimonial_blocks.size > 1 -%}
        <div class="smart-team-testimonials__dots" aria-label="Testimonial slides">
          {%- for block in testimonial_blocks -%}
            <button
              type="button"
              class="smart-team-testimonials__dot"
              aria-label="Go to testimonial {{ forloop.index }}"
              aria-controls="SmartTeamTestimonialsTrack-{{ section.id }}"
              data-smart-team-testimonials-dot="{{ forloop.index0 }}"
              {% if forloop.first %}aria-current="true"{% else %}aria-current="false"{% endif %}
            ></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

<script>
  (() => {
    const section = document.querySelector('.smart-team-testimonials-{{ section.id }}');
    if (!section || section.dataset.smartTeamTestimonialsInit === 'true') return;

    const track = section.querySelector('.smart-team-testimonials__grid');
    const cards = Array.from(section.querySelectorAll('.smart-team-testimonials__card'));
    const dots = Array.from(section.querySelectorAll('.smart-team-testimonials__dot'));
    if (!track || cards.length < 2 || dots.length === 0) return;

    section.dataset.smartTeamTestimonialsInit = 'true';

    const setActiveDot = (activeIndex) => {
      dots.forEach((dot, index) => {
        dot.setAttribute('aria-current', index === activeIndex ? 'true' : 'false');
      });
    };

    const updateActiveDot = () => {
      let activeIndex = 0;
      let closestDistance = Infinity;

      cards.forEach((card, index) => {
        const distance = Math.abs(card.offsetLeft - track.scrollLeft);
        if (distance < closestDistance) {
          closestDistance = distance;
          activeIndex = index;
        }
      });

      setActiveDot(activeIndex);
    };

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        cards[index].scrollIntoView({
          behavior: 'smooth',
          block: 'nearest',
          inline: 'start'
        });
      });
    });

    let scrollFrame = null;
    track.addEventListener('scroll', () => {
      if (scrollFrame) window.cancelAnimationFrame(scrollFrame);
      scrollFrame = window.requestAnimationFrame(updateActiveDot);
    }, { passive: true });

    window.addEventListener('resize', updateActiveDot);
    updateActiveDot();
  })();
</script>

{% schema %}
{
  "name": "Smart team testimonials",
  "tag": "section",
  "class": "t4s-section smart-team-testimonials-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why teams trust our digital business card solution"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro text",
      "default": "Organizations across North America rely on our platform to maintain consistent branding and eliminate the hassle of paper business cards."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 900,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Content width",
      "default": 1040
    },
    {
      "type": "range",
      "id": "header_width",
      "min": 420,
      "max": 1100,
      "step": 20,
      "unit": "px",
      "label": "Header width",
      "default": 860
    },
    {
      "type": "range",
      "id": "intro_width",
      "min": 420,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Intro width",
      "default": 680
    },
    {
      "type": "range",
      "id": "columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Desktop columns",
      "default": 3
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 8,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Desktop card gap",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_gap_mobile",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
