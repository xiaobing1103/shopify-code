{% comment %}TekMark AI Chat — Minimal light UI{% endcomment %}

<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
.page-content,.t4s-page-content,.main-content .container,.main-content .page-width,.shopify-section .container{padding:0!important;margin:0!important;max-width:100%!important}
#tk-app *{box-sizing:border-box!important;text-transform:none!important;letter-spacing:normal!important}
#tk-app,#tk-app div,#tk-app p,#tk-app span,#tk-app button,#tk-app textarea{font-family:'Inter',sans-serif!important}
#tk-app h1,#tk-app h2,#tk-app h3{font-size:inherit!important;font-weight:inherit!important;line-height:inherit!important;color:inherit!important;font-family:inherit!important}
@keyframes tkd{0%,60%,100%{opacity:.2;transform:translateY(0)}30%{opacity:1;transform:translateY(-3px)}}
@keyframes tku{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

#tk-app{width:100%;height:calc(100vh - var(--nh,80px) - var(--fh,60px));min-height:500px;display:flex;flex-direction:column;overflow:hidden;background:#fbfaf7;color:#1a1a1a;font-family:'Inter',sans-serif;font-size:14px;position:relative}

/* Welcome screen */
.tk-welcome-screen{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 24px;overflow-y:auto}
.tk-logo-row{display:flex;align-items:center;gap:14px;margin-bottom:36px}
.tk-logo-mark{width:32px;height:32px;display:flex;align-items:center;justify-content:center;color:#111;flex-shrink:0}
.tk-logo-mark svg{width:100%;height:100%}
.tk-welcome-title{font-family:'Instrument Serif',serif!important;font-size:46px!important;font-weight:400!important;color:#111!important;letter-spacing:-.5px!important;line-height:1!important}
.tk-welcome-title em{font-style:italic!important}

.tk-search-card{width:100%;max-width:720px;background:#fff;border:1px solid #e5e3dc;border-radius:18px;padding:18px 20px;box-shadow:0 4px 24px rgba(0,0,0,.03);transition:border-color .15s}
.tk-search-card:focus-within{border-color:#c4c1b4}
.tk-search-inp{width:100%;border:none!important;outline:none!important;resize:none!important;font-family:'Inter',sans-serif!important;font-size:15px!important;color:#111!important;background:transparent!important;min-height:44px;max-height:150px;line-height:1.5!important;padding:4px 0!important;box-shadow:none!important}
.tk-search-inp::placeholder{color:#a8a59a!important;font-style:italic!important}
.tk-search-actions{display:flex;align-items:center;justify-content:flex-end;margin-top:14px}
.tk-send-btn{width:34px;height:34px;background:#ebe9e1!important;border:none!important;border-radius:50%!important;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;padding:0!important}
.tk-send-btn:hover{background:#111!important}
.tk-send-btn:hover svg{stroke:#fff}
.tk-send-btn svg{width:15px;height:15px;transition:stroke .15s}
.tk-send-btn:disabled{opacity:.4!important;cursor:not-allowed!important}

.tk-examples{width:100%;max-width:720px;margin-top:28px}
.tk-ex-head{margin-bottom:10px}
.tk-ex-label{font-size:12px;color:#888;font-weight:500}
.tk-ex-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.tk-ex-card{padding:14px 16px;background:#fff;border:1px solid #e5e3dc;border-radius:12px;cursor:pointer;transition:all .15s;text-align:left;position:relative;min-height:68px;width:100%}
.tk-ex-card:hover{border-color:#c4c1b4!important;background:#fdfcf9!important;transform:translateY(-1px)!important}
.tk-ex-text{font-size:13px;color:#333;line-height:1.4;font-weight:500}
.tk-ex-arrow{position:absolute;right:10px;bottom:10px;color:#c4c1b4}
.tk-ex-arrow svg{width:11px;height:11px}

.tk-footer-note{margin-top:auto;padding:24px 24px 20px;font-size:12px;color:#b8b5a8;text-align:center;width:100%;max-width:720px}
.tk-footer-note::before,.tk-footer-note::after{content:'';display:inline-block;width:80px;height:1px;background:#e5e3dc;vertical-align:middle;margin:0 12px}

/* Chat mode */
.tk-msgs{flex:1;overflow-y:auto;padding:24px 0;background:#fbfaf7;display:none}
.tk-msgs::-webkit-scrollbar{width:3px}
.tk-msgs::-webkit-scrollbar-thumb{background:#e5e3dc;border-radius:2px}
.tk-mw{padding:3px 24px;max-width:720px;margin:0 auto;width:100%}
.tk-m{display:flex;gap:10px;margin-bottom:14px;animation:tku .25s ease forwards;opacity:0}
.tk-m.u{flex-direction:row-reverse}
.tk-av{width:28px;height:28px;border-radius:8px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;margin-top:1px}
.tk-av.a{background:#111;color:#fff}
.tk-av.u{background:#ebe9e1;color:#666}
.tk-b{max-width:calc(100% - 40px);padding:11px 15px;border-radius:14px;line-height:1.65;font-size:13.5px}
.tk-m.a .tk-b{background:#fff;border:1px solid #e5e3dc;color:#111;border-top-left-radius:4px;box-shadow:0 1px 3px rgba(0,0,0,.03)}
.tk-m.u .tk-b{background:#111;color:#fff;border-top-right-radius:4px}

.tk-tw{padding:3px 24px;max-width:720px;margin:0 auto;width:100%;display:none}
.tk-dots{display:inline-flex;gap:5px;align-items:center;padding:12px 15px;background:#fff;border:1px solid #e5e3dc;border-radius:14px;border-top-left-radius:4px}
.tk-dots s{width:4px;height:4px;background:#c4c1b4;border-radius:50%;display:inline-block;animation:tkd 1.4s ease-in-out infinite}
.tk-dots s:nth-child(2){animation-delay:.2s}.tk-dots s:nth-child(3){animation-delay:.4s}

.tk-err{display:none;max-width:720px;margin:0 auto 8px;padding:0 24px;width:100%}
.tk-erri{padding:10px 14px;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;font-size:12px;color:#ef4444}

.tk-bottom-input{display:none;flex-shrink:0;background:#fbfaf7;padding:14px 24px 20px;border-top:1px solid #ebe9e1}
.tk-bottom-inner{max-width:720px;margin:0 auto;background:#fff;border:1px solid #e5e3dc;border-radius:14px;padding:12px 14px;display:flex;align-items:flex-end;gap:10px;transition:border-color .15s}
.tk-bottom-inner:focus-within{border-color:#c4c1b4}
.tk-bottom-inp{flex:1;border:none!important;outline:none!important;resize:none!important;font-family:'Inter',sans-serif!important;font-size:14px!important;color:#111!important;background:transparent!important;min-height:28px;max-height:120px;line-height:1.5!important;box-shadow:none!important;padding:0!important}
.tk-bottom-inp::placeholder{color:#a8a59a!important}
.tk-bottom-send{width:32px;height:32px;background:#ebe9e1!important;border:none!important;border-radius:50%!important;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0;padding:0!important}
.tk-bottom-send:hover{background:#111!important}
.tk-bottom-send:hover svg{stroke:#fff}
.tk-bottom-send svg{width:14px;height:14px;transition:stroke .15s}
.tk-bottom-send:disabled{opacity:.4!important;cursor:not-allowed!important}

#tk-app.chatting .tk-welcome-screen{display:none}
#tk-app.chatting .tk-msgs{display:block}
#tk-app.chatting .tk-bottom-input{display:block}

@media(max-width:768px){
  .tk-welcome-title{font-size:32px!important}
  .tk-ex-grid{grid-template-columns:1fr 1fr}
  .tk-logo-row{margin-bottom:24px}
}
@media(max-width:500px){
  .tk-ex-grid{grid-template-columns:1fr}
  .tk-welcome-title{font-size:26px!important}
  .tk-logo-mark{width:26px;height:26px}
}
</style>

<div id="tk-app">
  <div class="tk-welcome-screen" id="tk-welcome">
    <div class="tk-logo-row">
      <div class="tk-logo-mark">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="4" y="4" width="24" height="24" rx="5" stroke="currentColor" stroke-width="2" fill="none"/>
          <circle cx="16" cy="16" r="3" fill="currentColor"/>
        </svg>
      </div>
      <div class="tk-welcome-title">How can I <em>help?</em></div>
    </div>

    <div class="tk-search-card">
      <textarea class="tk-search-inp" id="tk-search" rows="1" placeholder="Ask about your order, card setup, or anything else…"></textarea>
      <div class="tk-search-actions">
        <button class="tk-send-btn" onclick="tkGo()">
          <svg viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
        </button>
      </div>
    </div>

    <div class="tk-examples">
      <div class="tk-ex-head"><div class="tk-ex-label">Prompt examples</div></div>
      <div class="tk-ex-grid">
        <button class="tk-ex-card" onclick="tkGo('My NFC card isn\'t working')">
          <div class="tk-ex-text">My NFC card isn't tapping</div>
          <div class="tk-ex-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg></div>
        </button>
        <button class="tk-ex-card" onclick="tkGo('How do I activate my card?')">
          <div class="tk-ex-text">How do I activate my card?</div>
          <div class="tk-ex-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg></div>
        </button>
        <button class="tk-ex-card" onclick="tkGo('Track my order')">
          <div class="tk-ex-text">Track my order status</div>
          <div class="tk-ex-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg></div>
        </button>
        <button class="tk-ex-card" onclick="tkGo('Bulk / B2B pricing')">
          <div class="tk-ex-text">B2B & bulk pricing</div>
          <div class="tk-ex-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg></div>
        </button>
      </div>
    </div>

    <div class="tk-footer-note">Ask TekMark anything</div>
  </div>

  <div class="tk-msgs" id="tk-msgs"></div>

  <div class="tk-tw" id="tk-tw">
    <div style="display:flex;gap:10px;align-items:flex-start">
      <div class="tk-av a">TM</div>
      <div class="tk-dots"><s></s><s></s><s></s></div>
    </div>
  </div>

  <div class="tk-err" id="tk-err"><div class="tk-erri" id="tk-errt"></div></div>

  <div class="tk-bottom-input">
    <div class="tk-bottom-inner">
      <textarea class="tk-bottom-inp" id="tk-bottom" rows="1" placeholder="Ask a follow-up…"></textarea>
      <button class="tk-bottom-send" id="tk-bottom-btn" onclick="tkGo()">
        <svg viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
(function(){
  function gh(s){var e=document.querySelector(s);return e?e.offsetHeight:0}
  function sh(){
    var n=gh('header.site-header,header#header,.site-header,.t4s-header,.header,#shopify-section-header > *');
    var f=gh('footer.site-footer,footer#footer,.site-footer,.t4s-footer,.footer');
    if(n<20)n=80;if(f<20)f=60;
    document.getElementById('tk-app').style.height='calc(100vh - '+n+'px - '+f+'px)';
  }
  sh();window.addEventListener('resize',sh);

  var API='https://pcmrw5ufsgdcrtrshwcst2jhtu0fwais.lambda-url.us-east-2.on.aws/api/v1/chat';

  // Fresh session every page load — no storage persistence
  var sid='s'+Math.random().toString(36).substr(2,10)+'_'+Date.now();
  var hist=[];
  var flds={};
  var lastIntent='';
  var lastFollowup=false;
  var busy=false;

  var app=document.getElementById('tk-app');
  var msgs=document.getElementById('tk-msgs');
  var search=document.getElementById('tk-search');
  var bottom=document.getElementById('tk-bottom');
  var tw=document.getElementById('tk-tw');
  var err=document.getElementById('tk-err');
  var errt=document.getElementById('tk-errt');

  function add(role,text){
    var w=document.createElement('div');w.className='tk-mw';
    var m=document.createElement('div');m.className='tk-m '+role;
    var av=document.createElement('div');av.className='tk-av '+role;av.textContent=role==='a'?'TM':'You';
    var b=document.createElement('div');b.className='tk-b';
    b.innerHTML=text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
      .replace(/`(.*?)`/g,'<code style="background:#f3f1ea;padding:1px 5px;border-radius:3px;font-size:12px">$1</code>')
      .replace(/\n/g,'<br>');
    m.appendChild(av);m.appendChild(b);w.appendChild(m);msgs.appendChild(w);
    setTimeout(function(){msgs.scrollTop=msgs.scrollHeight;},50);
  }

  function buildFields(text){
    var f=Object.assign({},flds);
    if(lastFollowup && lastIntent==='ORDER_TRACKING'){
      var clean=text.replace('#','').trim();
      if(/^\d{3,8}$/.test(clean)) f.order_number=clean;
    }
    return f;
  }

  window.tkGo=function(preset){
    var text=preset||search.value.trim()||bottom.value.trim();
    if(!text||busy)return;
    app.classList.add('chatting');
    search.value='';bottom.value='';
    search.style.height='auto';bottom.style.height='auto';
    add('u',text);busy=true;tw.style.display='block';err.style.display='none';
    setTimeout(function(){msgs.scrollTop=msgs.scrollHeight;},50);
    hist.push({role:'user',content:text});

    fetch(API,{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        session_id:sid,message:text,language:'en',
        conversation_history:hist.slice(-10),
        collected_fields:buildFields(text)
      })})
    .then(function(r){if(!r.ok)throw r.status;return r.json();})
    .then(function(d){
      var rep=d.reply||'Sorry, something went wrong.';
      hist.push({role:'assistant',content:rep});
      lastIntent=d.intent||'';
      lastFollowup=d.requires_followup||false;
      if(d.collected_fields){flds=Object.assign(flds,d.collected_fields);}
      busy=false;tw.style.display='none';add('a',rep);
    })
    .catch(function(){
      busy=false;tw.style.display='none';
      errt.textContent='Unable to connect. Please try again.';
      err.style.display='block';setTimeout(function(){err.style.display='none';},5000);
    });
  };

  function ar(el,max){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,max)+'px';}
  search.addEventListener('input',function(){ar(this,150);});
  bottom.addEventListener('input',function(){ar(this,120);});
  search.addEventListener('keydown',function(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();tkGo();}});
  bottom.addEventListener('keydown',function(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();tkGo();}});
})();
</script>

