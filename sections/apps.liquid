<div class="{% if section.settings.include_margins %}t4s-container{% endif %} t4s-apps-section-{{ section.id }}"{% if settings.animations_reveal_on_scroll %} hdt-reveal="fade-in"{% endif %}>
  {%- for block in section.blocks -%}
    {%- render block -%}
  {%- endfor -%}
</div>

<style>
  {%- if section.settings.enable_full_width -%}
  /* Full Width Mode */
  .t4s-apps-section-{{ section.id }}.t4s-container {
    max-width: 100% !important;
    width: 100% !important;
    padding-left: {{ section.settings.full_width_padding }}px !important;
    padding-right: {{ section.settings.full_width_padding }}px !important;
  }
  
  @media (max-width: 1024px) {
    .t4s-apps-section-{{ section.id }}.t4s-container {
      padding-left: {{ section.settings.full_width_padding_tablet }}px !important;
      padding-right: {{ section.settings.full_width_padding_tablet }}px !important;
    }
  }
  
  @media (max-width: 767px) {
    .t4s-apps-section-{{ section.id }}.t4s-container {
      padding-left: {{ section.settings.full_width_padding_mobile }}px !important;
      padding-right: {{ section.settings.full_width_padding_mobile }}px !important;
    }
  }
  {%- elsif section.settings.custom_container_width > 0 -%}
  /* Custom Width Mode */
  .t4s-apps-section-{{ section.id }}.t4s-container {
    max-width: {{ section.settings.custom_container_width }}px !important;
  }
  
  @media (max-width: 1024px) {
    {%- if section.settings.custom_container_width_tablet > 0 -%}
    .t4s-apps-section-{{ section.id }}.t4s-container {
      max-width: {{ section.settings.custom_container_width_tablet }}px !important;
    }
    {%- endif -%}
  }
  
  @media (max-width: 767px) {
    {%- if section.settings.custom_container_width_mobile > 0 -%}
    .t4s-apps-section-{{ section.id }}.t4s-container {
      max-width: {{ section.settings.custom_container_width_mobile }}px !important;
    }
    {%- endif -%}
  }
  {%- endif -%}
</style>

{% schema %}
{
  "name": "App",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "include_margins",
      "default": true,
      "label": "Make section margins the same as theme"
    },
    {
      "type": "header",
      "content": "Container Width Settings"
    },
    {
      "type": "paragraph",
      "content": "Choose between full width or custom width. Full width takes priority over custom width settings."
    },
    {
      "type": "checkbox",
      "id": "enable_full_width",
      "label": "Enable Full Width",
      "info": "Make the section span the entire screen width",
      "default": false
    },
    {
      "type": "number",
      "id": "full_width_padding",
      "label": "Full Width - Desktop Padding (px)",
      "info": "Left and right padding when full width is enabled",
      "default": 30
    },
    {
      "type": "number",
      "id": "full_width_padding_tablet",
      "label": "Full Width - Tablet Padding (px)",
      "info": "Left and right padding for tablet devices",
      "default": 20
    },
    {
      "type": "number",
      "id": "full_width_padding_mobile",
      "label": "Full Width - Mobile Padding (px)",
      "info": "Left and right padding for mobile devices",
      "default": 15
    },
    {
      "type": "header",
      "content": "Custom Width Settings (if Full Width is disabled)"
    },
    {
      "type": "paragraph",
      "content": "Set custom container width. Set to 0 to use theme default (1200px)."
    },
    {
      "type": "number",
      "id": "custom_container_width",
      "label": "Desktop Container Width (px)",
      "info": "Set to 0 for default (1200px). Recommended: 1200-1920px",
      "default": 0
    },
    {
      "type": "number",
      "id": "custom_container_width_tablet",
      "label": "Tablet Container Width (px)",
      "info": "Set to 0 to use desktop width",
      "default": 0
    },
    {
      "type": "number",
      "id": "custom_container_width_mobile",
      "label": "Mobile Container Width (px)",
      "info": "Set to 0 to use tablet/desktop width",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "App"
    }
  ]
}
{% endschema %}
