endor":false,"use_cdt":false,"image_ratio":"ratio1_1","image_size":"cover","image_position":"8","content_align":"center","limit":24,"enable_listing":false,"enable_listing_default":false,"col_dk":"4","col_tb":"3","col_mb":"2","space_h_item":"30","space_v_item":"30","space_h_item_mb":"10","space_v_item_mb":"10","layout_des":"1","use_pagination":"default","enable_bar_lm":true,"btn_icon":false,"button_style":"outline","btns_size":"medium","btns_cl":"primary","button_effect":"sweep-to-right","btn_pos":"t4s-text-center","type_filters":"facets","layout":"t4s-container-wrap","cl_bg":"#fbfbfd","cl_bg_gradient":"","mg":"70px,,50px,","pd":"","mg_tb":"","pd_tb":"","mg_mb":",,30px,","pd_mb":""}},"sidebar":{"type":"sidebar-collection","disabled":true,"settings":{"enable_drawer":false,"space":50,"size":"medium","br_style":"none","brcolor":"#222222","sidebar_bdr":0,"sidebar_pd":15}},"ss_glow_faq_em6pnR":{"type":"ss-glow-faq","blocks":{"card_3EhkgU":{"type":"card","settings":{"title":"How Does Our Digital Business Card Work?","content":"Your TekMark digital business card uses NFC technology to share your information instantly. When someone taps their phone on your TekMark card, it automatically opens your personalized profile, no apps or downloads needed.\n\nYour profile can include your contact details, social media links, website, payment links, files, and anything else you want to share. You control what’s on it, and you can update it anytime.\n\nJust tap → your info appears → you make the connection."}},"card_LN9jW4":{"type":"card","settings":{"title":"Do I need to install an app to use the digital business card?","content":"No app is required. With a quick tap, your digital profile opens directly in the visitor’s mobile browser, where they can call, email, save your contact, or share their details. It works on all modern iPhone and Android devices."}},"card_a3g76L":{"type":"card","settings":{"title":"Is there a subscription fee?","content":"No. Your TekMark digital business card comes with lifetime access to your TekHub profile—no monthly or yearly fees. You pay once for your card or table tent."}},"card_DxCzTh":{"type":"card","settings":{"title":"Does the other person need an app for the digital business card to work?","content":"No. The other person doesn’t need any app, account, or TekMark product. They just tap your card with their phone, and your profile opens instantly in their browser. From there, they can call, email, save your contact, or share their details."}},"card_f4f6Ag":{"type":"card","settings":{"title":"Do I need to put all my information on the physical card itself?","content":"No. You don’t have to print any personal details on the card itself. Most people only add their logo or a simple design. All your contact information lives in your TekMark digital profile, which others can access by tapping the card or scanning the QR code."}},"card_M6tEnd":{"type":"card","settings":{"title":"Is there a way for someone to save or exchange contact information?","content":"Save Contact lets the visitor instantly save your details to their phone—no signup or sharing needed.\n\nExchange Contact allows both sides to share information. The visitor saves your details and can also send their own contact info back to you through the same page."}},"card_WM4c99":{"type":"card","settings":{"title":"Can I link multiple cards to one account?","content":"Yes. Multiple cards\/displays can be linked to a single account. Data stays in sync, and all collected contacts are automatically consolidated in the Platform"}}},"block_order":["card_3EhkgU","card_LN9jW4","card_a3g76L","card_DxCzTh","card_f4f6Ag","card_M6tEnd","card_WM4c99"],"name":"SS - Glow FAQ","settings":{"title":"<p><em>Frequently<\/em> Asked Questions<\/p>","collapse_other":true,"open_first":false,"header_font_size":40,"header_mob_font_size":28,"question_color":"#1c1c1f","content_text_color":"#121212","blur_color":"#dbd7f2","gradient_color_1":"#2222de","gradient_color_2":"#659bff","gradie