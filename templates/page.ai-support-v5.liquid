{% comment %}TekMark AI Support v5 — Aurora mesh background{% endcomment %}

<link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">

<style>
/* ── Reset Kalles interference ────────────────────────── */
.page-content,.t4s-page-content,.main-content .container,
.main-content .page-width,.shopify-section .container{
  padding:0!important;margin:0!important;max-width:100%!important;
}
#tk-app *{box-sizing:border-box!important;}
#tk-app h1,#tk-app h2,#tk-app h3,#tk-app p,#tk-app span,
#tk-app div,#tk-app button,#tk-app textarea,#tk-app a{
  font-family:inherit!important;text-transform:none!important;
  letter-spacing:normal!important;color:inherit!important;
}
#tk-app h1,#tk-app h2{font-size:inherit!important;font-weight:inherit!important;line-height:inherit!important;}

/* ── Animations ───────────────────────────────────────── */
@keyframes tkpulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.85)}}
@keyframes tkdot{0%,60%,100%{opacity:.15;transform:translateY(0)}30%{opacity:1;transform:translateY(-4px)}}
@keyframes tkup{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes aurora1{0%{transform:translate(0%,0%) rotate(0deg) scale(1)}33%{transform:translate(8%,6%) rotate(120deg) scale(1.15)}66%{transform:translate(-5%,10%) rotate(240deg) scale(.9)}100%{transform:translate(0%,0%) rotate(360deg) scale(1)}}
@keyframes aurora2{0%{transform:translate(0%,0%) rotate(0deg) scale(1)}33%{transform:translate(-10%,-8%) rotate(-140deg) scale(1.2)}66%{transform:translate(6%,-5%) rotate(-280deg) scale(.85)}100%{transform:translate(0%,0%) rotate(-360deg) scale(1)}}
@keyframes aurora3{0%{transform:translate(0%,0%) scale(1)}50%{transform:translate(4%,-8%) scale(1.25)}100%{transform:translate(0%,0%) scale(1)}}
@keyframes grain{0%,100%{transform:translate(0,0)}10%{transform:translate(-2%,-3%)}20%{transform:translate(3%,1%)}30%{transform:translate(-1%,4%)}40%{transform:translate(4%,-2%)}50%{transform:translate(-3%,3%)}60%{transform:translate(1%,-4%)}70%{transform:translate(-4%,2%)}80%{transform:translate(2%,3%)}90%{transform:translate(-1%,-1%)}}

/* ── App shell ────────────────────────────────────────── */
#tk-app{
  width:100%;
  height:calc(100vh - var(--tk-nav,80px) - var(--tk-foot,80px));
  min-height:420px;
  display:flex;
  flex-direction:column;
  overflow:hidden;
  position:relative;
  background:#07071a;
  color:#e8eaf4;
  font-family:'DM Mono',monospace;
  font-size:14px;
  isolation:isolate;
}

/* ── Aurora mesh ──────────────────────────────────────── */
.tk-aurora{position:absolute;inset:0;overflow:hidden;z-index:0;pointer-events:none}
.tk-orb{position:absolute;border-radius:50%;filter:blur(80px);mix-blend-mode:screen}
.tk-orb1{width:70%;height:70%;background:radial-gradient(circle,rgba(88,28,255,.55) 0%,rgba(59,7,180,.3) 50%,transparent 70%);top:-20%;right:-10%;animation:aurora1 18s ease-in-out infinite}
.tk-orb2{width:60%;height:60%;background:radial-gradient(circle,rgba(124,58,237,.5) 0%,rgba(79,16,232,.25) 50%,transparent 70%);bottom:-15%;left:-8%;animation:aurora2 22s ease-in-out infinite}
.tk-orb3{width:45%;height:45%;background:radial-gradient(circle,rgba(56,189,248,.35) 0%,rgba(14,165,233,.15) 50%,transparent 70%);top:20%;left:25%;animation:aurora3 28s ease-in-out infinite}

/* Noise grain overlay */
.tk-grain{position:absolute;inset:-50%;width:200%;height:200%;z-index:1;pointer-events:none;opacity:.04;animation:grain 8s steps(1) infinite;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E")}

/* Grid overlay */
.tk-grid{position:absolute;inset:0;z-index:1;pointer-events:none;background-image:linear-gradient(rgba(139,92,246,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(139,92,246,.06) 1px,transparent 1px);background-size:52px 52px}

/* ── Header ───────────────────────────────────────────── */
.tk-hdr{
  position:relative;z-index:20;
  display:flex;align-items:center;justify-content:space-between;
  padding:13px 28px;
  border-bottom:1px solid rgba(139,92,246,.18);
  background:rgba(7,7,26,.75);
  backdrop-filter:blur(24px);
  flex-shrink:0;
}
.tk-hdr-l{display:flex;align-items:center;gap:12px}
.tk-logo{
  width:32px;height:32px;
  background:linear-gradient(135deg,rgba(139,92,246,.3),rgba(88,28,255,.15));
  border:1px solid rgba(139,92,246,.5);
  border-radius:9px;
  display:flex;align-items:center;justify-content:center;
  font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:11px;
  color:#c4b5fd;
  box-shadow:0 0 20px rgba(139,92,246,.2),inset 0 1px 0 rgba(255,255,255,.07);
  flex-shrink:0;
}
.tk-name{font-family:'Cabinet Grotesk',sans-serif;font-weight:700;font-size:15px;color:#e8eaf4;letter-spacing:-.2px}
.tk-sub2{font-size:11px;color:rgba(196,181,253,.6);font-weight:300;margin-top:1px;font-family:'DM Mono',monospace}
.tk-badge{
  display:flex;align-items:center;gap:6px;
  padding:5px 12px;
  background:rgba(139,92,246,.12);
  border:1px solid rgba(139,92,246,.25);
  border-radius:20px;
  font-size:11px;color:rgba(196,181,253,.8);font-family:'DM Mono',monospace;
}
.tk-badge::before{content:'';width:5px;height:5px;background:#a78bfa;border-radius:50%;box-shadow:0 0 8px #a78bfa;animation:tkpulse 2.5s ease-in-out infinite}

/* ── Messages ─────────────────────────────────────────── */
.tk-msgs{position:relative;z-index:10;flex:1;overflow-y:auto;padding:20px 0;scroll-behavior:smooth}
.tk-msgs::-webkit-scrollbar{width:2px}
.tk-msgs::-webkit-scrollbar-thumb{background:rgba(139,92,246,.3);border-radius:1px}

/* ── Welcome screen ───────────────────────────────────── */
.tk-welcome-wrap{max-width:760px;margin:36px auto 0;padding:0 28px}
.tk-chip{
  display:inline-flex;align-items:center;gap:8px;
  padding:5px 14px;
  background:rgba(139,92,246,.12);
  border:1px solid rgba(139,92,246,.3);
  border-radius:20px;
  font-size:11px;color:#c4b5fd;
  font-family:'DM Mono',monospace;
  margin-bottom:20px;
}
.tk-chip::before{content:'✦';font-size:9px;color:#a78bfa}
.tk-wtitle{
  font-family:'Cabinet Grotesk',sans-serif;
  font-size:clamp(24px,4vw,38px);
  font-weight:800;
  line-height:1.1;
  letter-spacing:-.5px;
  color:#f0eeff;
  margin-bottom:12px;
}
.tk-wtitle em{
  font-style:normal;
  background:linear-gradient(135deg,#c4b5fd 0%,#818cf8 50%,#60a5fa 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.tk-wdesc{color:rgba(196,181,253,.55);font-size:13px;font-weight:300;line-height:1.65;margin-bottom:24px;max-width:480px}
.tk-pills{display:flex;flex-wrap:wrap;gap:8px}
.tk-pill{
  padding:8px 15px;
  background:rgba(139,92,246,.08);
  border:1px solid rgba(139,92,246,.2);
  border-radius:9px;
  font-size:12px;color:rgba(196,181,253,.7);
  cursor:pointer;font-family:'DM Mono',monospace;font-weight:300;
  transition:all .2s ease;white-space:nowrap;
  position:relative;overflow:hidden;
}
.tk-pill::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(139,92,246,.15),rgba(56,189,248,.08));opacity:0;transition:opacity .2s}
.tk-pill:hover{border-color:rgba(139,92,246,.55);color:#c4b5fd;transform:translateY(-1px);box-shadow:0 4px 20px rgba(139,92,246,.15)}
.tk-pill:hover::before{opacity:1}

/* ── Divider ──────────────────────────────────────────── */
.tk-divider{max-width:760px;margin:0 auto 16px;padding:0 28px;display:none;align-items:center;gap:12px}
.tk-divline{flex:1;height:1px;background:rgba(139,92,246,.15)}
.tk-divtxt{font-size:10px;color:rgba(139,92,246,.35);font-weight:300;letter-spacing:2px;text-transform:uppercase;font-family:'DM Mono',monospace}

/* ── Message bubbles ──────────────────────────────────── */
.tk-mwrap{padding:3px 28px;max-width:760px;margin:0 auto;width:100%}
.tk-msg{display:flex;gap:10px;margin-bottom:14px;animation:tkup .28s ease forwards;opacity:0}
.tk-msg.user{flex-direction:row-reverse}
.tk-av{
  width:26px;height:26px;border-radius:7px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:9px;margin-top:2px;font-family:'Cabinet Grotesk',sans-serif;font-weight:800;
}
.tk-av.ai{background:rgba(139,92,246,.15);border:1px solid rgba(139,92,246,.35);color:#c4b5fd}
.tk-av.user{background:rgba(56,189,248,.1);border:1px solid rgba(56,189,248,.25);color:#7dd3fc;font-size:9px}
.tk-bub{
  max-width:calc(100% - 38px);padding:11px 15px;
  border-radius:12px;line-height:1.72;font-size:13.5px;font-weight:300;
  font-family:'DM Mono',monospace;
}
.tk-msg.ai .tk-bub{
  background:rgba(139,92,246,.07);
  border:1px solid rgba(139,92,246,.16);
  color:#e2deff;border-top-left-radius:4px;
  backdrop-filter:blur(8px);
}
.tk-msg.user .tk-bub{
  background:rgba(56,189,248,.08);
  border:1px solid rgba(56,189,248,.2);
  color:#e0f2fe;border-top-right-radius:4px;
}

/* ── Typing ───────────────────────────────────────────── */
.tk-tw{display:none;padding:3px 28px;max-width:760px;margin:0 auto;width:100%}
.tk-tdots{
  display:inline-flex;gap:5px;align-items:center;
  padding:12px 16px;
  background:rgba(139,92,246,.07);
  border:1px solid rgba(139,92,246,.16);
  border-radius:12px;border-top-left-radius:4px;
  backdrop-filter:blur(8px);
}
.tk-tdots span{width:4px;height:4px;background:#a78bfa;border-radius:50%;display:inline-block;animation:tkdot 1.4s ease-in-out infinite}
.tk-tdots span:nth-child(2){animation-delay:.2s}
.tk-tdots span:nth-child(3){animation-delay:.4s}

/* ── Error ────────────────────────────────────────────── */
.tk-err{display:none;max-width:760px;margin:0 auto 8px;padding:0 28px;width:100%}
.tk-erri{padding:10px 14px;background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);border-radius:8px;font-size:12px;color:#fca5a5;font-weight:300}

/* ── Input area ───────────────────────────────────────── */
.tk-inp-wrap{
  position:relative;z-index:20;flex-shrink:0;
  border-top:1px solid rgba(139,92,246,.15);
  background:rgba(7,7,26,.88);
  backdrop-filter:blur(24px);
  padding:14px 28px;
}
.tk-inp-row{max-width:760px;margin:0 auto;display:flex;gap:10px;align-items:flex-end}
.tk-inp{
  flex:1;
  background:rgba(139,92,246,.07)!important;
  border:1px solid rgba(139,92,246,.22)!important;
  border-radius:12px!important;
  padding:12px 16px!important;
  color:#e2deff!important;
  font-family:'DM Mono',monospace!important;
  font-size:13px!important;font-weight:300!important;
  resize:none!important;outline:none!important;
  box-shadow:none!important;
  min-height:44px;max-height:120px;line-height:1.5!important;
  transition:border-color .2s,box-shadow .2s;
  backdrop-filter:blur(8px);
}
.tk-inp::placeholder{color:rgba(139,92,246,.35)!important}
.tk-inp:focus{border-color:rgba(139,92,246,.5)!important;box-shadow:0 0 0 3px rgba(139,92,246,.08)!important}
.tk-send{
  width:44px!important;height:44px!important;
  background:linear-gradient(135deg,#7c3aed,#4f46e5)!important;
  border:none!important;border-radius:12px!important;
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  flex-shrink:0;padding:0!important;
  box-shadow:0 0 20px rgba(124,58,237,.4),0 4px 12px rgba(0,0,0,.3)!important;
  transition:all .15s ease;
}
.tk-send:hover{transform:scale(1.05)!important;box-shadow:0 0 28px rgba(124,58,237,.6),0 4px 16px rgba(0,0,0,.4)!important}
.tk-send:active{transform:scale(.97)!important}
.tk-send:disabled{opacity:.3!important;cursor:not-allowed!important;transform:none!important;box-shadow:none!important}
.tk-hint{max-width:760px;margin:7px auto 0;font-size:11px;color:rgba(139,92,246,.3);font-family:'DM Mono',monospace}

@media(max-width:600px){
  .tk-hdr,.tk-inp-wrap{padding:12px 16px!important}
  .tk-mwrap,.tk-tw,.tk-welcome-wrap,.tk-divider,.tk-err{padding:0 16px!important}
  .tk-wtitle{font-size:22px}
}
</style>

<div id="tk-app">
  <!-- Aurora background -->
  <div class="tk-aurora">
    <div class="tk-orb tk-orb1"></div>
    <div class="tk-orb tk-orb2"></div>
    <div class="tk-orb tk-orb3"></div>
  </div>
  <div class="tk-grain"></div>
  <div class="tk-grid"></div>

  <!-- Header -->
  <div class="tk-hdr">
    <div class="tk-hdr-l">
      <div class="tk-logo">TM</div>
      <div>
        <div class="tk-name">TekMark Support</div>
        <div class="tk-sub2">AI-powered assistant</div>
      </div>
    </div>
    <div class="tk-badge">Online</div>
  </div>

  <!-- Messages -->
  <div class="tk-msgs" id="tk-msgs">
    <div class="tk-welcome-wrap" id="tk-welcome">
      <div class="tk-chip">Welcome to TekMark AI ✦</div>
      <div class="tk-wtitle">Hi there.<br>How can we <em>help you?</em></div>
      <div class="tk-wdesc">Ask about products, setup, troubleshooting, or your orders. I'm here 24/7.</div>
      <div class="tk-pills">
        <button class="tk-pill" onclick="tkGo('My NFC card isn\'t working')">My NFC card isn't working</button>
        <button class="tk-pill" onclick="tkGo('How do I activate my card?')">How do I activate my card?</button>
        <button class="tk-pill" onclick="tkGo('What products do you offer?')">What products do you offer?</button>
        <button class="tk-pill" onclick="tkGo('Track my order')">Track my order</button>
        <button class="tk-pill" onclick="tkGo('Bulk / B2B pricing')">Bulk / B2B pricing</button>
        <button class="tk-pill" onclick="tkGo('How to update my profile?')">How to update my profile?</button>
      </div>
    </div>
    <div class="tk-divider" id="tk-div">
      <div class="tk-divline"></div>
      <div class="tk-divtxt">Conversation</div>
      <div class="tk-divline"></div>
    </div>
  </div>

  <!-- Typing -->
  <div class="tk-tw" id="tk-tw">
    <div style="display:flex;gap:10px;align-items:flex-start">
      <div class="tk-av ai">TM</div>
      <div class="tk-tdots"><span></span><span></span><span></span></div>
    </div>
  </div>

  <!-- Error -->
  <div class="tk-err" id="tk-err">
    <div class="tk-erri" id="tk-errt"></div>
  </div>

  <!-- Input -->
  <div class="tk-inp-wrap">
    <div class="tk-inp-row">
      <textarea class="tk-inp" id="tk-inp" rows="1" placeholder="Ask anything about TekMark..."></textarea>
      <button class="tk-send" id="tk-btn" onclick="tkGo()">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>
    <div class="tk-hint">Enter to send · Shift+Enter for new line</div>
  </div>
</div>

<script>
(function(){
  function getH(sel){var el=document.querySelector(sel);return el?el.offsetHeight:0;}
  function setH(){
    var nav=getH('header.site-header,header#header,.site-header,#shopify-section-header > *,.t4s-header,.header');
    var foot=getH('footer.site-footer,footer#footer,.site-footer,.t4s-footer,.footer');
    if(nav<20)nav=80;if(foot<20)foot=60;
    document.getElementById('tk-app').style.height='calc(100vh - '+nav+'px - '+foot+'px)';
  }
  setH();window.addEventListener('resize',setH);

  var API='https://pcmrw5ufsgdcrtrshwcst2jhtu0fwais.lambda-url.us-east-2.on.aws/api/v1/chat';
  var sid=sessionStorage.getItem('tk_s5');
  if(!sid){sid='s'+Math.random().toString(36).substr(2,10);sessionStorage.setItem('tk_s5',sid);}
  var hist=JSON.parse(sessionStorage.getItem('tk_h5')||'[]');
  var flds=JSON.parse(sessionStorage.getItem('tk_f5')||'{}');
  var busy=false;
  var msgs=document.getElementById('tk-msgs'),inp=document.getElementById('tk-inp'),btn=document.getElementById('tk-btn');
  var tw=document.getElementById('tk-tw'),wel=document.getElementById('tk-welcome'),div=document.getElementById('tk-div');
  var err=document.getElementById('tk-err'),errt=document.getElementById('tk-errt');

  if(hist.length>0){
    wel.style.display='none';div.style.display='flex';
    hist.forEach(function(m){addMsg(m.role==='user'?'user':'ai',m.content);});
  }

  function addMsg(role,text){
    var isAI=role==='ai';
    var w=document.createElement('div');w.className='tk-mwrap';
    var m=document.createElement('div');m.className='tk-msg '+(isAI?'ai':'user');
    var av=document.createElement('div');av.className='tk-av '+(isAI?'ai':'user');
    av.textContent=isAI?'TM':'You';
    var b=document.createElement('div');b.className='tk-bub';
    b.innerHTML=fmt(text);
    m.appendChild(av);m.appendChild(b);w.appendChild(m);msgs.appendChild(w);
    setTimeout(function(){msgs.scrollTop=msgs.scrollHeight;},50);
  }

  function fmt(t){
    return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/\*\*(.*?)\*\*/g,'<strong style="color:#c4b5fd;font-weight:500">$1</strong>')
      .replace(/`(.*?)`/g,'<code style="background:rgba(139,92,246,0.15);color:#c4b5fd;padding:1px 6px;border-radius:4px;font-size:12px">$1</code>')
      .replace(/\n/g,'<br>');
  }

  window.tkGo=function(preset){
    var text=preset||inp.value.trim();
    if(!text||busy)return;
    if(wel.style.display!=='none'){wel.style.display='none';div.style.display='flex';}
    inp.value='';inp.style.height='auto';
    addMsg('user',text);busy=true;btn.disabled=true;
    tw.style.display='block';err.style.display='none';
    setTimeout(function(){msgs.scrollTop=msgs.scrollHeight;},50);
    hist.push({role:'user',content:text});
    fetch(API,{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({session_id:sid,message:text,language:'en',
        conversation_history:hist.slice(-10),collected_fields:flds})})
    .then(function(r){if(!r.ok)throw r.status;return r.json();})
    .then(function(d){
      var rep=d.reply||'Sorry, something went wrong.';
      hist.push({role:'assistant',content:rep});
      sessionStorage.setItem('tk_h5',JSON.stringify(hist));
      if(d.collected_fields){flds=Object.assign(flds,d.collected_fields);sessionStorage.setItem('tk_f5',JSON.stringify(flds));}
      busy=false;btn.disabled=false;tw.style.display='none';addMsg('ai',rep);
    })
    .catch(function(){
      busy=false;btn.disabled=false;tw.style.display='none';
      errt.textContent='Unable to connect. Please try again.';
      err.style.display='block';setTimeout(function(){err.style.display='none';},5000);
    });
  };

  inp.addEventListener('input',function(){this.style.height='auto';this.style.height=Math.min(this.scrollHeight,120)+'px';});
  inp.addEventListener('keydown',function(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();tkGo();}});
})();
</script>
